              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
using System.Windows.Forms;
using MySqlX.XDevAPI;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["User::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["User::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value);
            string packageName = Dts.Variables["System::PackageName"].Value.ToString();
            string Email = Dts.Variables["User::Email"].Value.ToString();

            string filePath = $@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\dados\";
            string file = "dados_" + revenda + ".xlsx";

            File.Delete(filePath + file);

            COB_VOL(Dts, filePath, file, "COB_VOL");
            SKU_POR_PDV(Dts, filePath, file, "SKU_POR_PDV");
            FDS(Dts, filePath, file, "FDS");
            MATERIAIS(Dts, filePath, file, "MATERIAIS");
            HEISHOP(Dts, filePath, file, "HEISHOP");
            CLIENTES_ESTAVEIS_RGB(Dts, filePath, file, "CLIENTES_ESTAVEIS_RGB");
            bd_Vendedores(Dts, filePath, file, "BD_VENDEDORES");
            dados_relatorios(Dts, filePath, file, "dados_relatorios");

            ExecutarMacroExcel($@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\vba.xlsm", "build.formataArquivo", revenda, packageName);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void COB_VOL(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@" WITH  agregadores AS (                                        
				                                           SELECT   a.cod_agregador
				                                                  , a.dados_agregador ->> 'descricao' AS descricao
				                                                  , (item ->> 'codigo')::INTEGER AS cod_produto
								                           FROM   agregadores_definicoes a
											                      LEFT JOIN LATERAL jsonb_array_elements(dados_agregador::jsonb->'itens') AS item ON TRUE
                                                        )
                                 
                  /*******************************************************************************************************************
                   *             										COBERTURAS
                   *******************************************************************************************************************/
                                 
                                      , metas_cobertura as (
				                                           SELECT   HC.gv
				                                                  , HC.sv
				                                                  , HC.vd
				                                                  , MCV.cod_agregador
				                                                  , UPPER(AG.descricao) as descricao
				                                                  , COALESCE(MCV.meta_cobertura, 0) as meta								               
				                                            FROM    metas_cobertura_vd MCV 
				                                                    INNER JOIN hierarquia_comercial HC ON MCV.vd = hc.vd
					    		                                    INNER JOIN agregadores AG ON AG.cod_agregador = MCV.cod_agregador
				                                            WHERE   validade_meta = {data}
				                                            GROUP BY  HC.gv
				                                                  , HC.sv
				                                                  , HC.vd
				                                                  , MCV.cod_agregador
				                                                  , UPPER(AG.descricao) 
				                                                  , MCV.meta_cobertura
				                              
				                                            UNION 
				                        
				                                            SELECT  HC.gv
				                                                  , HC.sv
				                                                  , HC.vd
				                                                  , 'SKU6TSCH' as cod_agregador
				                                                  , '6+ SKUs CERVEJA' as descricao
				                                                  , (ROUND(COUNT(DISTINCT CASE WHEN CAAA.cod_agregador = 'CTOT' THEN CAAA.cod_cliente END), 0) * 0.80)::INT
                                                            FROM    COBERTURA_AGREGADO_ANALITICO_AC CAAA  
								                                    INNER JOIN hierarquia_comercial HC ON CAAA.vd = hc.vd
                                                            WHERE   DATA_MX = ({data}::Date - INTERVAL '1 months')
								                            GROUP BY  HC.gv
								                                    , HC.sv
								                                    , HC.vd				                              
                   						                    )
                                      , real_cobertura as (
								                            SELECT    HC.gv
								                                    , HC.sv
								                                    , HC.vd
								                                    , CAAA.cod_agregador
								                                    , UPPER(AG.descricao) as descricao
								                                    , COUNT( DISTINCT COD_CLIENTE) as realizado								               
								                            FROM    COBERTURA_AGREGADO_ANALITICO_AC CAAA  
								                                    INNER JOIN hierarquia_comercial HC ON CAAA.vd = hc.vd
									    		                    INNER JOIN agregadores AG ON AG.cod_agregador = CAAA.cod_agregador
								                            WHERE   DATA_MX = {data}
								                            GROUP BY  HC.gv
								                                    , HC.sv
								                                    , HC.vd
								                                    , CAAA.cod_agregador
								                                    , UPPER(AG.descricao) 								              
                                                         )
                                      , cobertura as (	                  						
                                                            SELECT   R.GV
                                                                   , R.SV
                                                                   , R.VD
                                                                   , R.cod_agregador
                                                                   , R.DESCRICAO
                                                                   , M.META
                                                                   , R.REALIZADO
                                                            FROM   real_cobertura R  
                                                                   LEFT JOIN metas_cobertura M ON M.cod_agregador = R.cod_agregador
                                                                                              AND M.VD = R.VD
                                                            ORDER BY M.VD, M.cod_agregador
                                                     )
                                 
                  /*******************************************************************************************************************
                   *             										VOLUME
                   *******************************************************************************************************************/
                                        , metas_volume AS (
								                            SELECT    HC.gv
				                                                    , HC.sv
				                                                    , HC.vd
				                                                    , AG.cod_agregador
				                                                    , UPPER(AG.descricao) as descricao
				                                                    , SUM(ROUND(MVV.meta_hl,2)) AS meta
								                            FROM    metas_volume_vd MVV
								   			                        INNER JOIN hierarquia_comercial hc  ON mvv.vd = hc.vd
					    		                                    INNER JOIN agregadores AG ON AG.cod_produto = mvv.cod_produto
				                                            WHERE   validade_meta = {data}
				                                            GROUP BY HC.gv
				                                                    , HC.sv
				                                                    , HC.vd
				                                                    , AG.cod_agregador
				                                                    , UPPER(AG.descricao)
				          
				                                            UNION 
				   
				                                            SELECT   HC.gv
				                                                    , HC.sv
				                                                    , HC.vd
				                                                    , 'TSCH' AS cod_agregador
						                                            , 'QUALQUER PRODUTO' AS descricao
				                                                    , SUM(ROUND(MVV.meta_hl,2)) AS meta
				                                            FROM    metas_volume_vd MVV
					   		                                        INNER JOIN hierarquia_comercial hc  ON mvv.vd = hc.vd
				                                            WHERE   validade_meta = {data}
				                                            GROUP BY HC.gv
				                                                    , HC.sv
				                                                    , HC.vd				  
				                                            )                  
                                        , real_volume AS (
									                        SELECT    HC.gv
								                                    , HC.sv
								                                    , HC.vd
								                                    , AG.cod_agregador	
                                                                    , UPPER(AG.descricao) as descricao
                                                                    , SUM(ROUND(VAAA.SALDO_hl,2)) AS realizado 
									                        FROM 	VOLUME_AGREGADO_ANALITICO_AC VAAA
									   		                        INNER JOIN hierarquia_comercial hc ON VAAA.vd = hc.vd
                                                                    INNER JOIN (
                                                                                 SELECT cod_agregador, descricao
                                                                                 FROM agregadores 
                                                                                 GROUP BY cod_agregador, descricao
                                                                                ) AG ON VAAA.cod_agregador = AG.cod_agregador
				                                            WHERE   DATA_MX = {data}
									                        GROUP BY HC.gv
								                                    , HC.sv
								                                    , HC.vd
								                                    , AG.cod_agregador
                                                                    , UPPER(AG.descricao)
								                        )
					                    , volume as (	                  						
                                                            SELECT   R.GV
                                                                   , R.SV
                                                                   , R.VD
                                                                   , R.cod_agregador
                                                                   , R.DESCRICAO
                                                                   , M.META
                                                                   , R.REALIZADO
                                                            FROM   real_volume R 
                                                                   LEFT JOIN metas_volume M ON M.cod_agregador = R.cod_agregador
                                                                                           AND M.VD = R.VD
                                                            ORDER BY M.VD, M.cod_agregador
                                                     )                    
					
                                     
                            SELECT   C.GV 
                                   , C.SV
                                   , C.VD
                                   , C.cod_agregador
                                   , C.DESCRICAO
                                   , C.META as COB_META
                                   , C.REALIZADO as COB_REALIZADO
                                   , COALESCE( v.META, 0 ) as VOL_META
                                   , COALESCE( V.REALIZADO, 0 ) as VOL_REALIZADO
                            FROM   cobertura C 
                                   LEFT JOIN volume V ON C.cod_agregador = V.cod_agregador
                                                     AND C.VD = V.VD
                            -- WHERE C.META > 0
                            ORDER BY C.VD, C.cod_agregador";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void SKU_POR_PDV(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"
								WITH clientes AS (
                                                    SELECT    bas.gv
                                                            , bas.sv
                                                            , bas.vd
                                                            , COUNT(cad.cod_cliente) AS total_pdv
                                                    FROM    clientes_dados_comerciais com
                                                            INNER JOIN clientes_dados_cadastrais cad  ON com.cod_cliente = cad.cod_cliente
                                                            INNER JOIN clientes_dados_basicos bas ON bas.cod_cliente = com.cod_cliente
                                                    WHERE   cad.status_cliente = 'A'
                                                            AND bas.gv in ( 1, 4, 6 )
                                                    GROUP BY bas.gv
                                                            , bas.sv
                                                            , bas.vd
                                                 )


                                     , meta AS (
                                                    SELECT    c.vd
                                                            ,{data}::Date AS validade
                                                            , 7 AS meta
                                                    FROM    clientes c
                                                    GROUP BY  c.vd
                   
                                                )

                                     , base_realizado AS (                                
                                                    SELECT    cdb.vd
                                                            , OPF.cod_cliente
                                                            , OPF.cod_produto
                                                            , SUM(OPF.saldo_umb) AS saldo_umb
                                                            , OPF.data_mx AS validade
                                                    FROM    OPF_ANALITICO_MX OPF
                                                            INNER JOIN produtos p ON OPF.cod_produto = p.cod_produto
                                                            INNER JOIN clientes_dados_basicos cdb ON OPF.cod_cliente = cdb.cod_cliente
                                                            INNER JOIN cobertura_agregado_analitico_ac COB ON COB.cod_cliente = OPF.cod_cliente
                                                                                                                    AND COB.data_mx = OPF.data_mx
                                                                                                                    AND COB.COD_AGREGADOR = 'TSCH'
                                                    WHERE   OPF.data_mx = {data}
                                                            AND OPF.cod_operacao IN (1, 2, 4, 5, 6)
                                                    GROUP BY cdb.vd,
                                                            OPF.cod_cliente,
                                                            OPF.cod_produto,
                                                            OPF.data_mx
                                                )

                                     , realizado AS (
                                                    SELECT  sub.validade
                                                            , sub.vd
                                                            , SUM(sub.total_produtos) AS realizado
                                                    FROM   (
                                                                    SELECT  b.validade
                                                                            , b.vd
                                                                            , b.cod_cliente
                                                                            , COUNT(DISTINCT b.cod_produto) AS total_produtos
                                                                    FROM    base_realizado b                                                       
                                                                    GROUP BY b.validade,
                                                                            b.vd,
                                                                            b.cod_cliente
                                                            ) sub
                                                    GROUP BY sub.validade,
                                                            sub.vd
                                                )
   
                                    SELECT    c.gv
                                            , c.sv
                                            , c.vd                                             
                                            , CAA.total_pdv as total_pdv_cobertos
                                            , m.meta as total_skus_meta
                                            , r.realizado as total_skus_realizado
                                            , r.realizado / CAA.total_pdv AS media
                                            , COALESCE( r.realizado::DECIMAL / NULLIF(m.meta, 0)::DECIMAL, 0 )::DECIMAL(10,4) AS percentual
                                            , EXTRACT(YEAR FROM m.validade)::text || '_' || LPAD(EXTRACT(MONTH FROM m.validade)::text, 2, '0') AS ano_mes
                                    FROM    clientes c
                                            INNER JOIN meta m ON m.vd = c.vd
                                            LEFT JOIN realizado r ON m.vd = r.vd
                                                                    AND m.validade = r.validade
                                            INNER JOIN (
                                                            SELECT  data_mx
                                                                    , vd
                                                                    , COUNT(DISTINCT cod_cliente) AS total_pdv
                                                            FROM    cobertura_agregado_analitico_ac
                                                            WHERE   cod_agregador = 'TSCH'
                                                                    AND data_mx = {data}
                                                            GROUP BY data_mx
                                                                     , vd
                                                            ) CAA ON r.vd = CAA.vd
                                            AND r.validade = CAA.data_mx
            
                                    GROUP BY  c.gv
                                            , c.sv
                                            , c.vd
                                            , c.total_pdv
                                            , m.meta
                                            , r.realizado
                                            , CAA.total_pdv
                                            , m.validade
                                    ORDER BY c.vd
                                                , m.validade
		   	                 ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void FDS(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"
								SELECT    dfafa.GV
                                        , dfafa.SV
                                        , dfafa.VD
                                        , COALESCE( M.META_FDS, SUM( dfafa.valor_pontuavel ) ) as valor_pontuavel 
                                        , SUM( dfafa.pontuacao_atingida ) AS pontuacao_atingida                                        
		                                , SUM( dfafa.pontuacao_atingida )::DECIMAL(10,2) / COALESCE( M.META_FDS, SUM( dfafa.valor_pontuavel ) )::DECIMAL(10,2) AS PERCENTUAL 
								FROM    ds_fotografia_acompanhamento_fds_analitico dfafa
                                        LEFT JOIN METAS_FDS M ON M.VD = dfafa.VD
                                                        AND M.VALIDADE_META = dfafa.DATA_MX
								WHERE   dfafa.data_mx = {data}
                                        AND dfafa.GV IN ( 1, 4, 6 )
                                GROUP BY  dfafa.GV
                                        , dfafa.SV
                                        , dfafa.VD
                                        , M.META_FDS
		   	                 ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void MATERIAIS(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"
								WITH MATERIAL AS ( SELECT     cur.GV
                                                            , cur.SV
                                                            , cur.VD
                                                            , cur.COD_CLIENTE
                                                            , cdb.razao_social
                                                            , cur.CATEGORIA_CLIENTE
                                                            , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN 'CAIXARIAS'
                                                                   WHEN TIPO_COMODATAVEL LIKE '%VASIL%' THEN 'VASILHAMES' ELSE cur.GRUPO_COMODATAVEL END AS GRUPO_COMODATAVEL
                                                            , CMI.TIPO_COMODATAVEL
                                                            , CMI.QUANTIDADE_EMITIDA
                                                            , CMI.QUANTIDADE_RECOLHIDA
                                                            , CMI.SALDO_QUANTIDADE

                                                            -- CALCULO UMB
                                                            , ROUND( ( CASE WHEN CMI.TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN CMI.META_UMB_PROPORCIONAL_MOD2 / ( SELECT meta_umb 
                                                                                                                                                              FROM   produtos_tipo_comodatavel p
                                                                                                                                                              WHERE  p.TIPO_COMODATAVEL = CMI.TIPO_COMODATAVEL) * 3 ELSE CMI.META_UMB_PROPORCIONAL_MOD2 END ), 2 ) as META_UMB_INTEGRAL
                                                            , cur.SALDO_UMB
                                                            , COALESCE( prev.SALDO_UMB, 0 ) AS SALDO_UMB_MES_ANTERIOR
                                                            , CUR.STATUS_GIRO_MATERIAIS_UMB

                                                            -- CALCULO HL
                                                            , ROUND( ( CASE WHEN CMI.TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN CMI.META_HL_PROPORCIONAL_MOD2 / ( SELECT meta_hl
                                                                                                                                                             FROM   produtos_tipo_comodatavel p
                                                                                                                                                             WHERE  p.TIPO_COMODATAVEL = CMI.TIPO_COMODATAVEL) * 3 ELSE CMI.META_HL_PROPORCIONAL_MOD2 END ), 3 ) as META_HL_INTEGRAL
                                                            , cur.SALDO_HL
                                                            , COALESCE( prev.SALDO_HL, 0 ) AS SALDO_HL_MES_ANTERIOR
                                                            , CUR.STATUS_GIRO_MATERIAIS_HL

                                                            , EXTRACT(YEAR FROM cur.data_mx )::text || '_' || LPAD(EXTRACT(MONTH FROM cur.data_mx )::text, 2, '0') AS ano_mes
                                                            , cur.data_mx as validade
                                                            , CASE WHEN cur.STATUS_GIRO_MATERIAIS_HL IN ( 'GIRO ZERO','BAIXO GIRO' ) THEN 1 ELSE 0 END AS Flag_Critico
                                                            , ROUND( CASE WHEN COALESCE(prev.SALDO_HL, 0) = 0 AND cur.SALDO_HL > 0 THEN 1
                                                                          WHEN COALESCE(prev.SALDO_HL, 0) = 0 AND cur.SALDO_HL < 0 THEN -1
                                                                          WHEN COALESCE(prev.SALDO_HL, 0) = 0 AND cur.SALDO_HL = 0 THEN 0
                                                                          ELSE (cur.SALDO_HL - prev.SALDO_HL) / prev.SALDO_HL END, 3 ) AS QUEDA_VOLUME
                                                    FROM    ds_agm_comodatos_metas_vs_real_por_grupo cur
                                                            LEFT JOIN ds_agm_comodatos_metas_vs_real_por_grupo prev ON cur.COD_CLIENTE = prev.COD_CLIENTE
                                                                                                                            AND cur.GRUPO_COMODATAVEL = prev.GRUPO_COMODATAVEL
                                                                                                                            AND prev.data_mx = (cur.data_mx - INTERVAL '1 month')
                                                            INNER JOIN clientes_dados_basicos cdb on cur.cod_cliente = cdb.cod_cliente
                                                            INNER JOIN ds_agm_comodatos_material_investido CMI on CUR.DATA_MX = CMI.DATA_MX
                                                                                                                       AND CUR.COD_CLIENTE = CMI.COD_CLIENTE
                                                                                                                       AND CUR.GRUPO_COMODATAVEL  = CMI.GRUPO_COMODATAVEL
                                                                                                                       AND cmi.cod_status_comodato = 'A'
                                                    WHERE   ( CUR.grupo_comodatavel <> 'REFRIGERACAO' OR ( CUR.grupo_comodatavel = 'REFRIGERACAO' AND CUR.status_giro_materiais_hl <> 'SEM META') )
                                                             AND cur.data_mx = {data}
                                                    ORDER BY  cur.COD_CLIENTE, cur.vd, cur.grupo_comodatavel
                                            )

                SELECT    GV
                        , SV
                        , VD
                        , COD_CLIENTE
                        , razao_social
                        , CATEGORIA_CLIENTE
                        , GRUPO_COMODATAVEL
                        , TIPO_COMODATAVEL
                        , QUANTIDADE_EMITIDA
                        , QUANTIDADE_RECOLHIDA
                        , SALDO_QUANTIDADE

                        , META_UMB_INTEGRAL
                        , SALDO_UMB                

                        , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN  CASE WHEN SALDO_UMB = 0 THEN 1
                                                                                WHEN SALDO_UMB > 0 AND SALDO_UMB < META_UMB_INTEGRAL THEN 2
                                                                                WHEN SALDO_UMB >= META_UMB_INTEGRAL THEN 3 END
                                                                                ELSE CASE WHEN STATUS_GIRO_MATERIAIS_UMB = 'GIRO ZERO'  THEN 1
                                                                                          WHEN STATUS_GIRO_MATERIAIS_UMB = 'BAIXO GIRO' THEN 2
                                                                                          WHEN STATUS_GIRO_MATERIAIS_UMB = 'BATEU META' THEN 3 END END AS COD_STATUS_GIRO_MATERIAIS_UMB
	                    , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN CASE  WHEN SALDO_UMB = 0 THEN 'GIRO ZERO'
                                                                                WHEN SALDO_UMB > 0 AND SALDO_UMB < META_UMB_INTEGRAL THEN 'BAIXO GIRO'
                                                                                WHEN SALDO_UMB >= META_UMB_INTEGRAL THEN 'BATEU META' END
                                                                                ELSE STATUS_GIRO_MATERIAIS_UMB END AS STATUS_GIRO_MATERIAIS_UMB
                        , SALDO_UMB_MES_ANTERIOR

                        , META_HL_INTEGRAL
                        , SALDO_HL
                        , ROUND( CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXA%' THEN META_HL_INTEGRAL - SALDO_HL ELSE NULL END, 3 ) AS FALTA_HL
                        , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXA%' THEN CASE WHEN SALDO_HL = 0 THEN 1
                                                                              WHEN SALDO_HL > 0 AND SALDO_HL < META_HL_INTEGRAL THEN 2
                                                                              WHEN SALDO_HL >= META_HL_INTEGRAL THEN 3 END
                                                                              ELSE CASE WHEN STATUS_GIRO_MATERIAIS_HL = 'GIRO ZERO'  THEN 1
                                                                                        WHEN STATUS_GIRO_MATERIAIS_HL = 'BAIXO GIRO' THEN 2
                                                                                        WHEN STATUS_GIRO_MATERIAIS_HL = 'BATEU META' THEN 3 END END AS COD_STATUS_GIRO_MATERIAIS_HL
                        , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXA%' THEN CASE WHEN SALDO_HL = 0 THEN 'GIRO ZERO'
                                                                              WHEN SALDO_HL > 0 AND SALDO_HL < META_HL_INTEGRAL THEN 'BAIXO GIRO'
                                                                              WHEN SALDO_HL >= META_HL_INTEGRAL THEN 'BATEU META' END
                                                                              ELSE STATUS_GIRO_MATERIAIS_HL END AS STATUS_GIRO_MATERIAIS_HL                        
                        , ano_mes
                        , validade
                FROM   MATERIAL
                WHERE  GV IN ( 1, 4, 6 ) ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void HEISHOP(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"
								SELECT  GV
                                      , SV 
                                      , VD
      
                                      , COUNT(DISTINCT COD_CLIENTE) AS total_clientes
                                      , COUNT(DISTINCT CASE WHEN PEDIDOS_HEISHOP > 0 THEN COD_CLIENTE END) AS clientes_com_pedido_heishop    
                                      , COUNT(DISTINCT CASE WHEN PEDIDOS_HEISHOP > 0 THEN COD_CLIENTE END)::DECIMAL(10,2) / COUNT(DISTINCT COD_CLIENTE)::DECIMAL(10,2) as PERCENTUAL_TOTAL_CLIENTE
      
                                      , SUM(SALDO_VALOR) as SALDO_VALOR
                                      , SUM(SALDO_VALOR_HEISHOP)  as SALDO_VALOR_HEISHOP
                                      , NULLIF(SUM(SALDO_VALOR_HEISHOP),0)::DECIMAL(10,2) / SUM(SALDO_VALOR)::DECIMAL(10,2)  as PERCENTUAL_SALDO_VALOR
      
                                      , SUM(PEDIDOS_TOTAL) as PEDIDOS_TOTAL
                                      , SUM(PEDIDOS_HEISHOP) as PEDIDOS_HEISHOP
                                      , SUM(PEDIDOS_HEISHOP)::DECIMAL(10,2) / SUM(PEDIDOS_TOTAL)::DECIMAL(10,2) as PERCENTUAL_PEDIDOS_TOTAL
           
                                FROM ds_heishop_acompanhamento_heishop_analitico
                                WHERE DATA_MX = {data}
                                      and GV in ( 1, 4, 6 )
                                GROUP by GV
                                      , SV 
                                      , VD                                  
		   	                 ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void CLIENTES_ESTAVEIS_RGB(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"
								 WITH CLIENTES AS ( SELECT    HC.gv
					                                        , HC.sv
					                                        , HC.vd
					                                        , VAAA.COD_CLIENTE
					                                        , UPPER( CDB.RAZAO_SOCIAL ) as RAZAO_SOCIAL
					                                        , (  SELECT STRING_AGG(dia_visita, ', ')
							                                     FROM   clientes_agenda_de_visitas cadv
							                                     WHERE  cadv.cod_cliente = VAAA.COD_CLIENTE ) as DIA_VISITA
							                                , fn_retorna_canal(CDB.COD_CATEGORIA_CLIENTE) as CANAL
					                                        , UPPER( CC.CATEGORIA_CLIENTE ) as CATEGORIA_CLIENTE					        
					                                       
                                                            , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '3 MONTH')) THEN SALDO_HL  ELSE 0 END) AS vol_m3
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '2 MONTH')) THEN SALDO_HL  ELSE 0 END) AS vol_m2
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '1 MONTH')) THEN SALDO_HL  ELSE 0 END) AS vol_m1
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM {data}::date) THEN SALDO_HL  ELSE 0 END) AS vol_mes_atual
					        
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '3 MONTH')) THEN SALDO_VALOR ELSE 0 END) AS fat_m3
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '2 MONTH')) THEN SALDO_VALOR ELSE 0 END) AS fat_m2
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM ({data}::date - INTERVAL '1 MONTH')) THEN SALDO_VALOR ELSE 0 END) AS fat_m1
					                                        , SUM(CASE WHEN EXTRACT(MONTH FROM DATA_MX) = EXTRACT(MONTH FROM {data}::date)  THEN SALDO_VALOR ELSE 0 END) AS fat_mes_atual
					                              
                                                    FROM      VOLUME_AGREGADO_ANALITICO_AC VAAA
					                                          INNER JOIN hierarquia_comercial HC ON VAAA.vd = hc.vd
					                                          INNER JOIN CLIENTES_DADOS_CADASTRAIS CDB on VAAA.COD_CLIENTE = CDB.COD_CLIENTE
						                                      INNER JOIN CLIENTES_DADOS_BASICOS CDB2 on CDB.COD_CLIENTE = CDB2.COD_CLIENTE
						                                      INNER JOIN CLIENTES_CATEGORIAS CC on CDB.COD_CATEGORIA_CLIENTE = CC.COD_CATEGORIA_CLIENTE
					                                WHERE     DATA_MX BETWEEN ({data}::Date - INTERVAL '3 month') and {data}::Date
					                                          AND COD_AGREGADOR  = 'CRET'
					                                          AND CDB.status_cliente = 'A' 
					                                          AND HC.gv IN ( 1, 4, 6 )
					                                GROUP BY  HC.gv
					                                        , HC.sv
					                                        , HC.vd
					                                        , VAAA.COD_CLIENTE
					                                        , CDB.RAZAO_SOCIAL 
					                                        , CC.CATEGORIA_CLIENTE
					                                        , CDB.COD_CATEGORIA_CLIENTE
					                                ORDER BY  HC.vd,VAAA.COD_CLIENTE
 				                                 )
 		
                                    SELECT  GV
	                                      , SV
	                                      , VD
	                                      , COD_CLIENTE
	                                      , RAZAO_SOCIAL  
	                                      , DIA_VISITA
	                                      , CANAL
	                                      , CATEGORIA_CLIENTE  
	  
	                                      , CASE WHEN vol_m3 > 0 AND vol_m2 > 0 AND vol_m1 > 0 THEN 'ESTÁVEL' ELSE 'INSTÁVEL' END AS ESTABILIDADE_MESES_ANTERIORES
	                                      , CASE WHEN vol_m2 > 0 AND vol_m1 > 0 AND vol_mes_atual > 0 THEN 'ESTÁVEL' ELSE 'INSTÁVEL' END AS ESTABILIDADE_COM_MES_ATUAL
	                                     
                                          , COALESCE(vol_m3, 0) AS VOL_M3
	                                      , COALESCE(vol_m2, 0) AS VOL_M2
	                                      , COALESCE(vol_m1, 0) AS VOL_M1
	                                      , COALESCE(vol_mes_atual, 0) AS VOL_MES_ATUAL

	                                      , COALESCE(fat_m3, 0) AS FAT_M3
	                                      , COALESCE(fat_m2, 0) AS FAT_M2
	                                      , COALESCE(fat_m1, 0) AS FAT_M1
	                                      , COALESCE(fat_mes_atual, 0) AS FAT_MES_ATUAL
                                    FROM CLIENTES
		   	                 ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void bd_Vendedores(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String data = "'" + Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01'";

                string query = $@" 
                            SELECT codigo_colaborador AS VD, NOME
                            FROM   hierarquia_comercial_historico
                            WHERE  data_mx = {data} ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no POSTGREE - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["User::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["User::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                                    WITH calendario AS (
                                                          SELECT  DATE_FORMAT(@Data, '%Y-%m-01') AS data_inicial, -- Primeiro dia do mês
                                                                  LAST_DAY(@Data) AS data_final, -- Último dia do mês
                                                                  DATE_FORMAT(@Data, '%Y-%m-%d') AS data_emissao -- Data atual
                                                       )
                                    SELECT    c.data_inicial,
		                                      DATE_FORMAT(c.data_final, '%Y-%m-%d') as data_final,
		                                      c.data_emissao,
		                                      -- Contagem de dias úteis no mês (segunda a sexta),
		                                      (	   SELECT COUNT(*) 
					                               FROM (
					                                        SELECT DATE_ADD(c.data_inicial, INTERVAL seq DAY) AS data_dia
					                                        FROM (SELECT 0 seq UNION 
					                                                ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 
					                                                UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 
					                                                UNION ALL SELECT 9 UNION ALL SELECT 10 UNION ALL SELECT 11 UNION ALL SELECT 12 
					                                                UNION ALL SELECT 13 UNION ALL SELECT 14 UNION ALL SELECT 15 UNION ALL SELECT 16 
					                                                UNION ALL SELECT 17 UNION ALL SELECT 18 UNION ALL SELECT 19 UNION ALL SELECT 20 
					                                                UNION ALL SELECT 21 UNION ALL SELECT 22 UNION ALL SELECT 23 UNION ALL SELECT 24 
					                                                UNION ALL SELECT 25 UNION ALL SELECT 26 UNION ALL SELECT 27 UNION ALL SELECT 28 
					                                                UNION ALL SELECT 29 UNION ALL SELECT 30) AS numeros
					                                        JOIN calendario c ON 1 = 1 -- Substitua ""sua_tabela"" pelo nome correto da tabela
					                                    ) AS dias
					                                    WHERE data_dia BETWEEN c.data_inicial AND c.data_final
					                                        AND WEEKDAY(data_dia) NOT IN (5,6) -- Exclui sábados (5) e domingos (6)
		                                        ) AS dias_uteis,
		                                        -- Dias decorridos até a data_emissao
		                                        DATEDIFF(c.data_emissao, c.data_inicial) AS dias_decorridos,
		                                        -- Dias restantes até o final do mês
		                                        DATEDIFF(c.data_final, c.data_emissao) AS dias_restantes,
		                                        -- Dia anterior à data_emissao
		                                        DATE_SUB(c.data_emissao, INTERVAL 1 DAY) AS dia_anterior,
                                                -- Mês atual
		                                        MONTH(c.data_emissao) AS mes_atual,
		                                        -- Ano Atual
		                                        YEAR(c.data_emissao) AS ano_atual,
		                                        -- Mês anterior
		                                        MONTH(DATE_SUB(c.data_emissao, INTERVAL 1 MONTH)) AS mes_anterior,
		                                        -- Ano anterior
		                                        YEAR(DATE_SUB(c.data_emissao, INTERVAL 1 YEAR)) AS ano_anterior,
                                                -- Quantidade total de semanas no mês
                                               (WEEK(c.data_final, 3) - WEEK(c.data_inicial, 3) + 1) AS total_semanas_mes,
                                               -- Semana atual no mês
                                               (WEEK(c.data_emissao, 3) - WEEK(c.data_inicial, 3) + 1) AS semana_atual,
                                               -- Data da segunda-feira da semana atual
                                               DATE_SUB(DATE(NOW()), INTERVAL (WEEKDAY(DATE(NOW()))) DAY) AS data_segunda,
                                               -- Data da sexta-feira da semana atual
                                               DATE_ADD( DATE_SUB(DATE(NOW()), INTERVAL (WEEKDAY(DATE(NOW()))) DAY), INTERVAL 4 DAY ) AS data_sexta
                                    FROM calendario c ";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int revenda, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, revenda, packageName); // Passando os parâmetros como objetos

                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
