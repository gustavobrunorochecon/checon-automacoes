              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
using System.Windows.Forms;
using System.Collections.Generic;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value);
            string packageName = Dts.Variables["System::PackageName"].Value.ToString();
            string Email = Dts.Variables["$Package::Email"].Value.ToString();

            string filePath = $@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\dados\";
            string file = "dados_" + revenda + ".xlsx";

            File.Delete(filePath + file);

            bd_Dados(Dts, filePath, file, "GV_");
            dados_relatorios(Dts, filePath, file, "dados_relatorios");

            ExecutarMacroExcel($@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\vba.xlsm", "build.formataArquivo", revenda, packageName);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            List<string> GVs = new List<string>();
            List<string> SVs = new List<string>();

            if (Dts.Variables["User::Revenda"].Value.ToString() == "1")
            {
                GVs.Add("1");
                GVs.Add("4");

                //SVs.Add("100");
                //SVs.Add("300");
                //SVs.Add("400");
                //SVs.Add("500");

            }
            else
            {
                GVs.Add("6");

                //SVs.Add("600");
                //SVs.Add("700");
                //SVs.Add("800");
            }            

            try
            {

                foreach (string gv in GVs)
                {

                    //foreach (string sv in SVs)
                    //{

                        string data = "'" + Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01'";

                        string query = $@"WITH  mes_Anterior as (
								                                     SELECT   vaa.vd
								                                            , vaa.cod_cliente
								                                            , vaa.saldo_hl
								                                     FROM   volume_agregado_analitico_ac vaa 						       
								                                     WHERE  vaa.data_mx = {data}::Date - INTERVAL '1 month'
								                                            AND vaa.cod_agregador = 'CRGB'
					  		                                    )
		                                      , mes_Atual as    (
								                                     SELECT   vaa.vd
								                                            , vaa.cod_cliente
								                                            , vaa.saldo_hl
								                                     FROM   volume_agregado_analitico_ac vaa 						       
								                                     WHERE  vaa.data_mx = {data}::Date  
								                                            AND vaa.cod_agregador = 'CRGB'
					  		                                    )					  		
                                SELECT  ROW_NUMBER() OVER (ORDER BY ( atual.saldo_hl - ma.saldo_hl )) AS rank
                                      , ma.cod_cliente::INT
                                      , CONCAT( CASE WHEN hc.gv IN ('1', '4') THEN 'X230' ELSE 'X690' END, cdc.cod_heineken ) as codigo_bw
                                      , cdc.razao_social
                                      , hc.gv
                                      , hc.sv
                                      , hc.vd
                                      , cc.categoria_cliente
	                                  , ma.saldo_hl as mes_Anterior
                                      , atual.saldo_hl as mes_Atual
	                                  , atual.saldo_hl - ma.saldo_hl as variacao
                                      , CASE WHEN ma.saldo_hl > 0 THEN ROUND( CAST( ((ma.saldo_hl - atual.saldo_hl) * 100.0) / ma.saldo_hl AS numeric), 2) / 100 ELSE NULL END AS perc_ganho
                                FROM  mes_Atual atual
	 	                              LEFT JOIN mes_Anterior ma on ma.cod_cliente = atual.cod_cliente
	 	                              INNER JOIN clientes_dados_cadastrais cdc on ma.cod_cliente = cdc.cod_cliente
	 	                              INNER JOIN hierarquia_comercial hc on atual.vd = hc.vd
	 	                              INNER JOIN clientes_categorias cc on cdc.cod_categoria_cliente = cc.cod_categoria_cliente
                                WHERE hc.gv = {gv}
                                     -- AND hc.SV = 
                                ORDER BY ( atual.saldo_hl - ma.saldo_hl )  
                                LIMIT 20";

                        using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                        {
                            if (line.HasRows)
                            {
                                //exportaExcel(line, filePath, file, planilha + gv + "_" + sv);
                                exportaExcel(line, filePath, file, planilha + gv );
                            }
                        }
                    //}
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["$Package::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["$Package::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                            WITH calendario AS (
                                                  SELECT  DATE_FORMAT(@Data, '%Y-%m-01') AS data_inicial, -- Primeiro dia do mês
                                                          LAST_DAY(@Data) AS data_final, -- Último dia do mês
                                                          DATE_FORMAT(@Data, '%Y-%m-%d') AS data_emissao -- Data atual
                                               )
                            SELECT    c.data_inicial,
                                      c.data_final,
                                      c.data_emissao,
                                      -- Contagem de dias úteis no mês (segunda a sexta),
                                      (	   SELECT COUNT(*) 
			                               FROM (
			                                        SELECT DATE_ADD(c.data_inicial, INTERVAL seq DAY) AS data_dia
			                                        FROM (SELECT 0 seq UNION 
			                                                ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 
			                                                UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 
			                                                UNION ALL SELECT 9 UNION ALL SELECT 10 UNION ALL SELECT 11 UNION ALL SELECT 12 
			                                                UNION ALL SELECT 13 UNION ALL SELECT 14 UNION ALL SELECT 15 UNION ALL SELECT 16 
			                                                UNION ALL SELECT 17 UNION ALL SELECT 18 UNION ALL SELECT 19 UNION ALL SELECT 20 
			                                                UNION ALL SELECT 21 UNION ALL SELECT 22 UNION ALL SELECT 23 UNION ALL SELECT 24 
			                                                UNION ALL SELECT 25 UNION ALL SELECT 26 UNION ALL SELECT 27 UNION ALL SELECT 28 
			                                                UNION ALL SELECT 29 UNION ALL SELECT 30) AS numeros
			                                        JOIN calendario c ON 1 = 1 -- Substitua ""sua_tabela"" pelo nome correto da tabela
			                                    ) AS dias
			                                    WHERE data_dia BETWEEN c.data_inicial AND c.data_final
			                                        AND WEEKDAY(data_dia) NOT IN (5,6) -- Exclui sábados (5) e domingos (6)
                                        ) AS dias_uteis,
                                        -- Dias decorridos até a data_emissao
                                        DATEDIFF(c.data_emissao, c.data_inicial) AS dias_decorridos,
                                        -- Dias restantes até o final do mês
                                        DATEDIFF(c.data_final, c.data_emissao) AS dias_restantes,
                                        -- Dia anterior à data_emissao
                                        DATE_SUB(c.data_emissao, INTERVAL 1 DAY) AS dia_anterior,
                                        -- Mês atual
                                        MONTH(c.data_emissao) AS mes_atual,
                                        -- Ano Atual
                                        YEAR(c.data_emissao) AS ano_atual,
                                        -- Mês anterior
                                        MONTH(DATE_SUB(c.data_emissao, INTERVAL 1 MONTH)) AS mes_anterior,
                                        -- Ano anterior
                                        YEAR(DATE_SUB(c.data_emissao, INTERVAL 1 YEAR)) AS ano_anterior
                            FROM calendario c ";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int revenda, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, revenda, packageName); // Passando os parâmetros como objetos

                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
