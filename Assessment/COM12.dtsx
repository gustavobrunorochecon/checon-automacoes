              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
using System.Windows.Forms;
using MySqlX.XDevAPI;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value);
            string packageName = Dts.Variables["System::PackageName"].Value.ToString();
            string Email = Dts.Variables["$Package::Email"].Value.ToString();

            string filePath = $@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\dados\";
            string file = "dados_" + revenda + ".xlsx";

            File.Delete(filePath + file);

            bd_Dados(Dts, filePath, file, "dados");
            MAIORES_HNK(Dts, filePath, file, "maiores_hnk");
            MAIORES_RGB(Dts, filePath, file, "maiores_rgb");

            //ExecutarMacroExcel($@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\vba.xlsm", "build.formataArquivo", revenda, packageName);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["$Package::Ano"].Value.ToString();
                String mes = Dts.Variables["$Package::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@" WITH sku as (
                                                    SELECT    opf.data_mx
                                                            , opf.cod_cliente
                                                            , count( DISTINCT opf.cod_produto )  AS TOTAL
                                                    FROM    opf_analitico_mx opf
                                                    WHERE   opf.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                            AND opf.cod_operacao in ( 1, 2, 4, 5 )                                                           
                                                    GROUP BY opf.data_mx
                                                            , opf.cod_cliente
                                               )
                                , clientes_estrategicos AS (

                                                    SELECT    cl.gv
                                                            , CL.cod_cliente
                                                            , CONCAT(current_user, cad.cod_heineken) AS CODIGO_BW
                                                            , UPPER( TRIM( cl.razao_social ) ) AS RAZAO_SOCIAL
                                                            , UPPER( cad.nome_fantasia ) AS NOME_FANTASIA
                                                            , UPPER( CONCAT( cl.tipo_logradouro, ' ', cl.logradouro ) ) AS LOGRADOURO
                                                            , UPPER( TRIM( cl.bairro ) ) AS BAIRRO
                                                            , UPPER( TRIM( cl.municipio ) ) AS MUNICIPIO
                                                            , UPPER( TRIM( cl.categoria_cliente ) ) AS CANAL
                                                            , CASE WHEN  mp.segmentacao IS NULL THEN  'OURO' ELSE mp.segmentacao END AS SEGMENTACAO
                                                            , (
                                                                    SELECT upper(email)
                                                                    FROM   clientes_emails clm
                                                                    WHERE  clm.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                                ) AS EMAIL
                                                            , (
                                                                    SELECT  concat( ddd_telefone, ' ', numero_telefone ) as telefone
                                                                    FROM   clientes_telefones clt
                                                                    WHERE  clt.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                                ) AS TELEFONE


                                                            , '' AS CONTRATO_HNK
                                                            , '' AS MARCA_PRINCIPAL

                                                              -- HL TOTAL
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_HL_TOTAL_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_HL_TOTAL_ATUAL

                                                              -- RGB
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_RGB_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_RGB_ATUAL
                    
                     										 -- CHOPP
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_CHOPP_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 )  AS VOL_CHOPP_ATUAL
                    
                                                            , (  SELECT ROUND( SUM(TOTAL) / 3, 0 )
                                                                    FROM   sku sku
                                                                    WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND (DATE {data} - INTERVAL '1 months') ) AS SKU_PDV_TRI
                                                            , (  SELECT SUM(TOTAL)
                                                                    FROM   sku sku
                                                                    WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx = {data} )  AS SKU_PDV_ATUAL

                                                            , '' AS VENDA_CHOPP
										                    , '' AS CHOPP_Concorrencia
                                                            , '' AS Plano_acao

                                                    FROM 	   clientes_dados_basicos cl
                                                                INNER JOIN clientes_dados_cadastrais cad ON cl.COD_CLIENTE = cad.cod_cliente
                                                                LEFT JOIN volume_agregado_analitico_ac vol ON vol.cod_cliente = cl.cod_cliente
                                                                                                            AND VOL.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                                                                            AND cod_agregador IN ( 'TSCH', 'CRET', 'CPTT' )
                                                                LEFT JOIN clientes_dados_matriz_potencial mp ON CL.cod_cliente = mp.cod_cliente

                                                    WHERE  	   cl.gv IN (1, 4, 6)
                                                                AND cl.status_cliente = 'A'
                                                    GROUP BY  cl.gv
                                                            , CL.cod_cliente
                                                            , cad.cod_heineken
                                                            , cl.razao_social
                                                            , cad.nome_fantasia
                                                            , cl.tipo_logradouro
                                                            , cl.logradouro
                                                            , cl.bairro
                                                            , cl.municipio
                                                            , cl.categoria_cliente
                                                            , mp.segmentacao

			                                        )


                    SELECT    ce.gv
                            , ce.CODIGO_BW
                            , ce.RAZAO_SOCIAL
                            , ce.NOME_FANTASIA
                            , ce.LOGRADOURO
                            , ce.BAIRRO
                            , ce.MUNICIPIO
                            , ce.CANAL
                            , ce.SEGMENTACAO
                            , ce.EMAIL
                            , ce.TELEFONE
                            , ce.CONTRATO_HNK
                            , ce.MARCA_PRINCIPAL

                            , ce.VOL_HL_TOTAL_TRI
                            , ce.VOL_HL_TOTAL_ATUAL
                            , ce.VOL_HL_TOTAL_ATUAL - ce.VOL_HL_TOTAL_TRI AS VOL_HL_TENDENCIA

                            , ce.VOL_RGB_TRI
                            , ce.VOL_RGB_ATUAL
                            , ce.VOL_RGB_ATUAL - ce.VOL_RGB_TRI AS VOL_RGB_TENDENCIA

                            , ce.VOL_CHOPP_TRI
                            , ce.VOL_CHOPP_ATUAL
                            , ce.VOL_CHOPP_ATUAL - ce.VOL_CHOPP_TRI AS VOL_CHOPP_TENDENCIA

                            , ce.SKU_PDV_TRI
                            , ce.SKU_PDV_ATUAL
                            , ce.SKU_PDV_ATUAL - ce.SKU_PDV_TRI AS SKU_PDV_TENDENCIA

                            , ce.VENDA_CHOPP
                            , ce.CHOPP_Concorrencia
                            , ce.Plano_acao
                    FROM    clientes_estrategicos ce
                    ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void MAIORES_HNK(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            string[] gvs;
           

            if (Convert.ToInt32(Dts.Variables["User::Revenda"].Value) == 1)
            {
                gvs = new string[] { "1", "4" };
            }
            else
            {
                gvs = new string[] { "6" };
            }

            foreach (string gv in gvs)
            {

                planilha = "maiores_hnk_" + gv;

                try
                {
                    String ano = Dts.Variables["$Package::Ano"].Value.ToString();
                    String mes = Dts.Variables["$Package::Mes"].Value.ToString();
                    String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                    string query = $@" WITH maiores_hnk AS (

                                                                    SELECT    cl.gv
                                                                            , CL.cod_cliente
                                                                            , CONCAT(current_user, cad.cod_heineken) AS CODIGO_BW
                                                                            , UPPER( TRIM( cl.razao_social ) ) AS RAZAO_SOCIAL
                                                                            , UPPER( cad.nome_fantasia ) AS NOME_FANTASIA
                                                                            , UPPER( CONCAT( cl.tipo_logradouro, ' ', cl.logradouro ) ) AS LOGRADOURO
                                                                            , UPPER( TRIM( cl.bairro ) ) AS BAIRRO
                                                                            , UPPER( TRIM( cl.municipio ) ) AS MUNICIPIO
                                                                            , UPPER( TRIM( cl.categoria_cliente ) ) AS CANAL
                                                                            , CASE WHEN  mp.segmentacao IS NULL THEN  'OURO' ELSE mp.segmentacao END AS SEGMENTACAO
                                                                            , (
                                                                                    SELECT upper(email)
                                                                                    FROM   clientes_emails clm
                                                                                    WHERE  clm.cod_cliente = cl.cod_cliente
                                                                                    LIMIT  1
                                                                              ) AS EMAIL
                                                                            , (
                                                                                    SELECT  concat( ddd_telefone, ' ', numero_telefone ) as telefone
                                                                                    FROM   clientes_telefones clt
                                                                                    WHERE  clt.cod_cliente = cl.cod_cliente
                                                                                    LIMIT  1
                                                                              ) AS TELEFONE


                                                                            , '' AS CONTRATO_HNK
                                                                            , '' AS MARCA_PRINCIPAL

                                                                              -- HL TOTAL
                                                                            , ROUND( SUM( CASE WHEN vol.data_mx = DATE {data} - INTERVAL '1 year' THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_HNK_LY
                                                                            , '' AS META_HNK
                                                                            , ROUND( SUM( CASE WHEN vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_HNK_ATUAL


                                                                    FROM 	   clientes_dados_basicos cl
                                                                               INNER JOIN clientes_dados_cadastrais cad ON cl.COD_CLIENTE = cad.cod_cliente
                                                                               LEFT JOIN volume_agregado_analitico_ac vol ON vol.cod_cliente = cl.cod_cliente
                                                                                                                            AND VOL.data_mx BETWEEN (DATE {data} - INTERVAL '1 YEAR') AND DATE {data}
                                                                                                                            AND cod_agregador IN ( 'HKTT' )
                                                                               LEFT JOIN clientes_dados_matriz_potencial mp ON CL.cod_cliente = mp.cod_cliente

                                                                    WHERE  	   cl.gv IN ({gv})
                                                                               AND cl.status_cliente = 'A'
                                                                               AND cod_agregador IN ( 'HKTT' )
                                                                    GROUP BY  cl.gv
                                                                            , CL.cod_cliente
                                                                            , cad.cod_heineken
                                                                            , cl.razao_social
                                                                            , cad.nome_fantasia
                                                                            , cl.tipo_logradouro
                                                                            , cl.logradouro
                                                                            , cl.bairro
                                                                            , cl.municipio
                                                                            , cl.categoria_cliente
                                                                            , mp.segmentacao

			                                                        )


                    SELECT  ROW_NUMBER() OVER (ORDER BY COALESCE(ce.VOL_HNK_ATUAL, 0) DESC) AS POSICAO
                            , ce.gv
                            , ce.CODIGO_BW
                            , ce.RAZAO_SOCIAL
                            , ce.NOME_FANTASIA
                            , ce.LOGRADOURO
                            , ce.BAIRRO
                            , ce.MUNICIPIO
                            , ce.CANAL
                            , ce.SEGMENTACAO
                            , ce.EMAIL
                            , ce.TELEFONE
                            , ce.CONTRATO_HNK
                            , ce.MARCA_PRINCIPAL

                            , ce.VOL_HNK_LY
                            , ce.VOL_HNK_ATUAL
                            , ce.META_HNK
                            , ce.VOL_HNK_ATUAL - ce.VOL_HNK_LY AS VOL_HL_TENDENCIA
                    FROM    maiores_hnk ce
                    ORDER BY COALESCE(ce.VOL_HNK_ATUAL, 0) DESC
                    LIMIT 50";

                    using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                    {
                        if (line.HasRows)
                        {
                            exportaExcel(line, filePath, file, planilha);
                        }
                    }
                }
                catch (Exception ex)
                {
                    Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                    Dts.TaskResult = (int)ScriptResults.Failure;
                }
            }
        }
        private void MAIORES_RGB(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            string[] gvs;


            if (Convert.ToInt32(Dts.Variables["User::Revenda"].Value) == 1)
            {
                gvs = new string[] { "1", "4" };
            }
            else
            {
                gvs = new string[] { "6" };
            }

            foreach (string gv in gvs)
            {

                planilha = "maiores_rgb_" + gv;

                try
                {
                    String ano = Dts.Variables["$Package::Ano"].Value.ToString();
                    String mes = Dts.Variables["$Package::Mes"].Value.ToString();
                    String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                    string query = $@" WITH maiores_rgb AS (

                                                                    SELECT    cl.gv
                                                                            , CL.cod_cliente
                                                                            , CONCAT(current_user, cad.cod_heineken) AS CODIGO_BW
                                                                            , UPPER( TRIM( cl.razao_social ) ) AS RAZAO_SOCIAL
                                                                            , UPPER( cad.nome_fantasia ) AS NOME_FANTASIA
                                                                            , UPPER( CONCAT( cl.tipo_logradouro, ' ', cl.logradouro ) ) AS LOGRADOURO
                                                                            , UPPER( TRIM( cl.bairro ) ) AS BAIRRO
                                                                            , UPPER( TRIM( cl.municipio ) ) AS MUNICIPIO
                                                                            , UPPER( TRIM( cl.categoria_cliente ) ) AS CANAL
                                                                            , CASE WHEN  mp.segmentacao IS NULL THEN  'OURO' ELSE mp.segmentacao END AS SEGMENTACAO
                                                                            , (
                                                                                    SELECT upper(email)
                                                                                    FROM   clientes_emails clm
                                                                                    WHERE  clm.cod_cliente = cl.cod_cliente
                                                                                    LIMIT  1
                                                                              ) AS EMAIL
                                                                            , (
                                                                                    SELECT  concat( ddd_telefone, ' ', numero_telefone ) as telefone
                                                                                    FROM   clientes_telefones clt
                                                                                    WHERE  clt.cod_cliente = cl.cod_cliente
                                                                                    LIMIT  1
                                                                              ) AS TELEFONE


                                                                            , '' AS CONTRATO_HNK
                                                                            , '' AS MARCA_PRINCIPAL

                                                                              -- HL TOTAL
                                                                            , ROUND( SUM( CASE WHEN vol.data_mx = DATE {data} - INTERVAL '1 year' THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_RGB_LY
                                                                            , '' AS META_RGB
                                                                            , ROUND( SUM( CASE WHEN vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_RGB_ATUAL


                                                                    FROM 	   clientes_dados_basicos cl
                                                                               INNER JOIN clientes_dados_cadastrais cad ON cl.COD_CLIENTE = cad.cod_cliente
                                                                               LEFT JOIN volume_agregado_analitico_ac vol ON vol.cod_cliente = cl.cod_cliente
                                                                                                                            AND VOL.data_mx BETWEEN (DATE {data} - INTERVAL '1 YEAR') AND DATE {data}
                                                                                                                            
                                                                               LEFT JOIN clientes_dados_matriz_potencial mp ON CL.cod_cliente = mp.cod_cliente

                                                                    WHERE  	   cl.gv IN ({gv})
                                                                               AND cl.status_cliente = 'A'
                                                                               AND cod_agregador IN ( 'HRET' )
                                                                    GROUP BY  cl.gv
                                                                            , CL.cod_cliente
                                                                            , cad.cod_heineken
                                                                            , cl.razao_social
                                                                            , cad.nome_fantasia
                                                                            , cl.tipo_logradouro
                                                                            , cl.logradouro
                                                                            , cl.bairro
                                                                            , cl.municipio
                                                                            , cl.categoria_cliente
                                                                            , mp.segmentacao

			                                                        )


                    SELECT   ROW_NUMBER() OVER (ORDER BY COALESCE(ce.VOL_RGB_ATUAL, 0) DESC) AS POSICAO
                            , ce.gv
                            , ce.CODIGO_BW
                            , ce.RAZAO_SOCIAL
                            , ce.NOME_FANTASIA
                            , ce.LOGRADOURO
                            , ce.BAIRRO
                            , ce.MUNICIPIO
                            , ce.CANAL
                            , ce.SEGMENTACAO
                            , ce.EMAIL
                            , ce.TELEFONE
                            , ce.CONTRATO_HNK
                            , ce.MARCA_PRINCIPAL

                            , ce.VOL_RGB_LY
                            , ce.VOL_RGB_ATUAL
                            , ce.META_RGB
                            , ce.VOL_RGB_ATUAL - ce.VOL_RGB_LY AS VOL_HL_TENDENCIA
                    FROM    maiores_rgb ce
                    ORDER BY COALESCE(ce.VOL_RGB_ATUAL, 0) DESC
                    LIMIT 50";

                    using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                    {
                        if (line.HasRows)
                        {
                            exportaExcel(line, filePath, file, planilha);
                        }
                    }
                }
                catch (Exception ex)
                {
                    Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                    Dts.TaskResult = (int)ScriptResults.Failure;
                }
            }
        }
        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["User::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["User::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                                    WITH sku as (
                                                    SELECT    opf.data_mx
                                                            , opf.cod_cliente
                                                            , count( DISTINCT opf.cod_produto )  AS TOTAL
                                                    FROM    opf_analitico_mx opf
                                                    WHERE   opf.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                            AND opf.cod_operacao in ( 1, 2, 4, 5 )
                                                            AND cod_cliente = '10155'
                                                    GROUP BY opf.data_mx
                                                           , opf.cod_cliente
                                                )
                                , clientes_estrategicos AS (

                                                    SELECT    cl.gv
                                                            , CL.cod_cliente
                                                            , CONCAT(current_user, cad.cod_heineken) AS CODIGO_BW
                                                            , UPPER( cl.razao_social ) AS RAZAO_SOCIAL
                                                            , UPPER( cad.nome_fantasia ) AS NOME_FANTASIA
                                                            , CONCAT( cl.tipo_logradouro, ' ', cl.logradouro ) AS LOGRADOURO
                                                            , UPPER( cl.bairro ) AS BAIRRO
                                                            , UPPER( cl.municipio ) AS MUNICIPIO
                                                            , UPPER( cl.categoria_cliente ) AS CANAL
                                                            , CASE WHEN  mp.segmentacao IS NULL THEN  'OURO' ELSE mp.segmentacao END AS SEGMENTACAO
                                                            , (
                                                                    SELECT upper(email)
                                                                    FROM   clientes_emails clm
                                                                    WHERE  clm.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                              ) AS EMAIL
                                                            , (
                                                                    SELECT  concat( ddd_telefone, ' ', numero_telefone ) as telefone
                                                                    FROM   clientes_telefones clt
                                                                    WHERE  clt.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                             ) AS TELEFONE


                                                            , '' AS CONTRATO_HNK
                                                            , '' AS MARCA_PRINCIPAL

                                                             -- HL TOTAL
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_HL_TOTAL_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_HL_TOTAL_ATUAL

                                                             -- RGB
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_RGB_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_RGB_ATUAL
                  
                                                             -- CHOPP
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_CHOPP_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 )  AS VOL_CHOPP_ATUAL
                   
                                                            , (  SELECT ROUND( SUM(TOTAL) / 3, 0 )
                                                                 FROM   sku sku
                                                                 WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND (DATE {data} - INTERVAL '1 months') ) AS SKU_PDV_TRI
                                                            , (  SELECT SUM(TOTAL)
                                                                 FROM   sku sku
                                                                 WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx = {data} )  AS SKU_PDV_ATUAL

                                                            , '' AS VENDA_CHOPP
										                    , '' AS CHOPP_Concorrencia
                                                            , '' AS Plano_acao

                                                    FROM 	   clientes_dados_basicos cl
                                                               INNER JOIN clientes_dados_cadastrais cad ON cl.COD_CLIENTE = cad.cod_cliente
                                                               LEFT JOIN volume_agregado_analitico_ac vol ON vol.cod_cliente = cl.cod_cliente
                                                                                                         AND VOL.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                                                                         AND cod_agregador IN ( 'TSCH', 'CRET', 'CPTT' )
                                                               LEFT JOIN clientes_dados_matriz_potencial mp ON CL.cod_cliente = mp.cod_cliente

                                                    WHERE  	   cl.gv IN (1, 4, 6)
                                                               AND cl.status_cliente = 'A'
                                                    GROUP BY  cl.gv
                                                            , CL.cod_cliente
                                                            , cad.cod_heineken
                                                            , cl.razao_social
                                                            , cad.nome_fantasia
                                                            , cl.tipo_logradouro
                                                            , cl.logradouro
                                                            , cl.bairro
                                                            , cl.municipio
                                                            , cl.categoria_cliente
                                                            , mp.segmentacao

			                                        )


                    SELECT    ce.gv
                            , ce.CODIGO_BW
                            , ce.RAZAO_SOCIAL
                            , ce.NOME_FANTASIA
                            , ce.LOGRADOURO
                            , ce.BAIRRO
                            , ce.MUNICIPIO
                            , ce.CANAL
                            , ce.SEGMENTACAO
                            , ce.EMAIL
                            , ce.TELEFONE
                            , ce.CONTRATO_HNK
                            , ce.MARCA_PRINCIPAL

                            , ce.VOL_HL_TOTAL_TRI
                            , ce.VOL_HL_TOTAL_ATUAL
                            , ce.VOL_HL_TOTAL_ATUAL - ce.VOL_HL_TOTAL_TRI AS VOL_HL_TENDENCIA

                            , ce.VOL_RGB_TRI
                            , ce.VOL_RGB_ATUAL
                            , ce.VOL_RGB_ATUAL - ce.VOL_RGB_TRI AS VOL_RGB_TENDENCIA

                            , ce.VOL_CHOPP_TRI
                            , ce.VOL_CHOPP_ATUAL
                            , ce.VOL_CHOPP_ATUAL - ce.VOL_CHOPP_TRI AS VOL_CHOPP_TENDENCIA

                            , ce.SKU_PDV_TRI
                            , ce.SKU_PDV_ATUAL
                            , ce.SKU_PDV_ATUAL - ce.SKU_PDV_TRI AS SKU_PDV_TENDENCIA

                            , ce.VENDA_CHOPP
                            , ce.CHOPP_Concorrencia
                            , ce.Plano_acao
                    FROM    clientes_estrategicos ce";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int revenda, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, revenda, packageName); // Passando os parâmetros como objetos

                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
