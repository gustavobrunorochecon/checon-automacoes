          <ProjectItem
            Name="CustomMessageBox .cs"
            Encoding="UTF8"><![CDATA[using System;
using System.Collections.Generic;
using System.Drawing;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Forms;

namespace ST_d7b8814700fe44dd9a3833e7fbbeb0e3
{

    public partial class CustomMessageBox : Form
    {
        private System.Windows.Forms.Label lblTempo;
        private System.Windows.Forms.Button btnSubir;
        private System.Windows.Forms.Button btnExecutar;

        public enum CustomDialogResult
        {
            Nenhuma,
            SubirBase,
            ExecutarBase
        }

        public CustomDialogResult Result { get; private set; } = CustomDialogResult.Nenhuma;

        private int segundosRestantes = 60;
        private Timer timer;

        public CustomMessageBox()
        {
            InitializeComponent();
            InicializarTimer();
        }

        private void InicializarTimer()
        {
            timer = new Timer();
            timer.Interval = 1000;
            timer.Tick += Timer_Tick;
            timer.Start();
            AtualizarLabel();
        }

        private void Timer_Tick(object sender, EventArgs e)
        {
            segundosRestantes--;
            AtualizarLabel();

            if (segundosRestantes <= 0)
            {
                timer.Stop();
                Result = CustomDialogResult.ExecutarBase;
                this.DialogResult = DialogResult.OK;
                this.Close();
            }
        }

        private void AtualizarLabel()
        {
            int min = segundosRestantes / 60;
            int sec = segundosRestantes % 60;
            lblTempo.Text = $"Tempo restante: {min:D2}:{sec:D2}";
        }

        private void btnSubir_Click(object sender, EventArgs e)
        {
            timer.Stop();
            Result = CustomDialogResult.SubirBase;
            this.DialogResult = DialogResult.OK;
            this.Close();
        }

        private void btnExecutar_Click(object sender, EventArgs e)
        {
            timer.Stop();
            Result = CustomDialogResult.ExecutarBase;
            this.DialogResult = DialogResult.OK;
            this.Close();
        }    

        private void InitializeComponent()
        {
            this.lblTempo = new System.Windows.Forms.Label();
            this.btnSubir = new System.Windows.Forms.Button();
            this.btnExecutar = new System.Windows.Forms.Button();
            this.SuspendLayout();

            // lblTempo
            this.lblTempo.AutoSize = true;
            this.lblTempo.Font = new System.Drawing.Font("Segoe UI", 12F);
            this.lblTempo.Location = new System.Drawing.Point(60, 20);
            this.lblTempo.Name = "lblTempo";
            this.lblTempo.Size = new System.Drawing.Size(180, 21);
            this.lblTempo.TabIndex = 0;
            this.lblTempo.Text = "Tempo restante: 01:00";

            // btnSubir
            this.btnSubir.Location = new System.Drawing.Point(40, 60);
            this.btnSubir.Name = "btnSubir";
            this.btnSubir.Size = new System.Drawing.Size(100, 30);
            this.btnSubir.TabIndex = 1;
            this.btnSubir.Text = "Subir Base";
            this.btnSubir.UseVisualStyleBackColor = true;
            this.btnSubir.Click += new System.EventHandler(this.btnSubir_Click);

            // btnLimpar
            this.btnExecutar.Location = new System.Drawing.Point(160, 60);
            this.btnExecutar.Name = "btnExecutar";
            this.btnExecutar.Size = new System.Drawing.Size(100, 30);
            this.btnExecutar.TabIndex = 2;
            this.btnExecutar.Text = "Executar";
            this.btnExecutar.UseVisualStyleBackColor = true;
            this.btnExecutar.Click += new System.EventHandler(this.btnExecutar_Click);

            // Form
            this.AutoScaleDimensions = new System.Drawing.SizeF(6F, 13F);
            this.AutoScaleMode = System.Windows.Forms.AutoScaleMode.Font;
            this.ClientSize = new System.Drawing.Size(300, 110);
            this.Controls.Add(this.lblTempo);
            this.Controls.Add(this.btnSubir);
            this.Controls.Add(this.btnExecutar);
            this.FormBorderStyle = System.Windows.Forms.FormBorderStyle.FixedDialog;
            this.MaximizeBox = false;
            this.MinimizeBox = false;
            this.Name = "CustomMessageBox";
            this.StartPosition = System.Windows.Forms.FormStartPosition.CenterScreen;
            this.Text = "Confirmação";
            this.ResumeLayout(false);
            this.PerformLayout();
        }
    }

}]]></ProjectItem>
