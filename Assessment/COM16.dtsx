              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MimeKit;
using MailKit.Security;
using MailKit.Net.Smtp;
using MySql.Data.MySqlClient;
using System.Globalization;
using Mysqlx.Datatypes;
using static System.Windows.Forms.VisualStyles.VisualStyleElement.ListView;

#endregion

namespace ST_00387ddfa53f4a61a67305738af9ad71
{
    /// <summary>
    /// ScriptMain is the entry point class of the script.  Do not change the name, attributes,
    /// or parent of this class.
    /// </summary>
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {

        public void Main()
        {
            try
            {
                int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
                int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
                string destino = Dts.Variables["$Package::Destino"].Value.ToString();
                string arquivo = "GESTÃO DE AÇÕES DE MERCADO.xlsx";

                string attachmentPath = $@"{destino}\gerados\{arquivo}";
                var bodyBuilder = new BodyBuilder();

                bodyBuilder.HtmlBody = $@" <html>
                                            <head>
                                                <meta charset='UTF-8'>
                                            </head>
                                            <body style='font-family: Arial, Helvetica, sans-serif; font-size:14px; color:#333;'>

                                                <p>{saudacao()}</p>

                                                <p>
                                                    Segue em anexo o arquivo 
                                                    <strong>{arquivo.Replace(".xlsx", "")}</strong>, 
                                                    contendo os resultados das <strong>AÇÕES DE TRADE</strong> da companhia referentes ao mês atual.
                                                </p>

                                                <br>

                                                {assinatura()}

                                            </body>
                                            </html>";


                bodyBuilder.Attachments.Add(attachmentPath);


                var message = new MimeMessage();
                message.From.Add(new MailboxAddress(null, "gustavo.brunoro@checon.com.br"));

                // Definindo a prioridade como alta
                message.Priority = MessagePriority.Urgent;  // Define o e-mail como urgente
                message.Headers.Add("X-Priority", "1");  // Definindo a prioridade do cabeçalho


                //string[] destinatarios = new string[] {
                //                                        "henrique.dantas@checon.com.br",
                //                                        "uelvis.cordeiro@checon.com.br",
                //                                        "gevaldo.junior@checon.com.br"
                //                                       };

                //string[] destinatariosCc = { "gvendas@checon.com.br" };

                //// Adiciona cada destinatário ao campo To
                //foreach (var email in destinatarios)
                //{
                //    message.To.Add(new MailboxAddress(null, email));
                //}

                //// Adiciona cada destinatário ao campo Cc
                //foreach (var email in destinatariosCc)
                //{
                //    message.Cc.Add(new MailboxAddress(null, email));
                //}               

                message.To.Add(new MailboxAddress(null, "gustavo.brunoro@checon.com.br"));

                message.Subject = "AÇÕES DE TRADE";

                message.Body = bodyBuilder.ToMessageBody();

                using (var client = new SmtpClient())
                {
                    try
                    {
                        client.Connect("smtp.office365.com", 587, SecureSocketOptions.StartTls);
                        client.Authenticate("gustavo.brunoro@checon.com.br", "Xap41697");

                        client.Send(message);
                        Console.WriteLine("E-mail enviado com sucesso!");
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Erro ao enviar e-mail: {ex.Message}");
                    }
                    finally
                    {
                        client.Disconnect(true);
                        client.Dispose();
                    }
                }

                Dts.TaskResult = (int)ScriptResults.Success;

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao enviar o e-mail", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        public string saudacao()
        {
            DateTime horaAtual = DateTime.Now;

            // Verifica se está entre 06:00 e 12:00 (Bom Dia)
            if (horaAtual.TimeOfDay >= TimeSpan.Parse("06:00") && horaAtual.TimeOfDay <= TimeSpan.Parse("12:00"))
            {
                return "Bom Dia!, ";
            }
            // Verifica se está entre 12:01 e 20:00 (Boa Tarde)
            else if (horaAtual.TimeOfDay > TimeSpan.Parse("12:00") && horaAtual.TimeOfDay <= TimeSpan.Parse("20:00"))
            {
                return "Boa Tarde!, ";
            }

            return "Boa Noite!, ";  // Caso contrário, "Boa Noite!"
        }

        public string assinatura()
        {
            string assinatura = @"<p>Att.,</p>
                                  <br>
                                  <p>Gustavo Brunoro<br>
                                  Analista de Vendas<br>
                                  (73) 9 9963-6328 <br>
                                  Eunápolis - Ba</p>
                                  <br>
                                  <img src=""cid:logo.png"" alt=""Logo"" />";

            return assinatura;
        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

    }
}]]></ProjectItem>
