        public void Main()
        {
            int Ano = Convert.ToInt32(Dts.Variables["Package::Ano"].Value);
            int Mes = Convert.ToInt32(Dts.Variables["Package::Mes"].Value);
  
            string diretorios = $@"C:\Users\GustavoBrunoro\CHECON DISTRIBUIDORA E TRANSPORTADORA LTDA\ANALISTAS - Documentos\01 ACOES";

            string nomeMes = $"{Mes:00} - " + CultureInfo.GetCultureInfo("pt-BR").DateTimeFormat.GetMonthName(Mes).ToUpper();          

            diretorios = $@"{diretorios}\{Ano}\{nomeMes}\";

            List<string> schemas = new List<string> { "x230", "x690" };

            foreach (string schema in schemas)
            {

                var ACAO = new Dictionary<string, Type>
                {
                    { "acao", typeof(int) },
                    { "nome", typeof(string) },
                    { "descricao", typeof(string) },
                    { "dataInicio", typeof(DateTime) },
                    { "dataFim", typeof(DateTime) },
                    { "meta", typeof(int) },
                    { "ativo", typeof(int) },

                };

                atualizar_ACAO(Dts, schema, "acao", null, importarCSV($@"{diretorios}\acao.csv"));

                var ACAO_BASE = new Dictionary<string, Type>
                {
                    { "acao", typeof(int) },
                    { "codigo_bw", typeof(string) },
                    { "meta", typeof(decimal) },
                    { "categoria", typeof(string) },
                    { "pack", typeof(string) },
                    { "canal", typeof(string) }

                };

                atualizar_ACAO_BASE(Dts, schema, "acao_base", null, importarCSV($@"{diretorios}\acao_base.csv"));
            }

            Dts.TaskResult = (int)ScriptResults.Success;
        }
        #region Metodos

        private void atualizar_ACAO(ScriptObjectModel dts, string schema, string tabela, string primaryKey, DataTable dataTable)
        {
            AccessDataPostgreSQL accessDataPostgreSQL = new AccessDataPostgreSQL(schema);

            accessDataPostgreSQL.dropAndCreateTable(schema, tabela, dataTable, null);

            try
            {
                string insertSql = @" INSERT INTO acao (acao, nome, descricao, datainicio, datafim, meta, ativo)
                                      VALUES           (@acao, @nome, @descricao, @datainicio, @datafim, @meta, @ativo)";

                string updateSql = @"
                                    UPDATE acao
                                    SET nome = @nome
                                      , descricao = @descricao    
                                      , datainicio = @datainicio  
                                      , datafim = @datafim
                                      , meta = @meta
                                      , ativo = @ativo
                                    WHERE acao = @acao";

                foreach (DataRow row in dataTable.Rows)
                {

                    string condition = $"acao = {row["acao"].ToString()}";

                    // Limpar parâmetros antes de cada execução
                    accessDataPostgreSQL.parameterClear();

                    // Adicionar os parâmetros dinamicamente com base nas colunas
                    accessDataPostgreSQL.addParameter("@acao", row["acao"]);
                    accessDataPostgreSQL.addParameter("@nome", row["nome"]);
                    accessDataPostgreSQL.addParameter("@descricao", row["descricao"]);
                    accessDataPostgreSQL.addParameter("@datainicio", row["datainicio"]);
                    accessDataPostgreSQL.addParameter("@datafim", row["datafim"]);
                    accessDataPostgreSQL.addParameter("@meta", row["meta"]);
                    accessDataPostgreSQL.addParameter("@ativo", row["ativo"]);

                    // Executar InsertOrUpdate
                    int linhasAfetadas = accessDataPostgreSQL.executeInsertOrUpdate("acao", condition, insertSql, updateSql);
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro no InsertOrUpdate. Detalhes ", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }

        }

        private void atualizar_ACAO_BASE(ScriptObjectModel dts, string schema, string tabela, string primaryKey, DataTable dataTable)
        {

            AccessDataPostgreSQL accessDataPostgreSQL = new AccessDataPostgreSQL(schema);

            // accessDataPostgreSQL.dropAndCreateTable(schema, tabela, dataTable, primaryKey);

            try
            {
                string insertSql = @" INSERT INTO acao_base (acao,   codigo_bw,  meta,  categoria,  pack,  canal,  datainicio,  datafim)
                                      VALUES                (@acao, @codigo_bw, @meta, @categoria, @pack, @canal, @datainicio, @datafim)";



                var rows = dataTable.Select()
                                    .Where(r => r["codigo_bw"]?.ToString().Contains(schema.ToUpper()) == true)
                                    .OrderBy(r => Convert.ToInt32( r["acao"]) );


                string deleteSql = @" DELETE FROM acao_base
                                      WHERE  acao = @acao
                                             AND datainicio = @datainicio::date
                                             AND datafim = @datafim::date";

                var chaves = rows
                    .Select(r => new
                    {
                        Acao = r["acao"],
                        DataInicio = r["datainicio"],
                        DataFim = r["datafim"]
                    })
                    .Distinct()
                    .ToList();

                // ============================
                // DELETE (ANTES DO INSERT)
                // ============================
                foreach (var chave in chaves)
                {
                    accessDataPostgreSQL.parameterClear();

                    accessDataPostgreSQL.addParameter("@acao", chave.Acao);
                    accessDataPostgreSQL.addParameter("@datainicio", chave.DataInicio);
                    accessDataPostgreSQL.addParameter("@datafim", chave.DataFim);

                    accessDataPostgreSQL.executeDelete(deleteSql);

                }

                // ============================
                // INSERI OS DADOS
                // ============================
                foreach (DataRow row in rows)
                {
                    // Limpar parâmetros antes de cada execução
                    accessDataPostgreSQL.parameterClear();

                    // Adicionar os parâmetros dinamicamente com base nas colunas                    
                    accessDataPostgreSQL.addParameter("@acao", row["acao"]);
                    accessDataPostgreSQL.addParameter("@codigo_bw", row["codigo_bw"]);
                    accessDataPostgreSQL.addParameter("@meta", row["meta"]);
                    accessDataPostgreSQL.addParameter("@categoria", row["categoria"]);
                    accessDataPostgreSQL.addParameter("@pack", row["pack"]);
                    accessDataPostgreSQL.addParameter("@canal", row["canal"]);
                    accessDataPostgreSQL.addParameter("@datainicio", row["datainicio"]);
                    accessDataPostgreSQL.addParameter("@datafim", row["datafim"]);

                    // Executar Insert
                    accessDataPostgreSQL.executeInsert(insertSql);
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro no Insert. Detalhes ", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

