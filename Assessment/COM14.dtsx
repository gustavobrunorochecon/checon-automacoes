using Bibliotecas;
using System.Windows.Forms;
using MySqlX.XDevAPI;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value);
            string packageName = Dts.Variables["System::PackageName"].Value.ToString();
            string Email = Dts.Variables["$Package::Email"].Value.ToString();

            string filePath = $@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\dados\";
            string file = "dados_" + revenda + ".xlsx";

            File.Delete(filePath + file);

            bd_Dados(Dts, filePath, file, "dados");            

            ExecutarMacroExcel($@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\vba.xlsm", "build.formataArquivo", revenda, packageName);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                String ano = Dts.Variables["$Package::Ano"].Value.ToString();
                String mes = Dts.Variables["$Package::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = @" SELECT cl.cod_cliente
                                        , cl.vd as setor
		                                , UPPER( TRIM( cl.razao_social ) ) AS razao_social
		                                , UPPER( TRIM( cad.nome_fantasia ) ) AS nome_fantasia
		                                , UPPER( CASE WHEN mp.segmentacao IS NULL THEN 'BRONZE' ELSE mp.segmentacao END ) AS segmentacao
		                                , UPPER( cl.categoria_cliente ) as categoria_cliente
                                        , string_agg( trim(d.dia), ',' ORDER BY array_position(dias, trim(d.dia)) ) AS dia_visita
 		                                , (
                                            SELECT   frequencia_visita
 		                                    FROM     clientes_agenda_de_visitas vis
 		                                    WHERE    vis.cod_cliente = cl.cod_cliente
 		                                    GROUP BY frequencia_visita
                                           )
                                        -- , string_agg( dias[(array_position(dias, trim(d.dia)) % 7) + 1], ',' ORDER BY array_position(dias, (dias[(array_position(dias, trim(d.dia)) % 7) + 1])) ) AS dia_entrega
                                        , STRING_AGG( CASE  WHEN TRIM(d.dia) = 'SAB' THEN 'SEG' ELSE dias[(array_position(dias, trim(d.dia)) % 7) + 1] END, ','  ORDER BY CASE WHEN TRIM(d.dia) = 'SAB' THEN array_position(dias,'SEG') ELSE array_position(dias, dias[(array_position(dias, trim(d.dia)) % 7) + 1]) END ) AS dia_entrega
                                        , CASE WHEN cad.cpf_ou_cnpj = 'CPF' THEN regexp_replace(cad.num_cpf_cnpj, '(\d{3})(\d{3})(\d{3})(\d{2})', '\1.\2.\3-\4') ELSE regexp_replace(cad.num_cpf_cnpj, '(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})', '\1.\2.\3/\4-\5') END AS numero_cpf_cnpj

		                                , COALESCE ( (  SELECT CASE WHEN ddd_telefone = '0' OR LENGTH(ddd_telefone) = 1 THEN '73' ELSE TRIM(ddd_telefone) END || ' ' || TRIM(numero_telefone)
                                                        FROM clientes_telefones clt
                                                        WHERE clt.cod_cliente = cl.cod_cliente
                                                        LIMIT 1
                                        ), CONCAT( '73 99', FLOOR(RANDOM() * 90 + 10)::INT, FLOOR(RANDOM() * 9000 + 1000)::INT ) ) AS telefone

                                        , COALESCE ( (  SELECT TRIM(email)
                                                        FROM clientes_emails clt
                                                        WHERE clt.cod_cliente = cl.cod_cliente
                                                        LIMIT 1
                                        ), UPPER( split_part(TRIM(cad.nome_fantasia), ' ', 1) || '.' || split_part( TRIM(cad.nome_fantasia), ' ', array_length(  string_to_array(TRIM(cad.nome_fantasia), ' '), 1 ) ) || '@HOTMAIL.COM' ) ) AS email

		                                , UPPER( TRIM( cl.municipio ) ) AS municipio
		                                , UPPER( TRIM( cl.bairro ) ) AS bairro
		                                , UPPER( CONCAT( TRIM(cl.tipo_logradouro), '. ', TRIM(cl.logradouro) ) ) AS endereco
                                        , CAST( cl.cep AS TEXT ) CEP
		                                , CASE WHEN cad.latitude = '0'  OR cad.latitude IS NULL  OR cad.latitude = '' THEN '-16.335624828147843' ELSE cad.latitude END AS latitude
	                                    , CASE WHEN cad.longitude = '0' OR cad.longitude IS NULL OR cad.longitude = '' THEN ' -39.58324670865667' ELSE cad.latitude END AS longitude                           
                                        , REPLACE(
                                                    CASE                                                
                                                        -- BAR/ESPECIAIS OU RESTAURANTES
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('BAR A/B','BAR C/D','ENTRETENIMENTO ESPEC','RESTAURANTE A/B','RESTAURANTE C/D','LANCHONETE','OUTROS','PADARIA/CONFEITARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'BRONZE'   AND cad.limite_liberado < 300.00  THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('BAR A/B','BAR C/D','ENTRETENIMENTO ESPEC','RESTAURANTE A/B','RESTAURANTE C/D','LANCHONETE','OUTROS','PADARIA/CONFEITARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'PRATA'    AND cad.limite_liberado < 600.00  THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('BAR A/B','BAR C/D','ENTRETENIMENTO ESPEC','RESTAURANTE A/B','RESTAURANTE C/D','LANCHONETE','OUTROS','PADARIA/CONFEITARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'OURO'     AND cad.limite_liberado < 1500.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('BAR A/B','BAR C/D','ENTRETENIMENTO ESPEC','RESTAURANTE A/B','RESTAURANTE C/D','LANCHONETE','OUTROS','PADARIA/CONFEITARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'DIAMANTE' AND cad.limite_liberado < 3000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'

                                                        -- CASH & CARRY
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('CASH CARRY') AND COALESCE(mp.segmentacao, 'BRONZE') = 'BRONZE'   AND cad.limite_liberado < 200.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('CASH CARRY') AND COALESCE(mp.segmentacao, 'BRONZE') = 'PRATA'    AND cad.limite_liberado < 400.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('CASH CARRY') AND COALESCE(mp.segmentacao, 'BRONZE') = 'OURO'     AND cad.limite_liberado < 600.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('CASH CARRY') AND COALESCE(mp.segmentacao, 'BRONZE') = 'DIAMANTE' AND cad.limite_liberado < 800.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'

                                                        -- TRAD, MERCEARIA
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ARMAZÉM/MERCEARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'BRONZE'   AND cad.limite_liberado < 400.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ARMAZÉM/MERCEARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'PRATA'    AND cad.limite_liberado < 800.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ARMAZÉM/MERCEARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'OURO'     AND cad.limite_liberado < 1500.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ARMAZÉM/MERCEARIA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'DIAMANTE' AND cad.limite_liberado < 3000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'

                                                        -- ASI E AUTO SERV.
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('HIPERMERCADO','LOJA DE CONVENIÊNCIA','MINI A/B','MINI C/D','SUPER A/B','SUPER C/D') AND COALESCE(mp.segmentacao, 'BRONZE') = 'BRONZE'   AND cad.limite_liberado < 1000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('HIPERMERCADO','LOJA DE CONVENIÊNCIA','MINI A/B','MINI C/D','SUPER A/B','SUPER C/D') AND COALESCE(mp.segmentacao, 'BRONZE') = 'PRATA'    AND cad.limite_liberado < 3000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('HIPERMERCADO','LOJA DE CONVENIÊNCIA','MINI A/B','MINI C/D','SUPER A/B','SUPER C/D') AND COALESCE(mp.segmentacao, 'BRONZE') = 'OURO'     AND cad.limite_liberado < 5000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('HIPERMERCADO','LOJA DE CONVENIÊNCIA','MINI A/B','MINI C/D','SUPER A/B','SUPER C/D') AND COALESCE(mp.segmentacao, 'BRONZE') = 'DIAMANTE' AND cad.limite_liberado < 10000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'

                                                        -- ADEGA
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ADEGA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'BRONZE'   AND cad.limite_liberado < 1500.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ADEGA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'PRATA'    AND cad.limite_liberado < 3000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ADEGA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'OURO'     AND cad.limite_liberado < 5000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'
                                                        WHEN UPPER(TRIM(cl.categoria_cliente)) IN ('ADEGA') AND COALESCE(mp.segmentacao, 'BRONZE') = 'DIAMANTE' AND cad.limite_liberado < 10000.00 THEN 'PDV COM RESTRIÇÃO DE CRÉDITO'

                                                        ELSE CAST(cad.limite_liberado AS TEXT) END , '.', ',') as imite_credito
                                FROM   clientes_dados_basicos AS cl
                                       INNER JOIN clientes_dados_cadastrais cad on cl.cod_cliente = cad.cod_cliente
	                                   LEFT JOIN clientes_dados_matriz_potencial AS mp ON cl.cod_cliente = mp.cod_cliente
                                       -- dias de visita   
                                       CROSS JOIN LATERAL (SELECT dia_visita(cl.cod_cliente) AS dv) base
                                       -- quebra múltiplos dias
                                       CROSS JOIN LATERAL unnest(string_to_array(base.dv, ',')) AS d(dia)
                                       -- array fixo de dias
                                       CROSS JOIN (SELECT ARRAY['DOM','SEG','TER','QUA','QUI','SEX','SAB'] AS dias) t
                                WHERE  cad.status_cliente IN ('A')
	                                   AND cl.gv IN ( 1, 4, 6 )
	                                   AND cad.data_cadastro_cliente < last_day( DATE " + data + @" )                                       
                                GROUP BY  cl.cod_cliente
                                        , cl.vd
                                        , cl.razao_social
                                        , cad.nome_fantasia
                                        , mp.segmentacao
                                        , cl.categoria_cliente
                                        , cad.cpf_ou_cnpj
                                        , cad.num_cpf_cnpj
                                        , cad.latitude
	                                    , cad.longitude
                                        , cad.limite_liberado ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }        
        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["User::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["User::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                                    WITH sku as (
                                                    SELECT    opf.data_mx
                                                            , opf.cod_cliente
                                                            , count( DISTINCT opf.cod_produto )  AS TOTAL
                                                    FROM    opf_analitico_mx opf
                                                    WHERE   opf.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                            AND opf.cod_operacao in ( 1, 2, 4, 5 )
                                                            AND cod_cliente = '10155'
                                                    GROUP BY opf.data_mx
                                                           , opf.cod_cliente
                                                )
                                , clientes_estrategicos AS (

                                                    SELECT    cl.gv
                                                            , CL.cod_cliente
                                                            , CONCAT(current_user, cad.cod_heineken) AS CODIGO_BW
                                                            , UPPER( cl.razao_social ) AS RAZAO_SOCIAL
                                                            , UPPER( cad.nome_fantasia ) AS NOME_FANTASIA
                                                            , CONCAT( cl.tipo_logradouro, ' ', cl.logradouro ) AS LOGRADOURO
                                                            , UPPER( cl.bairro ) AS BAIRRO
                                                            , UPPER( cl.municipio ) AS MUNICIPIO
                                                            , UPPER( cl.categoria_cliente ) AS CANAL
                                                            , CASE WHEN  mp.segmentacao IS NULL THEN  'OURO' ELSE mp.segmentacao END AS SEGMENTACAO
                                                            , (
                                                                    SELECT upper(email)
                                                                    FROM   clientes_emails clm
                                                                    WHERE  clm.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                              ) AS EMAIL
                                                            , (
                                                                    SELECT  concat( ddd_telefone, ' ', numero_telefone ) as telefone
                                                                    FROM   clientes_telefones clt
                                                                    WHERE  clt.cod_cliente = cl.cod_cliente
                                                                    LIMIT  1
                                                             ) AS TELEFONE


                                                            , '' AS CONTRATO_HNK
                                                            , '' AS MARCA_PRINCIPAL

                                                             -- HL TOTAL
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_HL_TOTAL_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'TSCH' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_HL_TOTAL_ATUAL

                                                             -- RGB
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_RGB_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CRET' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 ) AS VOL_RGB_ATUAL
                  
                                                             -- CHOPP
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND DATE (DATE {data} - INTERVAL '1 months') THEN vol.saldo_hl ELSE 0 END ) / 3 ,3 ) AS VOL_CHOPP_TRI
                                                            , ROUND( SUM( CASE WHEN vol.cod_agregador IN ( 'CPTT' ) AND vol.data_mx = DATE {data} THEN vol.saldo_hl ELSE 0 END ),3 )  AS VOL_CHOPP_ATUAL
                   
                                                            , (  SELECT ROUND( SUM(TOTAL) / 3, 0 )
                                                                 FROM   sku sku
                                                                 WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx BETWEEN (DATE {data} - INTERVAL '3 months') AND (DATE {data} - INTERVAL '1 months') ) AS SKU_PDV_TRI
                                                            , (  SELECT SUM(TOTAL)
                                                                 FROM   sku sku
                                                                 WHERE  sku.cod_cliente = cl.cod_cliente
                                                                        AND sku.data_mx = {data} )  AS SKU_PDV_ATUAL

                                                            , '' AS VENDA_CHOPP
										                    , '' AS CHOPP_Concorrencia
                                                            , '' AS Plano_acao

                                                    FROM 	   clientes_dados_basicos cl
                                                               INNER JOIN clientes_dados_cadastrais cad ON cl.COD_CLIENTE = cad.cod_cliente
                                                               LEFT JOIN volume_agregado_analitico_ac vol ON vol.cod_cliente = cl.cod_cliente
                                                                                                         AND VOL.data_mx BETWEEN (DATE {data} - INTERVAL '4 months') AND DATE {data}
                                                                                                         AND cod_agregador IN ( 'TSCH', 'CRET', 'CPTT' )
                                                               LEFT JOIN clientes_dados_matriz_potencial mp ON CL.cod_cliente = mp.cod_cliente

                                                    WHERE  	   cl.gv IN (1, 4, 6)
                                                               AND cl.status_cliente = 'A'
                                                    GROUP BY  cl.gv
                                                            , CL.cod_cliente
                                                            , cad.cod_heineken
                                                            , cl.razao_social
                                                            , cad.nome_fantasia
                                                            , cl.tipo_logradouro
                                                            , cl.logradouro
                                                            , cl.bairro
                                                            , cl.municipio
                                                            , cl.categoria_cliente
                                                            , mp.segmentacao

			                                        )


                    SELECT    ce.gv
                            , ce.CODIGO_BW
                            , ce.RAZAO_SOCIAL
                            , ce.NOME_FANTASIA
                            , ce.LOGRADOURO
                            , ce.BAIRRO
                            , ce.MUNICIPIO
                            , ce.CANAL
                            , ce.SEGMENTACAO
                            , ce.EMAIL
                            , ce.TELEFONE
                            , ce.CONTRATO_HNK
                            , ce.MARCA_PRINCIPAL

                            , ce.VOL_HL_TOTAL_TRI
                            , ce.VOL_HL_TOTAL_ATUAL
                            , ce.VOL_HL_TOTAL_ATUAL - ce.VOL_HL_TOTAL_TRI AS VOL_HL_TENDENCIA

                            , ce.VOL_RGB_TRI
                            , ce.VOL_RGB_ATUAL
                            , ce.VOL_RGB_ATUAL - ce.VOL_RGB_TRI AS VOL_RGB_TENDENCIA

                            , ce.VOL_CHOPP_TRI
                            , ce.VOL_CHOPP_ATUAL
                            , ce.VOL_CHOPP_ATUAL - ce.VOL_CHOPP_TRI AS VOL_CHOPP_TENDENCIA

                            , ce.SKU_PDV_TRI
                            , ce.SKU_PDV_ATUAL
                            , ce.SKU_PDV_ATUAL - ce.SKU_PDV_TRI AS SKU_PDV_TENDENCIA

                            , ce.VENDA_CHOPP
                            , ce.CHOPP_Concorrencia
                            , ce.Plano_acao
                    FROM    clientes_estrategicos ce";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }
        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int revenda, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, revenda, packageName); // Passando os parâmetros como objetos

                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
