              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{
		        
        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value);
            string packageName = Dts.Variables["System::PackageName"].Value.ToString();
            string Email = Dts.Variables["$Package::Email"].Value.ToString();
           
            string filePath = $@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\dados\";
            string file = "dados_" + revenda + ".xlsx";


            bd_Dados(Dts, filePath, file, "dados");
            bd_Volume(Dts, filePath, file, "volume");
            dados_relatorios(Dts, filePath, file, "dados_relatorios");

            ExecutarMacroExcel($@"Y:\PUBLICO\ANALISTAS\SSIS\ASSESSMENT\{packageName}\vba.xlsm", "build.formataArquivo", revenda, packageName);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {

                int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
                int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
                string data ="'" + Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01'";

                string query = $@"
				                    SELECT    CASE WHEN USER = 'x230' THEN 201201 ELSE 223402 END AS ""CODIGO OPERACAO""
                                            , CASE WHEN USER = 'x230' THEN 'CHECON DISTRIBUIDORA' ELSE 'CHECON TEIXEIRA' END AS ""NOME OPERACAO""
                                            , CASE WHEN USER = 'x230' THEN '40.436.846/0001-82' ELSE '42.219.306/0001-83' END AS ""CNPJ REVENDA""
                                            , UPPER( user || CDC.COD_HEINEKEN ) AS""CODIGO BW""
                                            , CAST( CDC.cod_cliente AS INTEGER ) AS ""COD CLIENTE""
                                            , UPPER( CDC.RAZAO_SOCIAL ) AS ""NOME PDV""
                                            , COALESCE( matriz.segmentacao, 'BRONZE' ) as ""SEGMENTACAO""
                                            , (CDC.NUM_CPF_CNPJ)::TEXT AS ""CNPJ CPF""
                                            , 'HUMBERTO LUCIANO HOFFMANN DE MORAES' AS ""GVE""
                                            , CASE WHEN bas.gv = 1 THEN 'HENRIQUE MENEZES DANTAS'
                                                    WHEN bas.gv = 4 THEN 'UELVIS CORDEIRO'
                                                    WHEN bas.gv = 6 THEN 'GEVALDO BARBOSA NOVAIS JUNIOR'
                                                    ELSE 'PADRÃO' END AS ""GV""
                                            , CASE WHEN bas.sv = 100 THEN 'GENIVALDO RODRIGUES'
                                                    WHEN bas.sv = 300 THEN 'ALBERT REIAS SILVA'
                                                    WHEN bas.sv = 400 THEN 'ITAMAR OLIVEIRA DE JESUS'
                                                    WHEN bas.sv = 500 THEN 'NORMANDO DA HORA AQUINO JUNIOR'
                                                    WHEN bas.sv = 600 THEN 'THIAGO MAIA H.'
                                                    WHEN bas.sv = 700 THEN 'AELSON CARVALHO'
                                                    WHEN bas.sv = 800 THEN 'IAGO SANTANA'
                                                    ELSE 'PADRÃO' END AS ""SV""
                                            , upper( trim( vd.nome ) ) ""VD""
                                            , comod.data_dx_emissao AS ""DATA EMISSAO""
                                            , '' AS ESPACO_1
                                            , CAST( CASE WHEN PTC.COD_TIPO_COMODATAVEL = '1' THEN SUM( comod.quantidade_emitida - comod.quantidade_recolhida ) ELSE 0 END AS INTEGER ) AS ""REFRIGERADOR 8CX""
                                            , CAST( CASE WHEN PTC.COD_TIPO_COMODATAVEL = '2' THEN SUM( comod.quantidade_emitida - comod.quantidade_recolhida ) ELSE 0 END AS INTEGER ) AS ""REFRIGERADOR 4CX""
                                            , 0 AS ""REFRIGERADOR 1CX""
                                            , CAST( CASE WHEN PTC.COD_TIPO_COMODATAVEL = '22' THEN SUM( comod.quantidade_emitida - comod.quantidade_recolhida ) ELSE 0 END AS INTEGER ) AS ""CHOPPEIRA""
                                            , P.COD_PRODUTO AS ""COD MATERIAL""
                                            , P.NOME_PRODUTO AS ""DESCRICAO MATERIAL""
                                            , PM.MARCA AS ""MARCA""
                                            
                                    FROM    comodatos_emitidos comod
                                            INNER JOIN clientes_dados_cadastrais CDC ON comod.COD_CLIENTE = CDC.COD_CLIENTE
                                            INNER JOIN clientes_dados_basicos bas ON bas.cod_cliente = cdc.cod_cliente
                                            INNER JOIN produtos P ON comod.COD_PRODUTO = P.COD_PRODUTO
                                            INNER JOIN produtos_marcas PM ON P.COD_MARCA = PM.COD_MARCA

                                            INNER JOIN produtos_comodataveis PC ON comod.cod_produto = PC.cod_produto
                                            INNER JOIN produtos_tipo_comodatavel PTC ON PC.cod_tipo_comodatavel = PTC.cod_tipo_comodatavel
                                            INNER JOIN produtos_grupo_comodatavel PGC ON PGC.cod_grupo_comodatavel = PTC.cod_grupo_comodatavel
                                            LEFT JOIN clientes_dados_matriz_potencial matriz ON matriz.cod_cliente = CDC.cod_cliente

                                            LEFT JOIN LATERAL (
                                                                SELECT vd.nome
                                                                FROM   hierarquia_comercial_historico vd
                                                                WHERE  vd.codigo_colaborador = bas.vd
                                                                ORDER BY vd.data_mx DESC
                                                                LIMIT 1
                                                            ) vd ON TRUE
                                     WHERE  date_trunc('month',comod.data_dx_emissao) BETWEEN date_trunc('month', DATE {data})::DATE - INTERVAL '1 year' AND {data}
                                            AND comod.cod_status_comodato = 'A'
                                            AND PGC.COD_GRUPO_COMODATAVEL IN ( 1 , 6 )
                                            AND PTC.tipo_comodatavel IN ( 'REFRIGERADOR GRANDE', 'REFRIGERADOR PEQUENO', 'CHOPPEIRA ELETRICA', 'REFRIGERADOR MINI' )
                                            AND bas.gv IN ( 1, 4, 6 )
                                    GROUP BY CDC.COD_HEINEKEN
                                            , CDC.cod_cliente
                                            , CDC.RAZAO_SOCIAL 
                                            , matriz.segmentacao
                                            , CDC.NUM_CPF_CNPJ
                                            , bas.GV
                                            , bas.SV
                                            , vd.nome
                                            , comod.data_dx_emissao
                                            , PTC.COD_TIPO_COMODATAVEL
                                            , P.COD_PRODUTO 
                                            , P.NOME_PRODUTO
                                            , PM.COD_MARCA
                                            , PM.MARCA 
                                    ORDER BY   bas.GV, CDC.COD_HEINEKEN ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void bd_Volume(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {

                int ano = Convert.ToInt32(Dts.Variables["$Package::Ano"].Value);
                int mes = Convert.ToInt32(Dts.Variables["$Package::Mes"].Value);
                string data = "'" + Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01'";

                // Converter string para DateTime
                DateTime nomeMes = DateTime.ParseExact( Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01" , "yyyyMMdd", CultureInfo.InvariantCulture);

                // Cultura pt-BR
                CultureInfo cultura = new CultureInfo("pt-BR");                

                string query = $@"with base as (
                                                    SELECT    CASE WHEN USER = 'x230' THEN 201201 ELSE 223402 END AS CODIGO_OPERACAO
                                                            , CASE WHEN USER = 'x230' THEN 'CHECON DISTRIBUIDORA' ELSE 'CHECON TEIXEIRA' END AS NOME_OPERACAO
                                                            , CASE WHEN USER = 'x230' THEN '40.436.846/0001-82' ELSE '42.219.306/0001-83' END AS CNPJ_REVENDA
                                                            , UPPER( user || CDC.COD_HEINEKEN ) AS CODIGO_BW
                                                            , CAST( CDC.cod_cliente AS INTEGER ) AS COD_CLIENTE
                                                            , UPPER( CDC.RAZAO_SOCIAL ) AS NOME_PDV
                                                            , COALESCE( matriz.segmentacao, 'BRONZE' ) as SEGMENTACAO
                                                            , (CDC.NUM_CPF_CNPJ)::TEXT AS CNPJ_CPF
                                                            , 'HUMBERTO LUCIANO HOFFMANN DE MORAES' AS GVE
                                                            , CASE WHEN bas.gv = 1 THEN 'HENRIQUE MENEZES DANTAS'
                                                                   WHEN bas.gv = 4 THEN 'UELVIS CORDEIRO'
                                                                   WHEN bas.gv = 6 THEN 'GEVALDO BARBOSA NOVAIS JUNIOR'
                                                                   ELSE 'PADRÃO' END AS GV
                                                            , CASE WHEN bas.sv = 100 THEN 'GENIVALDO RODRIGUES'
                                                                   WHEN bas.sv = 300 THEN 'ALBERT REIAS SILVA'
                                                                   WHEN bas.sv = 400 THEN 'ITAMAR OLIVEIRA DE JESUS'
                                                                   WHEN bas.sv = 500 THEN 'NORMANDO DA HORA AQUINO JUNIOR'
                                                                   WHEN bas.sv = 600 THEN 'THIAGO MAIA H.'
                                                                   WHEN bas.sv = 700 THEN 'AELSON CARVALHO'
                                                                   WHEN bas.sv = 800 THEN 'IAGO SANTANA'
                                                                   ELSE 'PADRÃO' END AS SV
                                                            , upper( trim( vd.nome ) ) VD
                                                            , date_trunc('month',comod.data_dx_emissao) AS data_dx
                                                    FROM    comodatos_emitidos comod
                                                            INNER JOIN clientes_dados_cadastrais CDC ON comod.COD_CLIENTE = CDC.COD_CLIENTE
                                                            INNER JOIN clientes_dados_basicos bas ON bas.cod_cliente = cdc.cod_cliente
                                                            INNER JOIN produtos P ON comod.COD_PRODUTO = P.COD_PRODUTO
                                                            INNER JOIN produtos_marcas PM ON P.COD_MARCA = PM.COD_MARCA

                                                            INNER JOIN produtos_comodataveis PC ON comod.cod_produto = PC.cod_produto
                                                            INNER JOIN produtos_tipo_comodatavel PTC ON PC.cod_tipo_comodatavel = PTC.cod_tipo_comodatavel
                                                            INNER JOIN produtos_grupo_comodatavel PGC ON PGC.cod_grupo_comodatavel = PTC.cod_grupo_comodatavel
                                                            LEFT JOIN clientes_dados_matriz_potencial matriz ON matriz.cod_cliente = CDC.cod_cliente

                                                            LEFT JOIN LATERAL (
                                                                                SELECT vd.nome
                                                                                FROM   hierarquia_comercial_historico vd
                                                                                WHERE  vd.codigo_colaborador = bas.vd
                                                                                ORDER BY vd.data_mx DESC
                                                                                LIMIT 1
                                                                            ) vd ON TRUE
                                                    WHERE   date_trunc('month',comod.data_dx_emissao) BETWEEN date_trunc('month', DATE {data})::DATE - INTERVAL '1 year' AND {data}
                                                            AND comod.cod_status_comodato = 'A'
                                                            AND PGC.COD_GRUPO_COMODATAVEL IN ( 1 , 6 )
                                                            AND PTC.tipo_comodatavel IN ( 'REFRIGERADOR GRANDE', 'REFRIGERADOR PEQUENO', 'CHOPPEIRA ELETRICA', 'REFRIGERADOR MINI' )
                                                            AND bas.gv IN ( 1, 4, 6 )
                                                    GROUP BY  CDC.COD_HEINEKEN
                                                            , CDC.cod_cliente
                                                            , CDC.RAZAO_SOCIAL
                                                            , matriz.segmentacao
                                                            , CDC.NUM_CPF_CNPJ
                                                            , bas.GV
                                                            , bas.SV
                                                            , vd.nome
                                                            , ptc.COD_TIPO_COMODATAVEL
                                                            ,comod.data_dx_emissao

                                          )
                                     , volume as (

                                            SELECT  UPPER( user || CDC.COD_HEINEKEN ) AS CODIGO_BW
                                                    , CMI.cod_cliente
                                                    , CASE WHEN TIPO_COMODATAVEL LIKE '%CAIXAR%' THEN 'CAIXARIAS'
                                                           WHEN TIPO_COMODATAVEL LIKE '%VASIL%'  THEN 'VASILHAMES' ELSE CMI.GRUPO_COMODATAVEL END AS GRUPO_COMODATAVEL

                                                    , CMI.cod_tipo_comodatavel
                                                    , CMI.TIPO_COMODATAVEL
                                                    , CMI.GRUPO_COMODATAVEL

                                                    -- MES 0
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} THEN cur.SALDO_HL ELSE 0 END) AS MES_0_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_0_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_0_STATUS

                                                    -- MES 1
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '1 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_1_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '1 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_1_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '1 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_1_STATUS

                                                    -- MES 2
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '2 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_2_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '2 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_2_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '2 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_2_STATUS

                                                    -- MES 3
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '3 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_3_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '3 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_3_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '3 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_3_STATUS

                                                    -- MES 4
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '4 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_4_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '4 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_4_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '4 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_4_STATUS

                                                    -- MES 5
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '5 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_5_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '5 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_5_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '5 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_5_STATUS

                                                    -- MES 6
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '6 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_6_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '6 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_6_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '6 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_6_STATUS

                                                    -- MES 7
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '7 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_7_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '7 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_7_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '7 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_7_STATUS

                                                    -- MES 8
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '8 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_8_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '8 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_8_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '8 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_8_STATUS

                                                    -- MES 9
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '9 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_9_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '9 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_9_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '9 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_9_STATUS

                                                    -- MES 10
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '10 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_10_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '10 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_10_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '10 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_10_STATUS

                                                    -- MES 11
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '11 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_11_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '11 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_11_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '11 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_11_STATUS

                                                    -- MES 12
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '12 MONTH' THEN cur.SALDO_HL ELSE 0 END) AS MES_12_SALDO_HL
                                                    , SUM(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '12 MONTH' THEN CMI.SALDO_QUANTIDADE ELSE 0 END) AS MES_12_SALDO_QUANTIDADE
                                                    , MAX(CASE WHEN CMI.DATA_MX = DATE {data} - INTERVAL '12 MONTH' THEN CUR.STATUS_GIRO_MATERIAIS_HL END) AS MES_12_STATUS

                                                    , CMI.data_mx
                                            FROM    ds_agm_comodatos_material_investido CMI
                                                    INNER JOIN clientes_dados_basicos cdb ON CMI.cod_cliente = cdb.cod_cliente
                                                    INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CDC.COD_CLIENTE = cdb.COD_CLIENTE
                                                    LEFT JOIN ds_agm_comodatos_metas_vs_real_por_grupo cur ON CUR.DATA_MX = CMI.DATA_MX
                                                                                                          AND CUR.COD_CLIENTE = CMI.COD_CLIENTE
                                                                                                          AND CUR.GRUPO_COMODATAVEL = CMI.GRUPO_COMODATAVEL
                                                                                                          AND cmi.cod_status_comodato = 'A'
                                            WHERE   CMI.data_mx BETWEEN {data}::DATE - INTERVAL '1 year' AND {data}
                                                    AND CMI.cod_tipo_comodatavel IN ( 1, 2, 22 )
                                            GROUP BY CMI.cod_cliente
                                                   , TIPO_COMODATAVEL
                                                   , CUR.STATUS_GIRO_MATERIAIS_UMB
                                                   , CUR.STATUS_GIRO_MATERIAIS_HL
                                                   , CMI.GRUPO_COMODATAVEL
                                                   , CMI.data_mx
                                                   , CDC.COD_HEINEKEN
                                                   , CMI.cod_tipo_comodatavel
                                    )
                                    , geral as (

                                                SELECT    B.CODIGO_OPERACAO
                                                        , B.NOME_OPERACAO
                                                        , B.CNPJ_REVENDA
                                                        , B.CODIGO_BW
                                                        , B.COD_CLIENTE
                                                        , B.NOME_PDV
                                                        , B.SEGMENTACAO
                                                        , B.CNPJ_CPF
                                                        , B.GVE
                                                        , B.GV
                                                        , B.SV
                                                        , B.VD

                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 1 THEN MES_0_SALDO_QUANTIDADE ELSE 0 END ) AS REFRIGERADOR_8CX
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 2 THEN MES_0_SALDO_QUANTIDADE ELSE 0 END ) AS REFRIGERADOR_4CX
                                                        , 0 AS REFRIGERADOR_1CX
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 22 THEN MES_0_SALDO_QUANTIDADE ELSE 0 END ) AS CHOPEIRAS

                                                        , SUM( MES_0_SALDO_QUANTIDADE ) AS TOTAL_EQUIPAMENTOS

                                                        -- Volume
                                                        , SUM(COALESCE(MES_0_SALDO_HL,0)) AS MES_0_SALDO_HL
                                                        , SUM(COALESCE(MES_0_SALDO_QUANTIDADE,0)) AS MES_0_SALDO_QUANTIDADE
                                                        , MAX(MES_0_STATUS) AS MES_0_STATUS
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 1  THEN MES_0_SALDO_QUANTIDADE * 2   ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 2  THEN MES_0_SALDO_QUANTIDADE * 1.2 ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 22 THEN MES_0_SALDO_QUANTIDADE * 3   ELSE 0 END ) AS MES_0_META

                                                        , SUM(COALESCE(MES_1_SALDO_HL,0)) AS MES_1_SALDO_HL
                                                        , SUM(COALESCE(MES_1_SALDO_QUANTIDADE,0)) AS MES_1_SALDO_QUANTIDADE
                                                        , MAX(MES_1_STATUS) AS MES_1_STATUS
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 1  THEN MES_1_SALDO_QUANTIDADE * 2   ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 2  THEN MES_1_SALDO_QUANTIDADE * 1.2 ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 22 THEN MES_1_SALDO_QUANTIDADE * 3   ELSE 0 END ) AS MES_1_META

                                                        , SUM(COALESCE(MES_2_SALDO_HL,0)) AS MES_2_SALDO_HL
                                                        , SUM(COALESCE(MES_2_SALDO_QUANTIDADE,0)) AS MES_2_SALDO_QUANTIDADE
                                                        , MAX(MES_2_STATUS) AS MES_2_STATUS
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 1  THEN MES_2_SALDO_QUANTIDADE * 2   ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 2  THEN MES_2_SALDO_QUANTIDADE * 1.2 ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 22 THEN MES_2_SALDO_QUANTIDADE * 3   ELSE 0 END ) AS MES_2_META

                                                        , SUM(COALESCE(MES_3_SALDO_HL,0)) AS MES_3_SALDO_HL
                                                        , SUM(COALESCE(MES_3_SALDO_QUANTIDADE,0)) AS MES_3_SALDO_QUANTIDADE
                                                        , MAX(MES_3_STATUS) AS MES_3_STATUS
                                                        , SUM( CASE WHEN V.cod_tipo_comodatavel = 1  THEN MES_3_SALDO_QUANTIDADE * 2   ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 2  THEN MES_3_SALDO_QUANTIDADE * 1.2 ELSE 0 END ) +
                                                          SUM( CASE WHEN V.cod_tipo_comodatavel = 22 THEN MES_3_SALDO_QUANTIDADE * 3   ELSE 0 END ) AS MES_3_META

                                                        , SUM(COALESCE(MES_4_SALDO_HL,0)) AS MES_4_SALDO_HL
                                                        , SUM(COALESCE(MES_4_SALDO_QUANTIDADE,0)) AS MES_4_SALDO_QUANTIDADE
                                                        , MAX(MES_4_STATUS) AS MES_4_STATUS

                                                        , SUM(COALESCE(MES_5_SALDO_HL,0)) AS MES_5_SALDO_HL
                                                        , SUM(COALESCE(MES_5_SALDO_QUANTIDADE,0)) AS MES_5_SALDO_QUANTIDADE
                                                        , MAX(MES_5_STATUS) AS MES_5_STATUS

                                                        , SUM(COALESCE(MES_6_SALDO_HL,0)) AS MES_6_SALDO_HL
                                                        , SUM(COALESCE(MES_6_SALDO_QUANTIDADE,0)) AS MES_6_SALDO_QUANTIDADE
                                                        , MAX(MES_6_STATUS) AS MES_6_STATUS

                                                        , SUM(COALESCE(MES_7_SALDO_HL,0)) AS MES_7_SALDO_HL
                                                        , SUM(COALESCE(MES_7_SALDO_QUANTIDADE,0)) AS MES_7_SALDO_QUANTIDADE
                                                        , MAX(MES_7_STATUS) AS MES_7_STATUS

                                                        , SUM(COALESCE(MES_8_SALDO_HL,0)) AS MES_8_SALDO_HL
                                                        , SUM(COALESCE(MES_8_SALDO_QUANTIDADE,0)) AS MES_8_SALDO_QUANTIDADE
                                                        , MAX(MES_8_STATUS) AS MES_8_STATUS

                                                        , SUM(COALESCE(MES_9_SALDO_HL,0)) AS MES_9_SALDO_HL
                                                        , SUM(COALESCE(MES_9_SALDO_QUANTIDADE,0)) AS MES_9_SALDO_QUANTIDADE
                                                        , MAX(MES_9_STATUS) AS MES_9_STATUS

                                                        , SUM(COALESCE(MES_10_SALDO_HL,0)) AS MES_10_SALDO_HL
                                                        , SUM(COALESCE(MES_10_SALDO_QUANTIDADE,0)) AS MES_10_SALDO_QUANTIDADE
                                                        , MAX(MES_10_STATUS) AS MES_10_STATUS

                                                        , SUM(COALESCE(MES_11_SALDO_HL,0)) AS MES_11_SALDO_HL
                                                        , SUM(COALESCE(MES_11_SALDO_QUANTIDADE,0)) AS MES_11_SALDO_QUANTIDADE
                                                        , MAX(MES_11_STATUS) AS MES_11_STATUS

                                                        , SUM(COALESCE(MES_12_SALDO_HL,0)) AS MES_12_SALDO_HL
                                                        , SUM(COALESCE(MES_12_SALDO_QUANTIDADE,0)) AS MES_12_SALDO_QUANTIDADE
                                                        , MAX(MES_12_STATUS) AS MES_12_STATUS
                                                    FROM base b
                                                         LEFT JOIN volume v ON b.codigo_bw = v.codigo_bw
                                                    GROUP BY
                                                          B.CODIGO_OPERACAO
                                                        , B.NOME_OPERACAO
                                                        , B.CNPJ_REVENDA
                                                        , B.CNPJ_CPF
                                                        , B.CODIGO_BW
                                                        , B.COD_CLIENTE
                                                        , B.NOME_PDV
                                                        , B.SEGMENTACAO
                                                        , B.GVE
                                                        , B.GV
                                                        , B.SV
                                                        , B.VD
                                        )

                            SELECT    CODIGO_OPERACAO AS ""CODIGO OPERACAO""
                                    , NOME_OPERACAO AS ""NOME OPERACAO""
                                    , CNPJ_REVENDA AS ""CNPJ REVENDA""
                                    , CODIGO_BW AS ""CODIGO BW""
                                    , COD_CLIENTE AS ""COD CLIENTE""
                                    , NOME_PDV AS ""NOME PDV""
                                    , SEGMENTACAO AS ""SEGMENTAÇÃO""
                                    , CNPJ_CPF AS ""CNPJ/CPF""
                                    , GVE AS ""GVE""
                                    , GV AS ""GV""
                                    , SV AS ""SV""
                                    , VD AS ""VD""
                                    , '' AS ESPACO_01

--                                     -- Equipamentos
                                    , REFRIGERADOR_8CX AS ""REFRIGERADOR 8CX""
                                    , REFRIGERADOR_4CX AS ""REFRIGERADOR 4CX""
                                    , REFRIGERADOR_1CX AS ""REFRIGERADOR 1CX""
                                    , CHOPEIRAS AS ""CHOPEIRAS""
                                    , TOTAL_EQUIPAMENTOS AS ""TOTAL EQUIPAMENTOS""
                                    , '' AS ESPACO_02

                                    -- Volume Trimestre
                                    , MES_1_META + MES_2_META + MES_3_META AS ""META HL""
--
                                    , MES_0_SALDO_HL as ""{nomeMes.ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_1_SALDO_HL as ""{nomeMes.AddMonths(-1).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_2_SALDO_HL as ""{nomeMes.AddMonths(-2).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_3_SALDO_HL as ""{nomeMes.AddMonths(-3).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , (MES_1_SALDO_HL + MES_2_SALDO_HL + MES_3_SALDO_HL) AS ""TOTAL HL TRIMESTRE""
                                    , CASE  WHEN MES_1_SALDO_HL >= (REFRIGERADOR_8CX * 2 + REFRIGERADOR_4CX * 1.2 + REFRIGERADOR_1CX * 0.85 + CHOPEIRAS * 3)
                                             AND MES_2_SALDO_HL >= (REFRIGERADOR_8CX * 2 + REFRIGERADOR_4CX * 1.2 + REFRIGERADOR_1CX * 0.85 + CHOPEIRAS * 3)
                                             AND MES_3_SALDO_HL >= (REFRIGERADOR_8CX * 2 + REFRIGERADOR_4CX * 1.2 + REFRIGERADOR_1CX * 0.85 + CHOPEIRAS * 3)  THEN 'BATEU META'
                                            WHEN MES_1_SALDO_HL = 0 AND MES_2_SALDO_HL = 0 AND MES_3_SALDO_HL = 0 THEN 'GIRO ZERO'
                                          ELSE 'BAIXO GIRO' END AS ""STATUS DO TRIMESTRE""
                                    , '' AS ESPACO_03

                                    -- Volume Anual
                                    , MES_0_SALDO_HL AS ""{nomeMes.ToString("MMM yyyy", cultura).ToUpper()} ""
                                    , MES_0_SALDO_QUANTIDADE AS ""{nomeMes.ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_0_STATUS AS ""{nomeMes.ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_1_SALDO_HL AS ""{nomeMes.AddMonths(-1).ToString("MMM yyyy", cultura).ToUpper()} ""
                                    , MES_1_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-1).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_1_STATUS AS ""{nomeMes.AddMonths(-1).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_2_SALDO_HL AS ""{nomeMes.AddMonths(-2).ToString("MMM yyyy", cultura).ToUpper()} ""
                                    , MES_2_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-2).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_2_STATUS AS ""{nomeMes.AddMonths(-2).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_3_SALDO_HL AS ""{nomeMes.AddMonths(-3).ToString("MMM yyyy", cultura).ToUpper()} ""
                                    , MES_3_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-3).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_3_STATUS AS ""{nomeMes.AddMonths(-3).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_4_SALDO_HL AS ""{nomeMes.AddMonths(-4).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_4_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-4).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_4_STATUS AS ""{nomeMes.AddMonths(-4).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_5_SALDO_HL AS ""{nomeMes.AddMonths(-5).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_5_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-5).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_5_STATUS AS ""{nomeMes.AddMonths(-5).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_6_SALDO_HL AS ""{nomeMes.AddMonths(-6).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_6_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-63).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_6_STATUS AS ""{nomeMes.AddMonths(-6).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_7_SALDO_HL AS ""{nomeMes.AddMonths(-7).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_7_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-7).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_7_STATUS AS ""{nomeMes.AddMonths(-7).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_8_SALDO_HL AS ""{nomeMes.AddMonths(-8).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_8_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-8).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_8_STATUS AS ""{nomeMes.AddMonths(-8).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_9_SALDO_HL AS ""{nomeMes.AddMonths(-9).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_9_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-9).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_9_STATUS AS ""{nomeMes.AddMonths(-9).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_10_SALDO_HL AS ""{nomeMes.AddMonths(-10).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_10_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-10).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_10_STATUS AS ""{nomeMes.AddMonths(-10).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_11_SALDO_HL AS ""{nomeMes.AddMonths(-11).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_11_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-11).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_11_STATUS AS ""{nomeMes.AddMonths(-11).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                                    , MES_12_SALDO_HL AS ""{nomeMes.AddMonths(-12).ToString("MMM yyyy", cultura).ToUpper()}""
                                    , MES_12_SALDO_QUANTIDADE AS ""{nomeMes.AddMonths(-12).ToString("MMM yyyy", cultura).ToUpper()} QTND""
                                    , MES_12_STATUS AS ""{nomeMes.AddMonths(-12).ToString("MMM yyyy", cultura).ToUpper()} STATUS""

                            FROM geral g ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void Base_VD(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);

                string query = @"  SELECT  vd
                                        , nome
                                   FROM	  tbl_vendedores";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["$Package::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["$Package::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                            WITH calendario AS (
                                                  SELECT  DATE_FORMAT(@Data, '%Y-%m-01') AS data_inicial, -- Primeiro dia do mês
                                                          LAST_DAY(@Data) AS data_final, -- Último dia do mês
                                                          DATE_FORMAT(@Data, '%Y-%m-%d') AS data_emissao -- Data atual
                                               )
                            SELECT    c.data_inicial,
                                      c.data_final,
                                      c.data_emissao,
                                      -- Contagem de dias úteis no mês (segunda a sexta),
                                      (	   SELECT COUNT(*) 
			                               FROM (
			                                        SELECT DATE_ADD(c.data_inicial, INTERVAL seq DAY) AS data_dia
			                                        FROM (SELECT 0 seq UNION 
			                                                ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 
			                                                UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 
			                                                UNION ALL SELECT 9 UNION ALL SELECT 10 UNION ALL SELECT 11 UNION ALL SELECT 12 
			                                                UNION ALL SELECT 13 UNION ALL SELECT 14 UNION ALL SELECT 15 UNION ALL SELECT 16 
			                                                UNION ALL SELECT 17 UNION ALL SELECT 18 UNION ALL SELECT 19 UNION ALL SELECT 20 
			                                                UNION ALL SELECT 21 UNION ALL SELECT 22 UNION ALL SELECT 23 UNION ALL SELECT 24 
			                                                UNION ALL SELECT 25 UNION ALL SELECT 26 UNION ALL SELECT 27 UNION ALL SELECT 28 
			                                                UNION ALL SELECT 29 UNION ALL SELECT 30) AS numeros
			                                        JOIN calendario c ON 1 = 1 -- Substitua ""sua_tabela"" pelo nome correto da tabela
			                                    ) AS dias
			                                    WHERE data_dia BETWEEN c.data_inicial AND c.data_final
			                                        AND WEEKDAY(data_dia) NOT IN (5,6) -- Exclui sábados (5) e domingos (6)
                                        ) AS dias_uteis,
                                        -- Dias decorridos até a data_emissao
                                        DATEDIFF(c.data_emissao, c.data_inicial) AS dias_decorridos,
                                        -- Dias restantes até o final do mês
                                        DATEDIFF(c.data_final, c.data_emissao) AS dias_restantes,
                                        -- Dia anterior à data_emissao
                                        DATE_SUB(c.data_emissao, INTERVAL 1 DAY) AS dia_anterior,
                                        -- Mês atual
                                        MONTH(c.data_emissao) AS mes_atual,
                                        -- Ano Atual
                                        YEAR(c.data_emissao) AS ano_atual,
                                        -- Mês anterior
                                        MONTH(DATE_SUB(c.data_emissao, INTERVAL 1 MONTH)) AS mes_anterior,
                                        -- Ano anterior
                                        YEAR(DATE_SUB(c.data_emissao, INTERVAL 1 YEAR)) AS ano_anterior
                            FROM calendario c ";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {            
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int parametros, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, parametros, packageName); // Passando os parâmetros como objetos
               
                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
