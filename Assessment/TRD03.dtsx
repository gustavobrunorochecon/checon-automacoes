        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["$Package::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["$Package::Mes"].Value);
              
                accessDataMySql.addParameters("@Data", Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                DateTime dataAtual = DateTime.ParseExact( Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01", "yyyyMMdd", CultureInfo.InvariantCulture);

                string mes_3 = dataAtual.AddMonths(-3).ToString("MMMM", new CultureInfo("pt-BR")).ToUpper();
                string mes_2 = dataAtual.AddMonths(-2).ToString("MMMM", new CultureInfo("pt-BR")).ToUpper();
                string mes_1 = dataAtual.AddMonths(-1).ToString("MMMM", new CultureInfo("pt-BR")).ToUpper();
                string Atual = dataAtual.ToString("MMMM", new CultureInfo("pt-BR")).ToUpper();

                string query = $@" WITH base AS (

                                                    SELECT	  IF( cl.cod_revenda = 1, 201201, 223402 ) AS CODIGO_OPERACAO
                                                            , IF( cl.cod_revenda = 1, 'CHECON DISTRIBUIDORA', 'CHECON TEIXEIRA' ) AS NOME_OPERACAO
                                                            , IF( cl.cod_revenda = 1, '40.436.846/0001-82' ,'42.219.306/0001-83' ) AS CNPJ_REVENDA
                                                            , cl.codigo_bw AS CODIGO_BW											  
                                                            , cl.razao_social AS NOME_PDV
                                                            , cl.numero_cpf_cnpj AS CNPJ_CPF
                                                            , 'HUMBERTO LUCIANO HOFFMANN DE MORAES' AS GVE
                                                            , CASE	WHEN vd.gv = 1 THEN 'HENRIQUE MENEZES DANTAS'
                                                                    WHEN vd.gv = 4 THEN 'UELVIS CORDEIRO'
                                                                    WHEN vd.gv = 6 THEN 'GEVALDO BARBOSA NOVAIS JUNIOR' 
                                                                    ELSE 'PADRÃO' END AS GV
                                                            , CASE  WHEN vd.sv = 100 THEN 'GENIVALDO RODRIGUES'
                                                                        WHEN vd.sv = 300 THEN 'ALBERT REIAS SILVA'
                                                                        WHEN vd.sv = 400 THEN 'ITAMAR OLIVEIRA DE JESUS'
                                                                        WHEN vd.sv = 500 THEN 'NORMANDO DA HORA AQUINO JUNIOR'
                                                                        WHEN vd.sv = 600 THEN 'ANTONIEL DIAS'
                                                                        WHEN vd.sv = 700 THEN 'IAGO SANTANA CAETANO'                                                           
                                                                        ELSE 'PADRÃO' END AS SV
                                                            , vd.nome AS VD
                                                            , SUM( IF(   (pr.produto LIKE '%8CX%' OR pr.produto LIKE '%8 CX%') OR
                                                                            (pr.produto LIKE '%5CX%' OR pr.produto LIKE '%5 CX%') OR
                                                                            (pr.produto LIKE '%6CX%' OR pr.produto LIKE '%6 CX%') OR
                                                                            (pr.produto LIKE '%7CX%' OR pr.produto LIKE '%7 CX%') OR
                                                                            (pr.produto like '%350-449L%') OR
                                                                            (pr.produto like '%400L%') OR
                                                                            (pr.produto like '%430-499L%') OR
                                                                            (pr.produto like '%500-600L%') OR
                                                                            (pr.produto like '%450-550L%') OR
                                                                            (pr.produto like '%530-499L%') OR
                                                                            (pr.produto like '%470L%') OR
                                                                            (pr.cod_material_desempenho IN (1)) OR
                                                                            (pr.cod_material_desempenho IN (1)), 1, 0 ) ) AS REFRIGERADOR_8CX

                                                            , SUM( IF(	(pr.produto LIKE '%1CX%' OR pr.produto LIKE '%1 CX%') OR
                                                                            (pr.produto LIKE '%2CX%' OR pr.produto LIKE '%2 CX%') OR
                                                                            (pr.produto LIKE '%3CX%' OR pr.produto LIKE '%3 CX%') OR
                                                                            (pr.produto LIKE '%4CX%' OR pr.produto LIKE '%4 CX%') OR
                                                                            (pr.produto LIKE '%260-349L%') OR
                                                                            (pr.produto like '%200-300L%') OR
                                                                            (pr.produto like '%250-299L%') OR
                                                                            (pr.produto like '%160-259%') OR
                                                                            (pr.produto like '%250-350L%') OR
                                                                            (pr.produto LIKE '%160 -259L%') OR
                                                                            (pr.produto like '%200-300%') OR
                                                                            (pr.cod_material_desempenho IN (2)), 1, 0 ) ) AS REFRIGERADOR_4CX 

                                                            , 0 AS REFRIGERADOR_1CX
                                                            , pr.cod_produto AS COD_MATERIAL
                                                            , pr.produto AS DESCRICAO
                                                            , pr.marca AS MARCA
                                                            , SUM( IF( pr.cod_familia = 611, com.quantidade, 0 ) ) AS CHOPEIRAS
                                                            , IF( SUM( IF( pr.cod_familia = 611, com.quantidade, 0 ) ) > 0 , pr.produto, '' ) AS CHOPEIRAS_DESCRICAO
                                                            , IF( SUM( IF( pr.cod_familia = 611, com.quantidade, 0 ) ) > 0 , pr.marca, '' ) AS CHOPEIRAS_MARCA	 
                                                    FROM     tbl_produtos pr 
                                                            INNER JOIN tbl_comodatos_me com ON pr.cod_produto = com.cod_produto 
                                                                                           AND pr.cod_revenda = com.cod_revenda
                                                            INNER JOIN tbl_clientes cl ON cl.cod_cliente = com.cod_cliente 
                                                                                      AND cl.cod_revenda = com.cod_revenda
                                                            INNER JOIN tbl_vendedores  vd ON cl.vd = vd.vd                                                                                 
                                                    WHERE   com.`status` = 'A'
                                                            AND pr.cod_revenda IN ( @cod_revenda )
                                                            AND pr.produto NOT LIKE '%mesa%'
                                                            AND pr.cod_familia IN ( 
                                                                                          622	-- REFRG VERT 950 LTS
                                                                                        , 627	-- REFRIGERADOR HORI CG 01UN
                                                                                        , 620	-- REFRIGERADOR VERT VD 01UN
                                                                                        , 255	-- REFRIGERANTE 0,250ML 12UN
                                                                                        , 245	-- REFRIGERANTE 0,350ML 12UN
                                                                                        , 583	-- REFRIGERANTE 1,5L 06UN
                                                                                        , 210	-- REFRIGERANTE 1L 06UN
                                                                                        , 200	-- REFRIGERANTE 2L 06UN

                                                                                        , 160	-- CHOP 30L 01UN
                                                                                        , 165	-- CHOP 50L 01UN
                                                                                        , 611	-- CHOPEIRAS
                                                            )
                                                    GROUP BY cl.razao_social,
                                                             com.cod_cliente, 
                                                             cl.codigo_bw,
                                                             pr.cod_produto, 
                                                             pr.produto,
                                                             pr.marca
                                                    HAVING    SUM( IF( pr.cod_material_desempenho IN (1, 2, 3, 4) OR pr.cod_produto IN ( 5000140, 5000032, 5000139, 173465, 141183, 141184, 141212, 141205, 141207, 141417, 369847, 376230, 367598, 367291, 367595 ), com.quantidade, 0 ) ) > 0
                                                           OR SUM( IF( pr.cod_material_desempenho IN (5, 6), com.quantidade, 0 ) ) > 0
                                                           OR SUM( IF( ( pr.cod_familia = 600 AND pr.cod_produto IN ( 40585, 51493, 81535, 81536, 97390, 100557, 113121, 128416, 128459, 128460, 143687, 149842, 169620, 201204 )) OR pr.cod_material_desempenho IN (7), com.quantidade, 0 ) ) > 0
                                                           OR SUM( IF( ( pr.cod_familia = 600 AND pr.cod_produto IN ( 51452, 81533, 251141, 251159 ) ) OR  pr.cod_material_desempenho IN (8), com.quantidade, 0 ) ) > 0
                                                           OR SUM( IF( pr.cod_familia = 611, com.quantidade, 0 ) ) > 0
                                                    ORDER BY vd.cod_revenda
                                )
                          , volume AS ( 

                                SELECT  cl.codigo_bw 
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 0 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_0
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 1 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_1
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 2 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_2
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 3 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_3
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 4 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_4
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 5 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_5
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 6 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_6
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 7 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_7
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 8 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_8
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 9 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_9
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 10 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_10
                                         , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 11 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_11
                                         -- , SUM(IF( MONTH( pd.data_pedido ) = MONTH( DATE_SUB( @Data, INTERVAL 12 MONTH) ) , (pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un, 0 )) AS MES_12
                                FROM     vw_pedidos pd
                                         INNER JOIN tbl_produtos pr ON pd.cod_produto = pr.cod_produto
                                                                 AND  pd.cod_revenda = pr.cod_revenda
                                         INNER JOIN tbl_clientes cl ON pd.cod_cliente = cl.cod_cliente
                                                                 AND pd.cod_revenda = cl.cod_revenda
                                 WHERE   pd.data_pedido BETWEEN DATE_FORMAT(DATE_SUB( @Data, INTERVAL 12 MONTH), '%Y-%m-01') AND LAST_DAY( @Data )
                                         AND cl.gv IN ( 1, 4, 6 )
                                         AND pd.ocorrencia IN ( 1, 2, 4, 26 )
                                         AND cl.codigo_bw IN (
                                                                 SELECT CODIGO_BW 
                                                                 FROM   base 
                                                              )
                                 GROUP BY cl.codigo_bw
                                 HAVING SUM((pd.quantidade_emissao - pd.quantidade_retorno) / pr.qnt_un) >= 1
                              )

                            SELECT    b.*
                                    , IFNULL( v.MES_0, 0) AS MES_0
                                    , IFNULL( v.MES_1, 0) AS MES_1
                                    , IFNULL( v.MES_2, 0) AS MES_2 
                                    , IFNULL( v.MES_3, 0) AS MES_3
                                    , IFNULL( v.MES_4, 0) AS MES_4
                                    , IFNULL( v.MES_5, 0) AS MES_5
                                    , IFNULL( v.MES_6, 0) AS MES_6
                                    , IFNULL( v.MES_7, 0) AS MES_7
                                    , IFNULL( v.MES_8, 0) AS MES_8
                                    , IFNULL( v.MES_9, 0) AS MES_9
                                    , IFNULL( v.MES_10, 0) AS MES_10
                                    , IFNULL( v.MES_11, 0) AS MES_11
                                   -- , IFNULL( v.MES_12, 0) AS MES_12
                            FROM    base b
                                    LEFT JOIN volume v ON b.codigo_bw = v.codigo_bw";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["$Package::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["$Package::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["$Package::Ano"].Value.ToString() + Dts.Variables["$Package::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                                    WITH calendario AS (
                                                          SELECT  DATE_FORMAT(@Data, '%Y-%m-01') AS data_inicial, -- Primeiro dia do mês
                                                                  LAST_DAY(@Data) AS data_final, -- Último dia do mês
                                                                  DATE_FORMAT(@Data, '%Y-%m-%d') AS data_emissao -- Data atual
                                                       )
                                    SELECT    c.data_inicial,
		                                      c.data_final,
		                                      c.data_emissao,
		                                      -- Contagem de dias úteis no mês (segunda a sexta),
		                                      (	   SELECT COUNT(*) 
					                               FROM (
					                                        SELECT DATE_ADD(c.data_inicial, INTERVAL seq DAY) AS data_dia
					                                        FROM (SELECT 0 seq UNION 
					                                                ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 
					                                                UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 
					                                                UNION ALL SELECT 9 UNION ALL SELECT 10 UNION ALL SELECT 11 UNION ALL SELECT 12 
					                                                UNION ALL SELECT 13 UNION ALL SELECT 14 UNION ALL SELECT 15 UNION ALL SELECT 16 
					                                                UNION ALL SELECT 17 UNION ALL SELECT 18 UNION ALL SELECT 19 UNION ALL SELECT 20 
					                                                UNION ALL SELECT 21 UNION ALL SELECT 22 UNION ALL SELECT 23 UNION ALL SELECT 24 
					                                                UNION ALL SELECT 25 UNION ALL SELECT 26 UNION ALL SELECT 27 UNION ALL SELECT 28 
					                                                UNION ALL SELECT 29 UNION ALL SELECT 30) AS numeros
					                                        JOIN calendario c ON 1 = 1 -- Substitua ""sua_tabela"" pelo nome correto da tabela
					                                    ) AS dias
					                                    WHERE data_dia BETWEEN c.data_inicial AND c.data_final
					                                        AND WEEKDAY(data_dia) NOT IN (5,6) -- Exclui sábados (5) e domingos (6)
		                                        ) AS dias_uteis,
		                                        -- Dias decorridos até a data_emissao
		                                        DATEDIFF(c.data_emissao, c.data_inicial) AS dias_decorridos,
		                                        -- Dias restantes até o final do mês
		                                        DATEDIFF(c.data_final, c.data_emissao) + 1 AS dias_restantes,
		                                        -- Dia anterior à data_emissao
		                                        DATE_SUB(c.data_emissao, INTERVAL 1 DAY) AS dia_anterior,
                                                -- Mês atual
		                                        MONTH(c.data_emissao) AS mes_atual,
		                                        -- Ano Atual
		                                        YEAR(c.data_emissao) AS ano_atual,
		                                        -- Mês anterior
		                                        MONTH(DATE_SUB(c.data_emissao, INTERVAL 1 MONTH)) AS mes_anterior,
		                                        -- Ano anterior
		                                        YEAR(DATE_SUB(c.data_emissao, INTERVAL 1 YEAR)) AS ano_anterior
                                    FROM calendario c ";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {

            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int revenda, string packageName)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, revenda, packageName); // Passando os parâmetros como objetos

                // Salva o arquivo (se necessário)
                workbook.Save();

                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
