              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{
		        
        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["User::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["User::Mes"].Value);
            int revenda = Convert.ToInt32(Dts.Variables["User::Revenda"].Value.ToString());
            string pesquisa = Dts.Variables["User::Pesquisa"].Value.ToString();

            DateTime mesAnterior = new DateTime(ano, mes, 1);
            string mesFormatado = mesAnterior.ToString("MM. MMMM", new CultureInfo("pt-BR")).ToUpper();

            string filePath = $@"" + Dts.Variables["User::Dados"].Value.ToString() + '\\' + ano.ToString() + '\\' + mesFormatado + '\\' + pesquisa + @"\\dados\\";
            string file = "dados_" + Convert.ToString(Dts.Variables["User::Revenda"].Value) + ".xlsx";

           
            File.Delete(filePath + file);

            dados_pesquisa(Dts, filePath, file, "dados_pesquisa");
            produto_cod_pesquisa(Dts, filePath, file, "produto_cod_pesquisa");
            motivos_db(Dts, filePath, file, "motivos_db");
            respostas_db(Dts, filePath, file, "respostas_db");
            pedidos(Dts, filePath, file, "pedidos");
            Analítico(Dts, filePath, file, "Analítico");
            Base_VD(Dts, filePath, file, "Base_VD");
            dados_relatorios(Dts, filePath, file, "dados_relatorios");

            ExecutarMacroExcel(Dts.Variables["User::Dados"].Value.ToString() + '\\' + ano.ToString() + '\\' + mesFormatado + "\\" + pesquisa + @"\vba.xlsm", "build.formataArquivo", Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        #region SQL SERVER - AVANTE SALES
                
        private void dados_pesquisa(ScriptObjectModel dts, string filePath, string file, string planilha)
        {
            
            AccessDataSqlServer accessDataSqlServer = new AccessDataSqlServer(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                accessDataSqlServer.parameterClear();
                accessDataSqlServer.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);
                accessDataSqlServer.addParameters("@Cod_Pesquisa", Dts.Variables["User::Cod_Pesquisa"].Value);

                string query = @" SELECT P.COD_PESQUISA_MERC,
                                         FORMAT(P.DATINI_PESQUISA_MERC, 'dd/MM/yyyy') AS DATINI_PESQUISA_MERC,
                                         FORMAT(P.DATFIM_PESQUISA_MERC, 'dd/MM/yyyy') AS DATFIM_PESQUISA_MERC,
                                         FORMAT(P.DATA_ATUALIZACAO, 'dd/MM/yyyy') AS DATA_ATUALIZACAO,        
                                         P.DSC_PESQUISA
                                  FROM	 DBO.PESQUISA_MERCADO P                                       
                                  WHERE	 COD_PESQUISA_MERC IN ( SELECT CAST( value AS INT ) FROM STRING_SPLIT( @Cod_Pesquisa, ',' ) )";

                // Primeira execução: capturar datas
                using (SqlDataReader line = accessDataSqlServer.executeSelect(query))
                {
                    if (line.Read())
                    {
                        Dts.Variables["User::DataInicio"].Value = Convert.ToDateTime(line["DATINI_PESQUISA_MERC"]);
                        Dts.Variables["User::DataFim"].Value = Convert.ToDateTime(line["DATFIM_PESQUISA_MERC"]);
                    }
                }

                // Segunda execução: exportar para Excel
                using (SqlDataReader lineExport = accessDataSqlServer.executeSelect(query))
                {
                    if (lineExport.HasRows)
                    {
                        exportaExcel(lineExport, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no SQL SERVER - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void produto_cod_pesquisa(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataSqlServer accessDataSqlServer = new AccessDataSqlServer(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                accessDataSqlServer.parameterClear();
                accessDataSqlServer.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);
                accessDataSqlServer.addParameters("@Cod_Pesquisa", Dts.Variables["User::Cod_Pesquisa"].Value);

                string query = @"  
                                    SELECT  P.COD_PESQUISA_MERC AS COD,
                                            LTRIM(RTRIM(value)) AS PROD
                                    FROM    PESQUISA_MERCADO P
                                            CROSS APPLY (
                                                    SELECT value 
                                                    FROM STRING_SPLIT(
                                                        CASE 
                                                            WHEN P.DSC_PESQUISA LIKE '%269%' THEN '902852'
                                                            WHEN P.DSC_PESQUISA LIKE '%275%' THEN '904631'
                                                            WHEN P.DSC_PESQUISA LIKE '%330%' THEN '903478'
                                                            WHEN P.DSC_PESQUISA LIKE '%350%' THEN '902406' 
                                                            WHEN P.DSC_PESQUISA LIKE '%355%' THEN '901781' 
                                                            WHEN P.DSC_PESQUISA LIKE '%473%' THEN '902410'                                                             
                                                            ELSE ''
                                                        END, 
                                                        ','
                                                    )
                                    ) AS X                                   
                                    WHERE P.COD_PESQUISA_MERC IN ( SELECT CAST(value AS INT) FROM STRING_SPLIT(@Cod_Pesquisa, ',') )
                                 ";

                using (SqlDataReader line = accessDataSqlServer.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no SQL SERVER - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void motivos_db(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataSqlServer accessDataSqlServer = new AccessDataSqlServer(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                accessDataSqlServer.parameterClear();
                accessDataSqlServer.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);
                accessDataSqlServer.addParameters("@Cod_Pesquisa", Dts.Variables["User::Cod_Pesquisa"].Value);

                string query = @" SELECT MNP.COD_EMPREGADO,
                                         MNP.COD_PDV,
                                         MNP.COD_PESQUISA_MERC,
                                         M.COD_MOTIVO,
                                         M.COD_TIPO_MOTIVO,
                                         M.DSC_MOTIVO
                                  FROM	 DBO.PESQUISA_MERCADO P
                                         INNER JOIN dbo.MOTIVO_NAO_PESQUISA MNP ON P.COD_PESQUISA_MERC = MNP.COD_PESQUISA_MERC
                                         INNER JOIN dbo.MOTIVO M ON M.COD_MOTIVO = MNP.COD_MOTIVO 
                                                                AND M.COD_TIPO_MOTIVO = MNP.COD_TIPO_MOTIVO
                                  WHERE	 P.COD_PESQUISA_MERC IN ( SELECT CAST(value AS INT) FROM STRING_SPLIT(@Cod_Pesquisa, ',') )";

                using (SqlDataReader line = accessDataSqlServer.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no SQL SERVER - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void respostas_db(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataSqlServer accessDataSqlServer = new AccessDataSqlServer(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                accessDataSqlServer.parameterClear();
                accessDataSqlServer.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);
                accessDataSqlServer.addParameters("@Cod_Pesquisa", Dts.Variables["User::Cod_Pesquisa"].Value);

                string query = @" SELECT COD_EMPREGADO,
                                         COD_PDV
                                  FROM	 DBO.PESQUISA_MERCADO P 
                                         INNER JOIN dbo.RESPOSTA_PESQUISA_MERCADO R ON P.COD_PESQUISA_MERC = R.COD_PESQUISA_MERC
                                  WHERE	 P.COD_PESQUISA_MERC IN ( SELECT CAST(value AS INT) FROM STRING_SPLIT(@Cod_Pesquisa, ',') )
                                  GROUP  BY COD_EMPREGADO,
                                         COD_PDV";

                using (SqlDataReader line = accessDataSqlServer.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no SQL SERVER - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #endregion

        #region POSTGREE
        private void pedidos(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));

            try
            {
                accessDataPostgree.parameterClear();
                accessDataPostgree.addParameter("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataPostgree.addParameter("@Ano", Dts.Variables["User::Ano"].Value);
                accessDataPostgree.addParameter("@Mes", Dts.Variables["User::Mes"].Value);
                accessDataPostgree.addParameter("@Data", Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"SELECT   OPF.COD_CLIENTE,    
                                          SUM( OPF.SALDO_HL ) AS total_saldo,
                                          SUM( OPF.saldo_valor ) AS fat_rgb
                                 FROM     opf_analitico_mx OPF 
                                          inner join hierarquia_comercial hc on opf.vd_pedido = hc.vd
                                 WHERE    OPF.data_mx BETWEEN CURRENT_DATE - INTERVAL '3 months' AND CURRENT_DATE                                         
                                          AND OPF.COD_OPERACAO IN ( 1, 2, 4, 5 )
                                          AND hc.GV IN ( 1, 4 , 6 )
                                          AND OPF.COD_PRODUTO IN (  
                                                                    904895, 904721, 904632, 904503, 904113, 903126, 903996, 
                                                                    903478, 904961, 904952, 904932, 904901, 904894, 904782, 
                                                                    904612, 904505, 904471, 904451, 904441, 904193, 903423,
                                                                    903991, 903423, 903131, 905351, 904602, 903901, 901742, 
                                                                    901741, 901161, 905332, 904504, 903940, 903128, 902410					            
                                                                 )
                                 GROUP BY OPF.COD_CLIENTE
                                 ORDER BY OPF.COD_CLIENTE";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no Postgree - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #endregion

        #region MYSQL SERVER - PRODUÇÃO

        private void Analítico(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);

                string query = @" SELECT  cl.codigo_bw,
                                          cl.gv,
                                          cl.sv,
                                          cl.vd,
                                          cl.cod_cliente,
                                          cl.dia_semana,
                                          cl.razao_social,
                                          cl.canal,
                                          cl.categoria
                                   FROM	  tbl_clientes cl
                                   WHERE  cod_revenda IN ( @Revenda )
                                          AND cl.gv IN ( 1, 4, 6 )
                                          AND cl.Status = 'A'";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }      

        private void Base_VD(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@Revenda", Dts.Variables["User::Revenda"].Value);

                string query = @"  SELECT  vd
                                        , nome
                                   FROM	  tbl_vendedores";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        #endregion

        private void dados_relatorios(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataMySql accessDataMySql = new AccessDataMySql();

            try
            {
                accessDataMySql.parameterClear();
                accessDataMySql.addParameters("@cod_revenda", Dts.Variables["User::Revenda"].Value);
                accessDataMySql.addParameters("@Ano", Dts.Variables["User::Ano"].Value);
                accessDataMySql.addParameters("@Mes", Dts.Variables["User::Mes"].Value);
                accessDataMySql.addParameters("@Data", Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01");

                string query = @"
                            WITH calendario AS (
                                                  SELECT  DATE_FORMAT(@Data, '%Y-%m-01') AS data_inicial, -- Primeiro dia do mês
                                                          LAST_DAY(@Data) AS data_final, -- Último dia do mês
                                                          DATE_FORMAT(@Data, '%Y-%m-%d') AS data_emissao -- Data atual
                                               )
                            SELECT    c.data_inicial,
                                      c.data_final,
                                      c.data_emissao,
                                      -- Contagem de dias úteis no mês (segunda a sexta),
                                      (	   SELECT COUNT(*) 
			                               FROM (
			                                        SELECT DATE_ADD(c.data_inicial, INTERVAL seq DAY) AS data_dia
			                                        FROM (  
                                                            SELECT 0 seq 
                                                            UNION ALL SELECT 1 UNION ALL SELECT 2 UNION ALL SELECT 3 UNION ALL SELECT 4 
			                                                UNION ALL SELECT 5 UNION ALL SELECT 6 UNION ALL SELECT 7 UNION ALL SELECT 8 
			                                                UNION ALL SELECT 9 UNION ALL SELECT 10 UNION ALL SELECT 11 UNION ALL SELECT 12 
			                                                UNION ALL SELECT 13 UNION ALL SELECT 14 UNION ALL SELECT 15 UNION ALL SELECT 16 
			                                                UNION ALL SELECT 17 UNION ALL SELECT 18 UNION ALL SELECT 19 UNION ALL SELECT 20 
			                                                UNION ALL SELECT 21 UNION ALL SELECT 22 UNION ALL SELECT 23 UNION ALL SELECT 24 
			                                                UNION ALL SELECT 25 UNION ALL SELECT 26 UNION ALL SELECT 27 UNION ALL SELECT 28 
			                                                UNION ALL SELECT 29 UNION ALL SELECT 30
                                                         ) AS numeros
			                                             JOIN calendario c ON 1 = 1 -- Substitua ""sua_tabela"" pelo nome correto da tabela
			                                    ) AS dias
			                                    WHERE data_dia BETWEEN c.data_inicial AND c.data_final
			                                          AND WEEKDAY(data_dia) NOT IN ( 5, 6 ) -- Exclui sábados (5) e domingos (6)
                                        ) AS dias_uteis,
                                        -- Dias decorridos até a data_emissao
                                        DATEDIFF(c.data_emissao, c.data_inicial) AS dias_decorridos,
                                        -- Dias restantes até o final do mês
                                        DATEDIFF(c.data_final, c.data_emissao) AS dias_restantes,
                                        -- Dia anterior à data_emissao
                                        DATE_SUB(c.data_emissao, INTERVAL 1 DAY) AS dia_anterior,
                                        -- Mês atual
                                        MONTH(c.data_emissao) AS mes_atual,
                                        -- Ano Atual
                                        YEAR(c.data_emissao) AS ano_atual,
                                        -- Mês anterior
                                        MONTH(DATE_SUB(c.data_emissao, INTERVAL 1 MONTH)) AS mes_anterior,
                                        -- Ano anterior
                                        YEAR(DATE_SUB(c.data_emissao, INTERVAL 1 YEAR)) AS ano_anterior,
                                        -- Data e HOra da Geração
                                        DATE_FORMAT(NOW(), '%d/%m/%Y %H:%i:%s') AS data_geracao
                            FROM calendario c ";

                using (MySqlDataReader line = accessDataMySql.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        exportaExcel(line, filePath, file, planilha);
                    }
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no MYSQL - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {            
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public void ExecutarMacroExcel(string arquivo, string macro, int parametros)
        {
            Excel.Application excelApp = null;
            Excel.Workbooks workbooks = null;
            Excel.Workbook workbook = null;

            try
            {
                // Cria uma nova instância do Excel
                excelApp = new Excel.Application();
                excelApp.Visible = false; // Tornar o Excel visível

                // Abre o arquivo Excel
                workbooks = excelApp.Workbooks;
                workbook = workbooks.Open(arquivo, ReadOnly: false, IgnoreReadOnlyRecommended: true);

                // Executa a macro especificada
                excelApp.Run(macro, parametros); // Passando os parâmetros como objetos
               
                // Fecha o Excel e o workbook
                workbook.Close(true);
                excelApp.Quit(); // Força o fechamento do Excel

                // Libera os objetos COM para evitar que o Excel continue executando em segundo plano
                Marshal.ReleaseComObject(workbook);
                Marshal.ReleaseComObject(workbooks);
                Marshal.ReleaseComObject(excelApp);
            }
            catch (Exception ex)
            {
                // Em caso de erro, captura a exceção
                Dts.Events.FireError(0, "Erro ao executar a macro", ex.Message, "", 0);
                Dts.TaskResult = (int)ScriptResults.Failure; // Define o task como falho
            }
            finally
            {
                // Libera todos os objetos COM para evitar que o Excel continue executando em segundo plano
                GC.Collect();
                GC.WaitForPendingFinalizers();
            }
        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
