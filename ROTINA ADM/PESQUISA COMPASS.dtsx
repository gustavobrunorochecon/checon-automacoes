              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[ #region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MimeKit;
using MailKit.Security;
using MailKit.Net.Smtp;
using MySql.Data.MySqlClient;
using Mysqlx.Datatypes;
using System.Globalization;
using System.IO;
using System.Windows.Forms;
using System.Runtime.InteropServices.ComTypes;

#endregion

namespace ST_00387ddfa53f4a61a67305738af9ad71
{
    /// <summary>
    /// ScriptMain is the entry point class of the script.  Do not change the name, attributes,
    /// or parent of this class.
    /// </summary>
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {
            try
            {
                string Ano = Dts.Variables["User::Ano"].Value.ToString();
                string Mes = Dts.Variables["User::Mes"].Value.ToString() ;
                string pesquisa = Dts.Variables["User::Pesquisa"].Value.ToString();

                string dataInicio = Convert.ToDateTime(Dts.Variables["User::DataInicio"].Value).ToString("dd/MM/yyyy");
                string dataFim = Convert.ToDateTime(Dts.Variables["User::DataFim"].Value).ToString("dd/MM/yyyy");

                string Dia = Convert.ToString(DateTime.Now.Day).PadLeft(2, '0');

                DateTime mesAnterior = new DateTime( Convert.ToInt32( Ano ), Convert.ToInt32( Mes ), 1);
                string mesFormatado = mesAnterior.ToString("MM. MMMM", new CultureInfo("pt-BR")).ToUpper();

                string imagePath = @"\\192.168.0.7\dados\PUBLICO\ANALISTAS\SSIS\logo.png";
                string attachmentPath = "";

                string[] destinatarios;

                if (Dts.Variables["User::Revenda"].Value.ToString() == "1")
                {

                    destinatarios = new string[] {
                            "henrique.dantas@checon.com.br",
                            "normando.junior@checon.com.br",
                            "genivaldo.rodrigues@checon.com.br",

                            "uelvis.cordeiro@checon.com.br",
                            "itamar.oliveira@checon.com.br",
                            "aelson.almeida@checon.com.br"
                        };

                    attachmentPath = $@"\\192.168.0.7\dados\PUBLICO\ANALISTAS\SSIS\ROTINAS MENSAIS\PESQUISA COMPASS\{Ano}\{mesFormatado}\{pesquisa}\gerados\Acomp Pesquisa Compass - Checon Eunápolis.xlsx";
                }
                else
                {

                    destinatarios = new string[] {
                            "gevaldo.junior@checon.com.br",
                            "sv600.checontx@checon.com.br",
                            "sv700.checontx@checon.com.br"
                        };

                    attachmentPath = $@"\\192.168.0.7\dados\PUBLICO\ANALISTAS\SSIS\ROTINAS MENSAIS\PESQUISA COMPASS\{Ano}\{mesFormatado}\{pesquisa}\gerados\Acomp Pesquisa Compass - Checon Teixeira.xlsx";
                }

                string[] destinatariosCc = {
                    "gvendas@checon.com.br",
                    "humberto.moraes@heineken.com.br",
                    "filippe@checon.com.br"
                };
         

                if (File.Exists(attachmentPath))
                {
                    // Verificar se a data de modificação é de hoje
                    DateTime dataModificacao = File.GetLastWriteTime(attachmentPath);
                    if (dataModificacao.Date == DateTime.Today)
                    {
                       sendEmail( imagePath, attachmentPath, pesquisa, destinatarios, destinatariosCc, dataInicio, dataFim);
                    }
                    else
                    {                       
                        Dts.Events.FireError(0, "Erro ao enviar o e-mail: Data Incorreto","" ,string.Empty, 0);
                        Dts.TaskResult = (int)ScriptResults.Failure;
                    }
                } 

                Dts.TaskResult = (int)ScriptResults.Success;

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao enviar o e-mail", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        public void sendEmail(string imagePath, string attachmentPath, string pesquisa, string[] destinatarios, string[] destinatariosCc, string dataInicio, string dataFim) {

            var bodyBuilder = new BodyBuilder();

            bodyBuilder.HtmlBody = $@"<html>
                                            <head></head>
                                            <body>
                                                <br>
                                                &nbsp;&nbsp;&nbsp;" + saudacao() +
                                            $@"<br>
                                                <br>
                                                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Segue status atualizado da Pesquisa Compass {pesquisa} com o prazo entre {dataInicio} ate {dataFim}.
                                                <br>
                                                <br>
                                                <br>"
                                            + assinatura() + $@"
                                            </body>
                                         </html>";

            // Adicione a imagem como um anexo inline
            var image = bodyBuilder.LinkedResources.Add(imagePath);
            image.ContentId = "logo.png";

            bodyBuilder.Attachments.Add(attachmentPath);

            MimeMessage message = new MimeMessage();
            message.From.Add(new MailboxAddress(null, "gustavo.brunoro@checon.com.br"));
            //message.To.Add(new MailboxAddress(null, "gustavo.brunoro@checon.com.br"));

            //Adiciona cada destinatário ao campo To
            foreach (var email in destinatarios)
            {
                message.To.Add(new MailboxAddress(null, email));
            }

            if (destinatariosCc != null)
            {
                //Adiciona cada destinatário ao campo Cc
                foreach (var email in destinatariosCc)
                {
                    message.Cc.Add(new MailboxAddress(null, email));
                }
            }

            message.Subject = $"Status Pesquisa Compass " + pesquisa;
            message.Body = bodyBuilder.ToMessageBody();

            using (var client = new SmtpClient())
            {
                try
                {
                    client.Connect("smtp.office365.com", 587, SecureSocketOptions.StartTls);
                    client.Authenticate("gustavo.brunoro@checon.com.br", "Xap41697");

                    client.Send(message);
                    Console.WriteLine("E-mail enviado com sucesso!");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Erro ao enviar e-mail: {ex.Message}");
                }
                finally
                {
                    client.Disconnect(true);
                    client.Dispose();
                }
            }
        }

        public string saudacao()
        {

            DateTime horaAtual = DateTime.Now;
            TimeSpan hora = horaAtual.TimeOfDay;

            if (hora >= TimeSpan.FromHours(6) && hora < TimeSpan.FromHours(12))
            {
                return "Bom Dia!";
            }
            else if (hora >= TimeSpan.FromHours(12) && hora < TimeSpan.FromHours(18))
            {
                return "Boa Tarde!";
            }
            else
            {
                return "Boa Noite!";
            }
        }

        public string assinatura() {

            string assinatura = @"<p>Att.,</p>
                                  <br>
                                  <p>Gustavo Brunoro<br>
                                  Analista de Vendas<br>
                                  (73) 9 9963-6328 <br>
                                  Eunápolis - Ba</p>
                                  <br>
                                  <img src=""cid:logo.png"" alt=""Logo"" />";

            return assinatura;

        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
