          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;

using System.Data.Odbc;
using Bibliotecas;
using System.Collections.Generic;
using System.Windows.Forms;
using MimeKit;
using MailKit.Net.Smtp;
using MailKit.Security;

#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            List<Vendedor> data = bd_Vendedores(Dts);
            send_Email(Dts, data);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares
               
        private List<Vendedor> bd_Vendedores( ScriptObjectModel dts )
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL("x230");

            List<Vendedor> vendedores = new List<Vendedor>();

            try
            {
                String data = "'" + Dts.Variables["User::Ano"].Value.ToString() + Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0') + "01'";

                string query = $@" 
                                    SELECT  hch.codigo_colaborador as vd
                                          , hch.nome
                                    FROM  hierarquia_comercial_historico HCh
                                          INNER JOIN hierarquia_comercial hc on hch.codigo_colaborador = hc.vd
                                                                            and hc.gv = 1
                                    WHERE hch.data_mx = {data}
                                    ORDER BY hch.codigo_colaborador  ";

                using (OdbcDataReader line = accessDataPostgree.executeSelect(query))
                {
                    if (line.HasRows)
                    {
                        while (line.Read())
                        {
                            vendedores.Add(new Vendedor
                            {
                                VD = Convert.ToInt32(line["vd"]),
                                Nome = line["nome"].ToString()
                            });
                        }
                    }
                }
                
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta no POSTGREE GV 1  " , ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }

            //MessageBox.Show("Consulta realizada com Sucesso! " + vendedores.Count + " registros encontrados.", "Sucesso", MessageBoxButtons.OK, MessageBoxIcon.Information);
            return vendedores;
        }

        private void send_Email(ScriptObjectModel dts, List<Vendedor> vendedores)
        {
            string MailBody = "";
            var bodyBuilder = new BodyBuilder();

            String Mes = Dts.Variables["User::Mes"].Value.ToString().PadLeft(2, '0');
            String Ano = Dts.Variables["User::Ano"].Value.ToString();

            string imagePath = @"Y:\PUBLICO\ANALISTAS\SSIS\logo.png";

            if (vendedores == null)
            {
                Dts.Events.FireError(0, "Erro ao consulta no POSTGREE GV 1 ", "Não foram encontrados dados para o período selecionado.", string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
                return;
            }

            try
            {                
                foreach (var vendedor in vendedores)
                {
                    MailBody += "<tr>" +
                                "<td style='text-align:center;'>" + vendedor.VD + "</td>" +
                                "<td style='padding-left:10px;padding-right:30px;'>" + vendedor.Nome + "</td>" +
                                "</tr>";
                }

                bodyBuilder.HtmlBody = @"<html>
                                                <head></head>
                                                <body>
                                                    <br>
                                                    &nbsp;&nbsp;&nbsp;" + saudacao() +
                                                        @"<br>
                                                    <br>
                                                    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Confirme, por gentileza, se foram estes os vendedores que realizaram as rotas do mês de " + Convert.ToString(Mes).PadLeft(2, '0') + @"/" + Convert.ToString(Ano) + @". Caso haja alguma rota em que o colaborador responsável seja outro, por gentileza, encaminhar o nome completo.
                                                    <br>
                                                    <br>
                                                    <br>
                                                    <table border=""1"" cellpadding=""2"" style=""border-collapse: collapse;"">
                                                        <tr style=""color:white;background-Color:SkyBlue;font-weight:bold;"">
                                                            <td style='padding-bottom: 10px;padding-top: 10px;padding-left: 30px; padding-right: 30px; text-align: center;'>VD</td>
                                                            <td style='text-align: center;'>NOME VENDEDOR</td>"
                                                                + MailBody + @"
                                                        </tr>
                                                    </table>

                                                    <br>
                                                    <br>
                                                    <br>"
                                                        + assinatura() + @"
                                                </body>
                                            </html>";

                // Adicione a imagem como um anexo inline
                var image = bodyBuilder.LinkedResources.Add(imagePath);
                image.ContentId = "logo.png";

                var message = new MimeMessage();
                message.From.Add(new MailboxAddress(null, "gustavo.brunoro@checon.com.br"));
              
                message.To.Add(new MailboxAddress(null, "henrique.dantas@checon.com.br"));

                // Adicionar destinatários em cópia (Cc)                               
                message.Cc.Add(new MailboxAddress(null, "normando.junior@checon.com.br"));
                message.Cc.Add(new MailboxAddress(null, "genivaldo.rodrigues@checon.com.br"));
                message.Cc.Add(new MailboxAddress(null, "joaovitor@checon.com.br"));

                message.Priority = MessagePriority.Urgent;  // Define o e-mail como urgente
                message.Headers.Add("X-Priority", "1");  // Definindo a prioridade do cabeçalho

                message.Subject = "Setores e Vendedores - Rotas em " + Convert.ToString(Mes).PadLeft(2, '0') + '/' + Convert.ToString(Ano) + " (Eunápolis)";

                message.Body = bodyBuilder.ToMessageBody();

                using (var client = new SmtpClient())
                {

                    try
                    {
                        client.Connect("smtp.office365.com", 587, SecureSocketOptions.StartTls);
                        client.Authenticate("gustavo.brunoro@checon.com.br", "Xap41697");

                        client.Send(message);
                        Console.WriteLine("E-mail enviado com sucesso!");
                    }
                    catch (Exception ex)
                    {
                        MessageBox.Show( ex.Message, "Sucesso", MessageBoxButtons.OK, MessageBoxIcon.Information);
                        Console.WriteLine($"Erro ao enviar e-mail: {ex.Message}");
                    }
                    finally
                    {
                        client.Disconnect(true);
                        client.Dispose();
                    }
                }

                Dts.TaskResult = (int)ScriptResults.Success;

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao enviar o e-mail", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }

        }

        public string saudacao()
        {

            DateTime horaAtual = DateTime.Now;

            // Verifica se está entre 08:00 e 12:00
            if (horaAtual.TimeOfDay >= TimeSpan.Parse("06:00") && horaAtual.TimeOfDay <= TimeSpan.Parse("12:00"))
            {
                return "Bom Dia!, ";
            }
            // Verifica se está entre 12:01 e 18:00
            else if (horaAtual.TimeOfDay > TimeSpan.Parse("12:00") && horaAtual.TimeOfDay <= TimeSpan.Parse("20:00"))
            {
                return "Boa Tarde!, ";
            }

            return "";

        }
        public string assinatura()
        {

            string assinatura = @"<p>Att.,</p>
                                  <br>
                                  <p>Gustavo Brunoro<br>
                                  Analista de Vendas<br>
                                  (73) 9 9963-6328 <br>
                                  Eunápolis - Ba</p>
                                  <br>
                                  <img src=""cid:logo.png"" alt=""Logo"" />";

            return assinatura;

        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
