              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using MySql.Data.MySqlClient;
using Mysqlx.Datatypes;
using System.IO;
using OfficeOpenXml;
using System.Diagnostics;
using Npgsql;
using System.Data.Odbc;
using Bibliotecas;
using System.Data.Common;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Collections.Generic;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{
		        
        public void Main()
        {

            string planilha = "acoes_desc";

            string revenda = (Dts.Variables["User::Revenda"].Value.ToString() == "1" ? @"GCINFO_8802\" : @"GCINFO_8803\");

            string filePath = $@"C:\Users\GustavoBrunoro\CHECON DISTRIBUIDORA E TRANSPORTADORA LTDA\ANALISTAS - Documentos\SSIS\INFO\ACOES\gerados\{revenda}";
            string file = "acoes_desc.xlsx";

            bd_Dados(Dts, filePath, file, planilha);
            ConverterExcelParaCsv(filePath + file);
            File.Delete(filePath + file);
            File.Copy( ( filePath + file.Replace("xlsx","csv")) , $@" C:\Code\{revenda}\csv\" + file.Replace("xlsx", "csv"), true );

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgreSQL = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));
            DataTable resultadoFinal = new DataTable();

            try
            {
                accessDataPostgreSQL.parameterClear();

                //string query = @" 
                //                       SELECT  'b' AS tipobase
                //                             , 'FABRICA' AS origem
                //                             ,  LTRIM(acao.nome)  AS nomeacao
                //                             , CASE  WHEN acao.acao IN ( 1 ) THEN 'COMPRE E GANHE'                 -- DROP HNK
                //                                     WHEN acao.acao IN ( 2 ) THEN 'COMBO DE COBERTURA'             -- COBERTURA HNK 600 + DEV 600 
                //                                     WHEN acao.acao IN ( 3 ) THEN 'COMBO DE COBERTURA'             -- COBERTURA HNK 600 + AMS 600
                //                                     WHEN acao.acao IN ( 4 ) THEN 'COMBO DE COBERTURA'             -- COBERTURA DEV 600 + SCH 600
                //                                     WHEN acao.acao IN ( 5 ) THEN 'COMBO DE COBERTURA'             -- HNK 0.0%
                //                                     WHEN acao.acao IN ( 6 ) THEN 'COMPRE E GANHE'                 -- PLANO ECONOMY - AÇÃO DROP ADG SCHIN
                //                                     WHEN acao.acao IN ( 7 ) THEN 'COMPRE E GANHE'                 -- PLANO ECONOMY - AÇÃO DROP MF SCHIN
                //                                     WHEN acao.acao IN ( 8 ) THEN 'COBERTURA RGB'                  -- PLANO ECONOMY - COBERTURA SCHIN RGB
                //                                     WHEN acao.acao IN ( 9 ) THEN 'PFP ADEGA - RGB ( 600 + 1L )'   -- PFP ADEGAS                                              
                //                                     WHEN acao.acao IN ( 11 ) THEN 'COMBO DE COBERTURA'            -- REG RGB - COMBO FDS 1
                //                                     WHEN acao.acao IN ( 12 ) THEN 'COMBO DE COBERTURA'            -- REG RGB - COMBO FDS 2
                //                                     WHEN acao.acao IN ( 13 ) THEN 'COMPROU GANHOU'                -- SCHIN COPA NE
                //                                     WHEN acao.acao IN ( 14 ) THEN 'COMPRE E GANHE'                -- PLANO ECONOMY - NO GRAU
                //                                     WHEN acao.acao IN ( 15 ) THEN 'COMBO DE COBERTURA'            -- COBERTURA HNK LN + BLUE MOON LN
                //                                     WHEN acao.acao IN ( 16 ) THEN 'INCENTIVO COBERTURA'           -- COBERTURA BLUE MOON ( HEISHOP )
                //                                     WHEN acao.acao IN ( 17 ) THEN 'DROP PREMIUM'                  -- DROP PREMIUM
                //                                     WHEN acao.acao IN ( 18 ) THEN 'DROP MAINSTREAM - AMSTEL'      -- DROP MAINSTREAM - AMSTEL
                //                                     WHEN acao.acao IN ( 19 ) THEN 'DROP MF - DEVASSA'             -- DROP MF - DEVASSA
                //                                     WHEN acao.acao IN ( 20 ) THEN 'COMBO DE COBERTUR'             -- COMBO DEV+AMS

                //                                     END AS foco
                //                             , CASE  WHEN acao.acao IN ( 1 ) THEN 903482
                //                                     WHEN acao.acao IN ( 2 ) THEN 903482
                //                                     WHEN acao.acao IN ( 3 ) THEN 903482
                //                                     WHEN acao.acao IN ( 4 ) THEN 903061
                //                                     WHEN acao.acao IN ( 5 ) THEN 903996
                //                                     WHEN acao.acao IN ( 6 ) THEN 902411
                //                                     WHEN acao.acao IN ( 7 ) THEN 902411
                //                                     WHEN acao.acao IN ( 8 ) THEN 902411    
                //                                     WHEN acao.acao IN ( 9 ) THEN 902411                                                  
                //                                     WHEN acao.acao IN ( 11 ) THEN 904932     
                //                                     WHEN acao.acao IN ( 12 ) THEN 904932  
                //                                     WHEN acao.acao IN ( 13 ) THEN 902411 
                //                                     WHEN acao.acao IN ( 14 ) THEN 903048 
                //                                     WHEN acao.acao IN ( 15 ) THEN 903478
                //                                     WHEN acao.acao IN ( 16 ) THEN 904602
                //                                     WHEN acao.acao IN ( 17 ) THEN 903482
                //                                     WHEN acao.acao IN ( 18 ) THEN 904502
                //                                     WHEN acao.acao IN ( 19 ) THEN 903061
                //                                     WHEN acao.acao IN ( 20 ) THEN 903061
                //                                     END AS ico
                //                             ,  LTRIM( acao.descricao ) AS desc_mecanica
                //                             , '' AS ocorrencia
                //                             , 1 AS fonteDados    
                //                    FROM	   acao acao	
                //                    WHERE    ativo = 1
                //                    GROUP BY acao.nome
                //                           , acao.Descricao
                //                           , acao.acao
                //                    ORDER BY acao.acao";


                string query = @"   WITH ACOES AS (
                                                    SELECT 'b' AS tipobase
                                                            , 'FABRICA' AS origem
                                                            , CASE WHEN acao.acao IN (21) AND b.categoria = '1' THEN CONCAT( 'COMBO HNK 350 E HNK 0.0 350 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '2' THEN CONCAT( 'COMBO HNK 350 E HNK 269 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '5' THEN CONCAT( 'COMBO HNK LN E HNK 0.0 LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '6' THEN CONCAT( 'COMBO HNK LN E HNK SHOT E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '7' THEN CONCAT( 'COMBO HNK LN E FYS LIMÃO E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '8' THEN CONCAT( 'COMBO HNK 600 E FYS LIMÃO E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '9' THEN CONCAT( 'COMBO HNK 600 E AMST 600 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '10' THEN CONCAT( 'COMBO HNK 600 E HNK LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '11' THEN CONCAT( 'COMBO HNK 600 E HNK 0.0  LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '12' THEN CONCAT( 'COMBO FYS E FYS 0.0 LIMÃO E GANHE R$' )
                                                                    ELSE LTRIM( acao.nome ) END AS nomeacao
                                                            , CASE WHEN acao.acao IN (1) THEN 'COMPRE E GANHE' -- DROP HNK
                                                                    WHEN acao.acao IN (2) THEN 'COMBO DE COBERTURA' -- COBERTURA HNK 600 + DEV 600
                                                                    WHEN acao.acao IN (3) THEN 'COMBO DE COBERTURA' -- COBERTURA HNK 600 + AMS 600
                                                                    WHEN acao.acao IN (4) THEN 'COMBO DE COBERTURA' -- COBERTURA DEV 600 + SCH 600
                                                                    WHEN acao.acao IN (5) THEN 'COMBO DE COBERTURA' -- HNK 0.0%
                                                                    WHEN acao.acao IN (6) THEN 'COMPRE E GANHE' -- PLANO ECONOMY - AÇÃO DROP ADG SCHIN
                                                                    WHEN acao.acao IN (7) THEN 'COMPRE E GANHE' -- PLANO ECONOMY - AÇÃO DROP MF SCHIN
                                                                    WHEN acao.acao IN (8) THEN 'COBERTURA RGB' -- PLANO ECONOMY - COBERTURA SCHIN RGB
                                                                    WHEN acao.acao IN (9) THEN 'PFP ADEGA - RGB ( 600 + 1L )' -- PFP ADEGAS
                                                                    WHEN acao.acao IN (11) THEN 'COMBO DE COBERTURA' -- REG RGB - COMBO FDS 1
                                                                    WHEN acao.acao IN (12) THEN 'COMBO DE COBERTURA' -- REG RGB - COMBO FDS 2
                                                                    WHEN acao.acao IN (13) THEN 'COMPROU GANHOU' -- SCHIN COPA NE
                                                                    WHEN acao.acao IN (14) THEN 'COMPRE E GANHE' -- PLANO ECONOMY - NO GRAU
                                                                    WHEN acao.acao IN (15) THEN 'COMBO DE COBERTURA' -- COBERTURA HNK LN + BLUE MOON LN
                                                                    WHEN acao.acao IN (16) THEN 'INCENTIVO COBERTURA' -- COBERTURA BLUE MOON ( HEISHOP )
                                                                    WHEN acao.acao IN (17) THEN 'DROP - PREMIUM' -- DROP PREMIUM
                                                                    WHEN acao.acao IN (18) THEN 'DROP - AMSTEL' -- DROP MAINSTREAM - AMSTEL
                                                                    WHEN acao.acao IN (19) THEN 'DROP - DEVASSA' -- DROP MF - DEVASSA
                                                                    WHEN acao.acao IN (20) THEN 'COMBO DE COBERTUR' -- COMBO DEV+AMS
                                                                    WHEN acao.acao IN (21) AND b.categoria = '1' THEN CONCAT( 'COMBO HNK 350 E HNK 0.0 350 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '2' THEN CONCAT( 'COMBO HNK 350 E HNK 269 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '5' THEN CONCAT( 'COMBO HNK LN E HNK 0.0 LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '6' THEN CONCAT( 'COMBO HNK LN E HNK SHOT E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '7' THEN CONCAT( 'COMBO HNK LN E FYS LIMÃO E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '8' THEN CONCAT( 'COMBO HNK 600 E FYS LIMÃO E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '9' THEN CONCAT( 'COMBO HNK 600 E AMST 600 E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '10' THEN CONCAT( 'COMBO HNK 600 E HNK LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '11' THEN CONCAT( 'COMBO HNK 600 E HNK 0.0  LN E GANHE R$' )
                                                                    WHEN acao.acao IN (21) AND b.categoria = '12' THEN CONCAT( 'COMBO FYS E FYS 0.0 LIMÃO E GANHE R$' ) END AS foco
                                                            , CASE WHEN acao.acao IN (1)  THEN 903482
                                                                    WHEN acao.acao IN (2)  THEN 903482
                                                                    WHEN acao.acao IN (3)  THEN 903482
                                                                    WHEN acao.acao IN (4)  THEN 903061
                                                                    WHEN acao.acao IN (5)  THEN 903996
                                                                    WHEN acao.acao IN (6)  THEN 902411
                                                                    WHEN acao.acao IN (7)  THEN 902411
                                                                    WHEN acao.acao IN (8)  THEN 902411
                                                                    WHEN acao.acao IN (9)  THEN 902411
                                                                    WHEN acao.acao IN (11) THEN 904932
                                                                    WHEN acao.acao IN (12) THEN 904932
                                                                    WHEN acao.acao IN (13) THEN 902411
                                                                    WHEN acao.acao IN (14) THEN 903048
                                                                    WHEN acao.acao IN (15) THEN 903478
                                                                    WHEN acao.acao IN (16) THEN 904602
                                                                    WHEN acao.acao IN (17) THEN 903482
                                                                    WHEN acao.acao IN (18) THEN 904502
                                                                    WHEN acao.acao IN (19) THEN 903061
                                                                    WHEN acao.acao IN (20) THEN 903061 END AS ico
                                                            , LTRIM( acao.descricao ) AS desc_mecanica
                                                            , '' AS ocorrencia
                                                            , 1 AS fonteDados
                                                        FROM  acao acao
                                                              INNER JOIN acao_base b ON b.acao = acao.acao
                                                        WHERE ativo = 1
                                                        GROUP BY acao.acao, b.categoria, acao.descricao, acao.nome
                                                        ORDER BY acao.acao
                                                    )

                                    SELECT  TIPOBASE, ORIGEM, NOMEACAO, FOCO, ICO, DESC_MECANICA, OCORRENCIA, FONTEDADOS
                                    FROM    ACOES
                                    GROUP BY TIPOBASE, ORIGEM, NOMEACAO, FOCO, ICO, DESC_MECANICA, OCORRENCIA, FONTEDADOS
";

                using (OdbcDataReader reader = accessDataPostgreSQL.executeSelect(query))
                {
                    DataTable tempTable = new DataTable();
                    tempTable.Load(reader);

                    if (resultadoFinal.Columns.Count == 0)
                    {
                        resultadoFinal = tempTable.Clone();
                    }

                    foreach (DataRow row in tempTable.Rows)
                    {
                        resultadoFinal.ImportRow(row);
                    }
                }


                // Verifica se há dados e exporta
                if (resultadoFinal.Rows.Count > 0)
                {                    
                    exportaExcel(resultadoFinal.CreateDataReader(), filePath, file, planilha);                    
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta na planilha - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
            {
                try
                {

                    if (!Directory.Exists(filePath))
                    {
                        // Cria o diretório
                        Directory.CreateDirectory(filePath);
                    }

                    filePath = filePath + file;

                    // Se o arquivo não existir, crie um novo
                    if (!new FileInfo(filePath).Exists)
                    {
                        // Cria um novo arquivo Excel
                        using (var excelPackage = new ExcelPackage(filePath))
                        {
                            // Cria uma planilha se não existir
                            var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                            // Salva o arquivo
                            excelPackage.Save();
                        }
                    }
                    else
                    {

                        using (var excelPackage = new ExcelPackage(filePath))
                        {
                            if (excelPackage.Workbook.Worksheets[planilha] == null)
                            {
                                excelPackage.Workbook.Worksheets.Add(planilha);
                                excelPackage.Save();
                            }
                        }

                    }

                    using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                    {
                        ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                        // Escreve os nomes das colunas
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[1, i + 1].Value = line.GetName(i);
                        }

                        // Escreve os dados					
                        while (line.Read())
                        {
                            for (int i = 0; i < line.FieldCount; i++)
                            {
                                worksheet.Cells[row, i + 1].Value = line[i];
                            }
                            row++;
                        }

                        worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                        excelPackage.Save();
                    }

                }
                catch (Exception ex)
                {
                    Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                    Dts.TaskResult = (int)ScriptResults.Failure;
                }


            }

        public static string ConverterExcelParaCsv(string destino)
        {
            // EPPlus requer isso fora de contextos web
            ExcelPackage.LicenseContext = LicenseContext.NonCommercial;

            if (!File.Exists(destino))
            {
                Console.WriteLine("Arquivo não encontrado: " + destino);
                return "";
            }

            string diretorio = Path.GetDirectoryName(destino);
            string nomeSemExtensao = Path.GetFileNameWithoutExtension(destino);
            string caminhoCsv = Path.Combine(diretorio, nomeSemExtensao + ".csv");

            using (var pacote = new ExcelPackage(new FileInfo(destino)))
            {
                var planilha = pacote.Workbook.Worksheets[0];
                int totalLinhas = planilha.Dimension.Rows;
                int totalColunas = planilha.Dimension.Columns;

                using (StreamWriter writer = new StreamWriter(caminhoCsv, false, System.Text.Encoding.UTF8))
                {
                    for (int r = 1; r <= totalLinhas; r++)
                    {
                        string[] linha = new string[totalColunas];

                        for (int c = 1; c <= totalColunas; c++)
                        {
                            string valor = planilha.Cells[r, c].Text ?? "";

                            // Limpeza
                            valor = valor.Replace("\r", " ").Replace("\n", " ").Trim();
                            valor = valor.Replace("\"", "\"\"");

                            if (valor.Contains(";") || valor.Contains("\""))
                            {
                                valor = $"\"{valor}\"";
                            }

                            linha[c - 1] = valor;
                        }

                        writer.WriteLine(string.Join(";", linha));
                    }
                }
            }


            return caminhoCsv;


        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
            {
                Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
                Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
            };
            #endregion

	}
}]]></ProjectItem>
