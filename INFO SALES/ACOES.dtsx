              <ProjectItem
                Name="AccessDataPostgreSQL.cs"
                Encoding="UTF8"><![CDATA[using Npgsql;
using System;
using System.Collections.Generic;
using System.Data;

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    internal class AccessDataPostgreSQL
    {
        private readonly string _connectionString;
        private readonly List<NpgsqlParameter> _sqlParameterCollection;

        public AccessDataPostgreSQL( int cod_revenda )
        {
            // Inicializa a lista de parâmetros
            _sqlParameterCollection = new List<NpgsqlParameter>();

            if (cod_revenda == 1) {

                // Usa variável de ambiente para segurança ou define um valor padrão
                _connectionString = Environment.GetEnvironmentVariable("POSTGRES_CONNECTION_STRING")
                                    ?? "Host=195.200.2.37;Database=airflow;Username=x230;Password=UYYzggaop9cbsLDr7r3vLd4T2";
            }
            else {

                // Usa variável de ambiente para segurança ou define um valor padrão
                _connectionString = Environment.GetEnvironmentVariable("POSTGRES_CONNECTION_STRING")
                                    ?? "Host=195.200.2.37;Database=airflow;Username=x690;Password=A5H9MYBVeL29nZqmnT3396yJP";
            }
            
        }       

        /// <summary>
        /// Limpa os parâmetros armazenados.
        /// </summary>
        public void ParameterClear()
        {
            _sqlParameterCollection.Clear();
        }

        /// <summary>
        /// Adiciona um parâmetro para a consulta SQL.
        /// </summary>
        public void AddParameters(string nameParameter, object valueParameter)
        {
            _sqlParameterCollection.Add(new NpgsqlParameter(nameParameter, valueParameter));
        }

        /// <summary>
        /// Executa uma consulta SELECT e retorna um NpgsqlDataReader.
        /// </summary>
        public NpgsqlDataReader ExecuteSelect(string sqlTexto)
        {
            try
            {
                var sqlConnection = new NpgsqlConnection(_connectionString);
                sqlConnection.Open();

                var sqlCommand = new NpgsqlCommand(sqlTexto, sqlConnection)
                {
                    CommandTimeout = 900
                };

                sqlCommand.Parameters.AddRange(_sqlParameterCollection.ToArray());

                // Limpa os parâmetros para evitar uso indevido
                ParameterClear();

                return sqlCommand.ExecuteReader(CommandBehavior.CloseConnection);
            }
            catch (NpgsqlException ex)
            {
                throw new Exception("Erro ao executar consulta no PostgreSQL.", ex);
            }
        }

        /// <summary>
        /// Executa um comando (INSERT, UPDATE, DELETE) e retorna o número de linhas afetadas.
        /// </summary>
        public int ExecuteNonQuery(string sqlTexto)
        {
            try
            {
                using (var sqlConnection = new NpgsqlConnection(_connectionString))
                {
                    sqlConnection.Open();

                    using (var sqlCommand = new NpgsqlCommand(sqlTexto, sqlConnection))
                    {
                        sqlCommand.CommandTimeout = 900;
                        sqlCommand.Parameters.AddRange(_sqlParameterCollection.ToArray());

                        ParameterClear(); // Limpa os parâmetros após execução

                        return sqlCommand.ExecuteNonQuery();
                    }
                }
            }
            catch (NpgsqlException ex)
            {
                throw new Exception("Erro ao executar comando no PostgreSQL.", ex);
            }
        }
    }
}]]></ProjectItem>
