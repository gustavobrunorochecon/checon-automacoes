              <ProjectItem
                Name="ScriptMain.cs"
                Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using System.Data;
using Microsoft.SqlServer.Dts.Runtime;
using System.Windows.Forms;
using MySql.Data.MySqlClient;
using Mysqlx.Datatypes;
using System.IO;
using OfficeOpenXml;
using System.Diagnostics;
using Npgsql;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Data.Odbc;
using Bibliotecas;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{

    [Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
    public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
    {

        public void Main()
        {

            string planilha = "acoes";

            string revenda = (Dts.Variables["User::Revenda"].Value.ToString() == "1" ? @"GCINFO_8802\" : @"GCINFO_8803\");

            string filePath = $@"C:\Users\GustavoBrunoro\CHECON DISTRIBUIDORA E TRANSPORTADORA LTDA\ANALISTAS - Documentos\SSIS\INFO\ACOES\gerados\{revenda}";
            string file = "acoes.xlsx";

            bd_Dados(Dts, filePath, file, planilha);
            ConverterExcelParaCsv(filePath + file);
            File.Delete(filePath + file);
            File.Copy((filePath + file.Replace("xlsx", "csv")), $@" C:\Code\{revenda}\csv\" + file.Replace("xlsx", "csv"), true);

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha)
        {

            AccessDataPostgreSQL accessDataPostgreSQL = new AccessDataPostgreSQL(Convert.ToInt32(Dts.Variables["User::Revenda"].Value));
            DataTable resultadoFinal = new DataTable();

            try
            {
                accessDataPostgreSQL.parameterClear();

                String ano = Dts.Variables["User::Ano"].Value.ToString();
                String mes = Dts.Variables["User::Mes"].Value.ToString();
                String data = "'" + ano + mes.PadLeft(2, '0') + "01'";

                string query = $@"WITH  CANAL as (
                                                        SELECT    C.COD_CATEGORIA_CLIENTE 
	       				                                        , UPPER( CATEGORIA_CLIENTE ) as CATEGORIA_CLIENTE 
	       				                                        , CASE 	WHEN TRIM(CATEGORIA_CLIENTE) = 'Adega' 	              THEN 'ADEGA'
		                                                                WHEN TRIM(CATEGORIA_CLIENTE) = 'Armazém/mercearia'    THEN 'TRAD'
		                                                                WHEN TRIM(CATEGORIA_CLIENTE) = 'Bar A/B' 	          THEN 'MF'
		                                                                WHEN TRIM(CATEGORIA_CLIENTE) = 'Bar C/D' 	          THEN 'MF'
		                                                                WHEN TRIM(CATEGORIA_CLIENTE) = 'Cash & Carry' 	      THEN 'CASH CARRY'
		                                                                WHEN TRIM(CATEGORIA_CLIENTE) = 'Entretenimento Espec' THEN 'MF'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Hipermercado' 	      THEN 'ASI'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Lanchonete' 	      THEN 'MF'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Loja de Conveniência' THEN 'ASI'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Mini A/B' 	          THEN 'ASI'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Mini C/D' 	          THEN 'ASI'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Outros' 	          THEN 'MF'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Padaria/confeitaria'  THEN 'TRAD'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Restaurante A/B'      THEN 'MF'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Restaurante C/D'      THEN 'MF'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Super A/B' 	          THEN 'ASI'
	                                                                    WHEN TRIM(CATEGORIA_CLIENTE) = 'Super C/D'            THEN 'ASI'
	                                                                    ELSE '' END AS CANAL
                                                        FROM   CLIENTES_CATEGORIAS C 
                                                        GROUP BY C.COD_CATEGORIA_CLIENTE, CATEGORIA_CLIENTE
			                                    )
                                        , DROP_HNK AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP HNK' AS acao
                                                                , '8' AS meta
                                                                , CONCAT( 'COMPRE 08CX HNK 600 E GANHE 01CX HNK 600') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 1
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
				                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_AMSTEL_10x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MAINSTREAM - AMSTEL' AS acao
                                                                , '10' AS meta
                                                                , CONCAT('COMPRE 10CX AMSTEL 300 E GANHE 01CX AMSTEL 300') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 18
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
				                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_AMSTEL_25x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MAINSTREAM - AMSTEL' AS acao
                                                                , '25' AS meta
                                                                , CONCAT('COMPRE 25CX AMSTEL 600 E GANHE 01CX AMSTEL 600') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 18
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
				                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_AMSTEL_7x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MAINSTREAM - AMSTEL' AS acao
                                                                , '7' AS meta
                                                                , CONCAT('COMPRE 7CX AMSTEL 1L E GANHE 01CX AMSTEL 1L') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 18
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
				                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_DEVASSA_25x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MF - DEVASSA' AS acao
                                                                , '25' AS meta
                                                                , CONCAT('COMPRE 25CX DEVASSA 300 E GANHE 01CX DEVASSA 300') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 19
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
                                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_DEVASSA_5x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MF - DEVASSA' AS acao
                                                                , '5' AS meta
                                                                , CONCAT('COMPRE 5CX DEVASSA 600 E GANHE 01CX DEVASSA 600') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 19
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
                                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )
                                        , DROP_MF_DEVASSA_10x1 AS (
                                                        SELECT   cl.cod_cliente AS cod_cli
                                                                , 'DROP MF - DEVASSA' AS acao
                                                                , '10' AS meta
                                                                , CONCAT('COMPRE 10CX DEVASSA 1L E GANHE 01CX DEVASSA 1L') AS obs
                                                        FROM    CLIENTES_DADOS_BASICOS cl
                                                                INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC ON CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                                INNER JOIN CANAL ON CANAL.COD_CATEGORIA_CLIENTE = CDC.COD_CATEGORIA_CLIENTE
                                                                INNER JOIN acao a ON a.acao = 19
                                                                                 AND a.ativo = 1
                                                        WHERE   CANAL IN ( 'MF' )
                                                                AND cl.status_cliente = 'A' 
                                                                AND cl.gv IN ( 1, 4, 6 )                                                                   
                                                        GROUP BY  cl.cod_cliente, CANAL
                                                    )                              
                                        , ADEGA_PFP as ( 
      					                                SELECT    cl.cod_cliente AS cod_cli
                                                                , LTRIM(acao.nome)  AS acao
                                                                , '' AS meta	   
                                                                , CONCAT( 'COBERTURA SCHIN ', string_agg( CONCAT( acaobase.Pack, ' ( ' , ROUND(acaobase.META,2 )  ), ' ), ' ORDER BY CASE WHEN acaobase.Pack = 'RGB' THEN  1
                                                                                                                                                                                          WHEN acaobase.Pack = 'PLUS 1L' THEN  2
                                                                                                                                                                                          WHEN acaobase.Pack = 'PLUS ECON' THEN 3 end ) , ' )') AS obs
                                                        FROM   CLIENTES_DADOS_BASICOS cl
                                                               INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC on CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                               INNER JOIN acao_base acaobase on UPPER( acaobase.CODIGO_BW ) = UPPER( CONCAT( CURRENT_USER, CDC.COD_HEINEKEN ) )
                                                               INNER JOIN acao acao ON acao.acao = acaobase.acao 
                                                        WHERE  acao.acao IN ( 9 )
                                                               AND acao.ativo = 1
                                                        GROUP BY cl.cod_cliente, acao.nome
                                                    ) 
                                        , BASE_FECHADA AS (
            
                                                        SELECT    cl.cod_cliente AS cod_cli
                                                                , LTRIM(acao.nome)  AS acao
                                                                , COALESCE( cast(acaobase.Meta as VARCHAR(10) ) , '' ) AS meta	   
                                                                , CASE WHEN acao.acao IN ( 1 ) AND UPPER(TRIM(acaobase.Categoria)) = 'DP - 3X1'  THEN CONCAT( 'COMPRE ', CAST(acaobase.Meta AS INT), ' CX HNK 600 RGB E GANHE 01CX HNK ',  acaobase.Pack )
WHEN acao.acao IN ( 1 ) AND UPPER(TRIM(acaobase.Categoria)) = 'DP - 6X1'  THEN CONCAT( 'COMPRE ', CAST(acaobase.Meta AS INT), ' CX HNK 600 RGB E GANHE 01CX HNK ',  acaobase.Pack )
WHEN acao.acao IN ( 1 ) AND UPPER(TRIM(acaobase.Categoria)) = 'DP - 10X1' THEN CONCAT( 'COMPRE ', CAST(acaobase.Meta AS INT), ' CX HNK 600 RGB E GANHE 01CX HNK ',  acaobase.Pack )
                                                                        WHEN acao.acao IN ( 2 ) THEN CONCAT( 'COMPRE 01CX HNK 600 + 01CX DEVASSA 600 E GANHE R$50')
                                                                        WHEN acao.acao IN ( 3 ) THEN CONCAT( 'COMPRE 01CX HNK 600 + 01CX AMSTEL 600 E GANHE R$50')
                                                                        WHEN acao.acao IN ( 4 ) THEN CONCAT( 'COMPRE 01CX DEVASSA 600 + 01CX SCHIN 600 E GANHE R$30')
                                                                        WHEN acao.acao IN ( 20 ) THEN CONCAT( 'COMPRE 01CX DEVASSA 600 + 01CX AMSTEL 600 E GANHE R$30')
                                                                        WHEN acao.acao IN ( 11 ) THEN CONCAT( 'COMPRE 01CX HNK LT350 + 01CX AMSTEL LT350 + 01CX DEVASSA LT350 E GANHE R$30')
                                                                        WHEN acao.acao IN ( 12 ) THEN CONCAT( 'COMPRE 01CX HNK LT350 + 01CX AMSTEL LT350 + 01CX FYS LT350 E GANHE R$30')
                                                                        WHEN acao.acao IN ( 5 )  AND acaobase.canal = 'MF'  THEN CONCAT( 'COMPRE 01CX HNK LN +  01CX HNK LN 0,0% E GANHE R$35')
                                                                        WHEN acao.acao IN ( 5 )  AND acaobase.canal = 'ADEGA/ASI' THEN CONCAT( 'COMPRE 01CX HNK 350LT +  01CX HNK 350LT 0,0% E GANHE R$25')
                                                        END  AS obs  
                                                        FROM   CLIENTES_DADOS_BASICOS cl
                                                               INNER JOIN CLIENTES_DADOS_CADASTRAIS CDC on CL.COD_CLIENTE = CDC.COD_CLIENTE
                                                               INNER JOIN acao_base acaobase on UPPER( acaobase.CODIGO_BW ) = UPPER( CONCAT( CURRENT_USER, CDC.COD_HEINEKEN ) )
                                                               INNER JOIN acao acao ON acao.acao = acaobase.acao 
                                                        WHERE  acao.acao  IN ( 1, 2, 3, 4, 5, 11, 12, 20) 
                                                               AND acao.ativo = 1
                                                        GROUP BY acao.nome,acaobase.meta,acaobase.canal,acaobase.categoria,cl.cod_cliente, acao.acao, acaobase.Pack 
                                                        ORDER BY acao.acao, acaobase.Pack DESC		
                                                    )
                                        , ACAO_BASE as (
      						                                SELECT  * 
            				                                FROM    DROP_HNK
            				
            				                                UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_AMSTEL_10x1
            				
            				                                UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_AMSTEL_25x1
            				
            				                                UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_AMSTEL_7x1

                                                            UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_DEVASSA_25x1

                                                            UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_DEVASSA_10x1

                                                            UNION ALL

      						                                SELECT  * 
            				                                FROM    DROP_MF_DEVASSA_5x1
            				
            				                                UNION ALL
            				
            				                                SELECT  * 
            				                                FROM    ADEGA_PFP
            				
            				                                UNION ALL
            				
            				                                SELECT  * 
            				                                FROM    BASE_FECHADA
					                                    )      
					 
                                SELECT *
                                FROM   ACAO_BASE       
                   
                  ";

                using (OdbcDataReader reader = accessDataPostgreSQL.executeSelect(query))
                {
                    DataTable tempTable = new DataTable();
                    tempTable.Load(reader);

                    if (resultadoFinal.Columns.Count == 0)
                    {
                        resultadoFinal = tempTable.Clone();
                    }

                    foreach (DataRow row in tempTable.Rows)
                    {
                        resultadoFinal.ImportRow(row);
                    }
                }


                // Verifica se há dados e exporta
                if (resultadoFinal.Rows.Count > 0)
                {
                    exportaExcel(resultadoFinal.CreateDataReader(), filePath, file, planilha);
                }
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta na planilha - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        public static string ConverterExcelParaCsv(string destino)
        {
            // EPPlus requer isso fora de contextos web
            ExcelPackage.LicenseContext = LicenseContext.NonCommercial;

            if (!File.Exists(destino))
            {
                Console.WriteLine("Arquivo não encontrado: " + destino);
                return "";
            }

            string diretorio = Path.GetDirectoryName(destino);
            string nomeSemExtensao = Path.GetFileNameWithoutExtension(destino);
            string caminhoCsv = Path.Combine(diretorio, nomeSemExtensao + ".csv");

            using (var pacote = new ExcelPackage(new FileInfo(destino)))
            {
                var planilha = pacote.Workbook.Worksheets[0];
                int totalLinhas = planilha.Dimension.Rows;
                int totalColunas = planilha.Dimension.Columns;

                using (StreamWriter writer = new StreamWriter(caminhoCsv, false, System.Text.Encoding.UTF8))
                {
                    for (int r = 1; r <= totalLinhas; r++)
                    {
                        string[] linha = new string[totalColunas];

                        for (int c = 1; c <= totalColunas; c++)
                        {
                            string valor = planilha.Cells[r, c].Text ?? "";

                            // Limpeza
                            valor = valor.Replace("\r", " ").Replace("\n", " ").Trim();
                            valor = valor.Replace("\"", "\"\"");

                            if (valor.Contains(";") || valor.Contains("\""))
                            {
                                valor = $"\"{valor}\"";
                            }

                            linha[c - 1] = valor;
                        }

                        writer.WriteLine(string.Join(";", linha));
                    }
                }
            }


            return caminhoCsv;


        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

    }
}]]></ProjectItem>
