        public DataTable importarCSV(string caminhoCsv)
        {
            DataTable dataTable = new DataTable();

            string[] linhas = File.ReadAllLines(caminhoCsv);

            if (linhas.Length < 2)
                throw new Exception("Arquivo CSV vazio ou sem dados.");

            // Cabeçalho
            string[] cabecalho = linhas[0].Split(';');

            foreach (string coluna in cabecalho)
            {
                dataTable.Columns.Add(coluna.Trim());
            }

            // Linhas
            foreach (string linha in linhas.Skip(1))
            {
                if (string.IsNullOrWhiteSpace(linha))
                    continue;

                string[] campos = linha.Split(';');

                DataRow row = dataTable.NewRow();

                for (int i = 0; i < cabecalho.Length; i++)
                {
                    if (i < campos.Length && !string.IsNullOrWhiteSpace(campos[i]))
                    {
                        row[i] = campos[i].Trim();
                    }
                    else
                    {
                        row[i] = DBNull.Value;
                    }
                }

                dataTable.Rows.Add(row);
            }

            // ============================
            // 🔥 ORDENAÇÃO POR ACAO
            // ============================
            if (!dataTable.Columns.Contains("acao"))
                throw new Exception("Coluna 'acao' não encontrada para ordenação.");

            DataView dv = dataTable.DefaultView;
            dv.Sort = "[acao] ASC";

            return dv.ToTable();
        }


        public DataTable importarXLSX(string caminhoXlsx, string planilha, Dictionary<string, Type> tiposObrigatorios = null, int linhasParaInferencia = 100 )
        {
            var dataTable = new DataTable();
            var linhasAmostra = new List<object[]>();
            string[] nomesColunas;

            string connString = $"Provider=Microsoft.ACE.OLEDB.12.0;Data Source={caminhoXlsx};Extended Properties='Excel 12.0 Xml;HDR=YES';";

            using (var conn = new OleDbConnection(connString))
            {
                conn.Open();
                var cmd = new OleDbCommand($"SELECT * FROM [{planilha}$]", conn);

                using (var reader = cmd.ExecuteReader())
                {
                    if (reader == null || reader.FieldCount == 0)
                        return dataTable;

                    // Obter nome das colunas
                    nomesColunas = new string[reader.FieldCount];
                    for (int i = 0; i < reader.FieldCount; i++)
                        nomesColunas[i] = reader.GetName(i);

                    // Coletar amostras para inferência
                    int linhaCont = 0;
                    while (reader.Read() && linhaCont < linhasParaInferencia)
                    {
                        var valores = new object[reader.FieldCount];
                        for (int i = 0; i < reader.FieldCount; i++)
                            valores[i] = reader[i];

                        linhasAmostra.Add(valores);
                        linhaCont++;
                    }
                }

                conn.Close();
            }

            // Inferência de tipos
            Type[] tipos = new Type[nomesColunas.Length];
            for (int i = 0; i < nomesColunas.Length; i++)
            {
                string nomeColuna = nomesColunas[i];

                if (tiposObrigatorios != null && tiposObrigatorios.ContainsKey(nomeColuna))
                {
                    tipos[i] = tiposObrigatorios[nomeColuna];
                }
                else
                {
                    var valores = linhasAmostra.Select(l => l[i]?.ToString()).ToList();
                    tipos[i] = InferirTipoColuna(valores);
                }

                dataTable.Columns.Add(nomeColuna, tipos[i]);
            }

            // Ler novamente e preencher com tipos corretos
            using (var conn = new OleDbConnection(connString))
            {
                conn.Open();
                var cmd = new OleDbCommand($@"SELECT * FROM [{planilha}]", conn);

                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        var novaLinha = dataTable.NewRow();

                        for (int i = 0; i < nomesColunas.Length; i++)
                        {
                            object valor = reader[i];

                            if (valor == DBNull.Value || valor == null || string.IsNullOrWhiteSpace(valor.ToString()))
                            {
                                novaLinha[i] = DBNull.Value;
                            }
                            else
                            {
                                try
                                {
                                    novaLinha[i] = Convert.ChangeType(valor, tipos[i]);
                                }
                                catch
                                {
                                    novaLinha[i] = DBNull.Value;
                                }
                            }
                        }

                        dataTable.Rows.Add(novaLinha);
                    }
                }

                conn.Close();
            }

            return dataTable;
        }

        private Type InferirTipoColuna(List<string> valores)
        {
            bool isInt = true;
            bool isDecimal = true;
            bool isDateTime = true;
            bool isBool = true;

            foreach (var valor in valores.Where(v => !string.IsNullOrWhiteSpace(v)))
            {
                if (!int.TryParse(valor, out _))
                    isInt = false;

                if (!decimal.TryParse(valor, out _))
                    isDecimal = false;

                if (!DateTime.TryParse(valor, out _))
                    isDateTime = false;

                if (!bool.TryParse(valor, out _))
                    isBool = false;
            }

            if (isInt)
                return typeof(int);
            if (isDecimal)
                return typeof(decimal);
            if (isDateTime)
                return typeof(DateTime);
            if (isBool)
                return typeof(bool);

            return typeof(string);
        }

        #endregion

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
