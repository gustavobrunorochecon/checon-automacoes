          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
using System.Collections.Generic;
using System.Data;
using MySqlX.XDevAPI;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {

            int ano = Convert.ToInt32(Dts.Variables["User::Ano"].Value);
            int mes = Convert.ToInt32(Dts.Variables["User::Mes"].Value);
            string planilha = "COBERTURA DEV 600 + AMS 600";
            int acao = 20;

            string filePath = $@"" + Dts.Variables["User::Dados"].Value + @"\dados\";
            string file = "dados.xlsx";

            bd_Dados(Dts, filePath, file, planilha, acao);   

            Dts.TaskResult = (int)ScriptResults.Success;
        }

        #region Métodos auxiliares

        private void bd_Dados(ScriptObjectModel dts, string filePath, string file, string planilha, int acao)
        {

            AccessDataPostgreSQL accessDataPostgree = new AccessDataPostgreSQL();
            DataTable resultadoFinal = new DataTable();

            List<string> schemas = new List<string> { "x230", "x690" };

            try
            {
                foreach (string schema in schemas)
                {

                    string Ano = Dts.Variables["User::Ano"].Value.ToString();
                    string Mes = Dts.Variables["User::Mes"].Value.ToString();
                    string data = "'" + Ano + Mes.PadLeft(2, '0') + "01'";

                    string query = $@"WITH verificar AS (
                                                                 SELECT 1
                                                                 FROM   {schema}.ACAO
                                                                 WHERE  ACAO = {acao} 
                                                                        AND ATIVO = 1
                                                        )
                                          , COBERTOS_ANTERIOR as (
		                                                         SELECT   AB.CODIGO_BW
		                                                                , SUM( case when V.COD_AGREGADOR in ( 'D6R' ) then V.SALDO_UMB end ) as DEV600
		                                                                , SUM( case when V.COD_AGREGADOR in ( 'A600' ) then V.SALDO_UMB end ) as AMS600		                            
		                                                         FROM    {schema}.ACAO_BASE Ab
		                                                                 INNER JOIN {schema}.CLIENTES_DADOS_CADASTRAIS C on CONCAT( UPPER( '{schema}' ), C.COD_HEINEKEN ) = UPPER ( AB.CODIGO_BW ) 
		                                                                 INNER JOIN {schema}.VOLUME_AGREGADO_ANALITICO_AC V on V.COD_CLIENTE = C.COD_CLIENTE
		                                                         WHERE   AB.ACAO = {acao}
                                                                         AND AB.datainicio = {data}::DATE
		                                                                 AND V.DATA_MX = {data}::DATE - INTERVAL '1 MONTH'
		                                                                 AND V.COD_AGREGADOR IN ( 'D6R', 'A600' )
		                                                         GROUP BY AB.CODIGO_BW
                                                     )
                                           , COBERTOS_ATUAL as (
		                                                         SELECT   AB.CODIGO_BW
		                                                                , SUM( case when V.COD_AGREGADOR in ( 'D6R' ) then V.SALDO_UMB end ) as DEV600
		                                                                , SUM( case when V.COD_AGREGADOR in ( 'A600' ) then V.SALDO_UMB end ) as AMS600	
		                                                                , SUM( V.SALDO_VALOR ) as SALDO_VALOR
		                                                         FROM    {schema}.ACAO_BASE Ab
		                                                                 INNER JOIN {schema}.CLIENTES_DADOS_CADASTRAIS C on CONCAT( UPPER( '{schema}' ), C.COD_HEINEKEN ) = UPPER ( AB.CODIGO_BW ) 
		                                                                 INNER JOIN {schema}.VOLUME_AGREGADO_ANALITICO_AC V on V.COD_CLIENTE = C.COD_CLIENTE
		                                                         WHERE   AB.ACAO = {acao}
                                                                         AND AB.datainicio = {data}::DATE
		                                                                 AND V.DATA_MX = {data}
		                                                                 AND V.COD_AGREGADOR IN ( 'D6R', 'A600' )
		                                                         GROUP BY AB.CODIGO_BW
                                                     )
                                            SELECT   HC.GV 
                                                   , HC.SV
                                                   , HC.VD
                                                   , AB.CODIGO_BW
                                                   , COALESCE(MATRIZ.SEGMENTACAO, 'BRONZE' ) as SEGMENTACAO
                                                   , C.COD_CLIENTE
                                                   , C.RAZAO_SOCIAL
                                                   , C.NOME_FANTASIA
                                                   , dia_visita as dia_visita
                                                   , CC.CATEGORIA_CLIENTE
                                                   , A.DESCRICAO
                                                   , 'R$ 50 por Cobertura' as MECANICA
                                                   , COALESCE(CO.DEV600, 0) as DEV600
                                                   , COALESCE(CO.AMS600, 0) as AMS600
                                                   , COALESCE(CO.DEV600, 0) + COALESCE(CO.AMS600, 0) as VOL_ATUAL
                                                   , COALESCE(CO.SALDO_VALOR, 0) as VALOR_TOTAL
                                                   , CASE WHEN COALESCE(CO.DEV600, 0) > 0 AND COALESCE(CO.AMS600, 0) > 0 THEN 'SIM' ELSE 'NÃO' END as COBERTO
                                                   , COALESCE(CA.DEV600, 0) + COALESCE(CA.AMS600, 0) as VOL_ANTERIOR
                                            FROM    {schema}.ACAO A 
	                                                INNER JOIN {schema}.ACAO_BASE AB on AB.ACAO = A.ACAO
	                                                INNER JOIN {schema}.CLIENTES_DADOS_CADASTRAIS C on CONCAT( UPPER( '{schema}' ), C.COD_HEINEKEN ) = UPPER ( AB.CODIGO_BW )	    
	                                                INNER JOIN {schema}.CLIENTES_DADOS_COMERCIAIS CDC on CDC.COD_CLIENTE =C.COD_CLIENTE
	                                                INNER JOIN {schema}.HIERARQUIA_COMERCIAL HC on HC.VD = CDC.VD
	                                                LEFT JOIN {schema}.CLIENTES_DADOS_MATRIZ_POTENCIAL MATRIZ on MATRIZ.COD_CLIENTE = C.COD_CLIENTE
	                                                INNER JOIN {schema}.CLIENTES_CATEGORIAS CC on CC.COD_CATEGORIA_CLIENTE = C.COD_CATEGORIA_CLIENTE
	                                                INNER JOIN (  SELECT cod_cliente,STRING_AGG(dia_visita, ', ') as dia_visita
                                                                  FROM   {schema}.clientes_agenda_de_visitas 
                                                                  GROUP BY cod_cliente ) CADV on CADV.COD_CLIENTE = C.cod_cliente
                                                    LEFT JOIN COBERTOS_ANTERIOR CA on CA.CODIGO_BW = AB.CODIGO_BW
                                                    LEFT JOIN COBERTOS_ATUAL CO on CO.CODIGO_BW = AB.CODIGO_BW
                                            WHERE   A.ACAO = {acao}
                                                    AND AB.datainicio = {data}::DATE
                                                    AND EXISTS ( SELECT 1 FROM verificar )
                                            ORDER BY HC.GV 
                                                   , HC.SV
                                                   , HC.VD
                                                   , AB.CODIGO_BW";

                    if (accessDataPostgree.isExist(schema, "acao", "acao = " + acao))
                    {
                        using (OdbcDataReader reader = accessDataPostgree.executeSelect(query))
                        {
                            DataTable tempTable = new DataTable();
                            tempTable.Load(reader);

                            if (resultadoFinal.Columns.Count == 0)
                            {
                                resultadoFinal = tempTable.Clone();
                            }

                            foreach (DataRow row in tempTable.Rows)
                            {
                                resultadoFinal.ImportRow(row);
                            }
                        }
                    }
                }

                // Verifica se há dados e exporta
                if (resultadoFinal.Rows.Count > 0)
                {
                    exportaExcel(resultadoFinal.CreateDataReader(), filePath, file, planilha);
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao consulta na planilha - " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }
        }

        private void exportaExcel(DbDataReader line, string filePath, string file, string planilha, int row = 2)
        {
            try
            {

                if (!Directory.Exists(filePath))
                {
                    // Cria o diretório
                    Directory.CreateDirectory(filePath);
                }

                filePath = filePath + file;

                // Se o arquivo não existir, crie um novo
                if (!new FileInfo(filePath).Exists)
                {
                    // Cria um novo arquivo Excel
                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        // Cria uma planilha se não existir
                        var worksheet = excelPackage.Workbook.Worksheets.Add(planilha);

                        // Salva o arquivo
                        excelPackage.Save();
                    }
                }
                else
                {

                    using (var excelPackage = new ExcelPackage(filePath))
                    {
                        if (excelPackage.Workbook.Worksheets[planilha] == null)
                        {
                            excelPackage.Workbook.Worksheets.Add(planilha);
                            excelPackage.Save();
                        }
                    }

                }

                using (ExcelPackage excelPackage = new ExcelPackage(new FileInfo(filePath)))
                {
                    ExcelWorksheet worksheet = excelPackage.Workbook.Worksheets[planilha];

                    // Escreve os nomes das colunas
                    for (int i = 0; i < line.FieldCount; i++)
                    {
                        worksheet.Cells[1, i + 1].Value = line.GetName(i);
                    }

                    // Escreve os dados					
                    while (line.Read())
                    {
                        for (int i = 0; i < line.FieldCount; i++)
                        {
                            worksheet.Cells[row, i + 1].Value = line[i];
                        }
                        row++;
                    }

                    worksheet.Cells[worksheet.Dimension.Address].AutoFitColumns();

                    excelPackage.Save();
                }

            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro ao salva planilha " + planilha, ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }


        }

        #endregion

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
