          <ProjectItem
            Name="ScriptMain.cs"
            Encoding="UTF8"><![CDATA[#region Help:  Introduction to the script task
/* The Script Task allows you to perform virtually any operation that can be accomplished in
 * a .Net application within the context of an Integration Services control flow. 
 * 
 * Expand the other regions which have "Help" prefixes for examples of specific ways to use
 * Integration Services features within this script task. */
#endregion


#region Namespaces
using System;
using MySql.Data.MySqlClient;
using System.IO;
using OfficeOpenXml;
using Microsoft.SqlServer.Dts.Tasks.ScriptTask;
using System.Data.Common;
using System.Runtime.InteropServices;
using Excel = Microsoft.Office.Interop.Excel;
using System.Globalization;
using System.Data.SqlClient;
using System.Data.Odbc;
using Bibliotecas;
using System.Collections.Generic;
using System.Data;
using MySqlX.XDevAPI;
using System.Windows.Forms;
using System.Linq;
using System.Collections;
#endregion

namespace ST_1d5348b3f62c4fa29edf085caff84d1d
{
    
	[Microsoft.SqlServer.Dts.Tasks.ScriptTask.SSISScriptTaskEntryPointAttribute]
	public partial class ScriptMain : Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase
	{

        public void Main()
        {
           
            List<string> schemas = new List<string> { "x230", "x690" };

            foreach (string schema in schemas)
            {
                atualizar_Metas_Cobertura(Dts, schema );               
            }

            Dts.TaskResult = (int)ScriptResults.Success;
        }       
       
        private void atualizar_Metas_Cobertura(ScriptObjectModel dts, string schema)
        {
            AccessDataPostgreSQL accessDataPostgreSQL = new AccessDataPostgreSQL(schema);

            string Ano = Dts.Variables["User::Ano"].Value.ToString();
            string Mes = Dts.Variables["User::Mes"].Value.ToString();
            string dataString = $"{Ano}-{Mes.PadLeft(2, '0')}-01";
            DateTime dt = DateTime.ParseExact(dataString, "yyyy-MM-dd", null);
            string data = "'" + dt.ToString("yyyy-MM-dd") + "'";

            try
            {
                string updateSql = $@" with BASE as (
                                                        SELECT    VD
                                                                , C.DATA_MX
				                                                , COUNT(COD_CLIENTE) AS qtd_clientes
				                                                , COUNT(COD_CLIENTE) / 6 as MEDIA
				                                                , ( COUNT(COD_CLIENTE) / 6 ) * 0.05 as PERCENTUAL
				                                                , ROUND( ( ( COUNT(COD_CLIENTE) / 6 ) * 0.05 ) + COUNT(COD_CLIENTE) / 6,0 ) as META
				                                        FROM   COBERTURA_AGREGADO_ANALITICO_AC C
				                                        WHERE  C.DATA_MX BETWEEN (DATE {data} - INTERVAL '6 months') AND DATE {data}
				 	                                           AND COD_AGREGADOR = 'DRGB'
				                                        GROUP BY VD, C.DATA_MX
			                                          )
                                              , META AS (
                                                        SELECT VD
                                                             , 'DRGB' AS COD_AGREGADOR
                                                             , SUM(QTD_CLIENTES)
                                                             , ROUND( SUM(QTD_CLIENTES) / 6, 0 ) AS MEDIA
                                                             , ROUND( ( SUM(QTD_CLIENTES) / 6 ) * 0.05,0 ) as PERCENTUAL
				                                             , ROUND( ( SUM(QTD_CLIENTES) / 6 ) * 0.05,0 ) + ROUND( SUM(QTD_CLIENTES) / 6, 0 ) as meta_cobertura
                                                        FROM   BASE
                                                        GROUP BY VD
                                                      )

                                        INSERT INTO metas_cobertura_vd (validade_meta, cod_agregador, vd, meta_cobertura)
                                        SELECT DATE {data}, COD_AGREGADOR, vd, meta_cobertura
                                        FROM META                                      
                                        ON CONFLICT (validade_meta, cod_agregador, vd)
                                        DO UPDATE SET
                                            cod_agregador  = EXCLUDED.cod_agregador,                                           
                                            meta_cobertura = EXCLUDED.meta_cobertura";

                                     
                  accessDataPostgreSQL.executeSelect(updateSql);
                   
               
            }
            catch (Exception ex)
            {
                Dts.Events.FireError(0, "Erro no InsertOrUpdate METAS_COBERTURA_VD. Detalhes ", ex.Message, string.Empty, 0);
                Dts.TaskResult = (int)ScriptResults.Failure;
            }

        }

        #region ScriptResults declaration
        /// <summary>
        /// This enum provides a convenient shorthand within the scope of this class for setting the
        /// result of the script.
        /// 
        /// This code was generated automatically.
        /// </summary>
        enum ScriptResults
        {
            Success = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Success,
            Failure = Microsoft.SqlServer.Dts.Runtime.DTSExecResult.Failure
        };
        #endregion

	}
}]]></ProjectItem>
